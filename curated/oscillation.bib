@article{todrisanial2024computing,
  title={Computing with oscillators from theoretical underpinnings to applications and demonstrators},
  author={Todri-Sanial, Aida and Delacour, Corentin and Abernot, Madeleine and Sabo, Filip},
  journal={npj Unconventional Computing},
  volume={1},
  number={1},
  pages={14},
