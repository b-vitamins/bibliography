@article{delacour2024energyperformance,
  title={{Energy-Performance Assessment of Oscillatory Neural Networks Based on VO2 Devices for Future Edge AI Computing}},
  author={Delacour, Corentin and Carapezzi, Stefania and Abernot, Madeleine and Todri-Sanial, Aida},
  journal={IEEE Transactions on Neural Networks and Learning Systems},
  volume={35},
  number={7},
  pages={10045--10058},
  year={2024},
  publisher={IEEE},
  doi={10.1109/TNNLS.2023.3238473},
  url={https://ieeexplore.ieee.org/document/10026654/},
  pdf={https://ieeexplore.ieee.org/iel7/5962385/10589508/10026654.pdf},
  month={7},
  abstract={Oscillatory neural network (ONN) is an emerging neuromorphic architecture composed of oscillators that implement neurons and are coupled by synapses. ONNs exhibit rich dynamics and associative properties that can be used to solve problems in the analog domain according to the paradigm "let physics compute." While ONNs are promising neuromorphic architectures, there is a need to understand their scalability and their performances when implemented in hardware. This paper assesses computation time, energy consumption, performance and accuracy for given applications before deploying ONN systems. We focus on compact oscillators made of VO2 material as good candidates for building low-power ONN architectures dedicated to AI applications at the edge like pattern recognition.}
}
@article{delacour2023mixedsignal,
  title={A mixed-signal oscillatory neural network for scalable analog computations in phase domain},
  author={Delacour, Corentin and Carapezzi, Stefania and Boschetto, Gabriele and Abernot, Madeleine and Gil, Thierry and Az{\'e}mard, Nadine and Todri-Sanial, Aida},
  journal={Neuromorphic Computing and Engineering},
  volume={3},
  number={3},
  pages={034004},
  year={2023},
  publisher={IOP Publishing},
  doi={10.1088/2634-4386/ace9f5},
  url={https://iopscience.iop.org/article/10.1088/2634-4386/ace9f5},
  pdf={https://iopscience.iop.org/article/10.1088/2634-4386/ace9f5/pdf},
  month={8},
  abstract={Digital electronics based on von Neumann's architecture is reaching its limits to solve large-scale problems essentially due to the memory fetching. Instead, recent efforts to bring the memory near the computation have enabled highly parallel computations at low energy costs. Oscillatory neural networks (ONNs) are an example of in-memory analog computing paradigm consisting of coupled oscillating neurons that naturally perform gradient descent of an energy landscape, making them particularly suited for solving optimization problems. Although ONN computational capability and its link with the Ising model have been known for decades, implementing a large-scale ONN remains difficult. Beyond oscillator variations, there are design challenges such as having compact, programmable synapses and a modular architecture for solving large problem instances. In this paper, we propose SKONN (Saturated Kuramoto ONN), a mixed-signal architecture that addresses these fundamental challenges. SKONN leverages both analog and digital domains for efficient ONN hardware implementation: it computes in the analog phase domain and propagates information digitally to facilitate scaling up the ONN size. SKONN's separation between computation and propagation enhances robustness and enables a feed-forward phase propagation that we showcase for the first time. SKONN architecture leads to unique binarizing dynamics that are particularly suitable for solving NP-hard combinatorial optimization problems such as finding the weighted Max-cut of a graph. We show that SKONN's accuracy is as good as the Goemans-Williamson 0.878-approximation algorithm for Max-cut, whereas SKONN's computation time only grows logarithmically. We report on Weighted Max-cut experiments using a 9-neuron SKONN proof-of-concept on PCB.}
}
