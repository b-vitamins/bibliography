@inproceedings{rusch2025oscillatory,
  abstract = {We propose Linear Oscillatory State-Space models ({LinOSS}) for learning on long sequences. Inspired by the cortical dynamics of biological neural networks, our model is based on a system of forced harmonic oscillators. {LinOSS} produces stable dynamics only requiring nonnegative diagonal state matrix, which is in stark contrast to many previous state-space models relying heavily on restrictive parameterizations. We rigorously show that {LinOSS} is universal, i.e., it can approximate any continuous and causal operator mapping between time-varying functions to desired accuracy. Empirical results spanning a wide range of time-series tasks demonstrate that {LinOSS} consistently outperforms state-of-the-art sequence models, including outperforming {Mamba} and {LRU} by nearly 2x on sequences of length 50k.},
  archiveprefix = {arXiv},
  author = {Rusch, T. Konstantin and Rus, Daniela},
  booktitle = {International Conference on Learning Representations},
  eprint = {2410.03943},
  note = {Oral presentation. Proposes {LinOSS}, a highly stable and provably universal State-Space Model based on forced harmonic oscillators. Outperforms state-of-the-art models like {Mamba} on very long sequence tasks.},
  primaryclass = {cs.LG},
  title = {Oscillatory State-Space Models},
  url = {https://openreview.net/forum?id=GRMfXcAAFh},
  year = {2025}
}
@misc{stlzle2025learning,
  abstract = {Learning from demonstration provides a sample-efficient approach to acquiring complex behaviors, enabling robots to move robustly, compliantly, and with fluidity. Dynamic Motion Primitives offer built-in stability and robustness to disturbances but often struggle to capture complex periodic behaviors and are limited in their ability to interpolate between different tasks. We introduce Orbitally Stable Motion Primitives ({OSMPs}) - a framework that combines a learned diffeomorphic encoder with a supercritical {Hopf} bifurcation in latent space, enabling the accurate acquisition of periodic motions from demonstrations while ensuring formal guarantees of orbital stability and transverse contraction. Tested across diverse robotic platforms including collaborative arms, soft manipulators, and a bio-inspired robot.},
  archiveprefix = {arXiv},
  author = {Stölzle, Maximilian and Rusch, T. Konstantin and Patterson, Zach J. and Pérez-Dattari, Rodrigo and Stella, Francesco and Hughes, Josie and Della Santina, Cosimo and Rus, Daniela},
  eprint = {2507.10602},
  month = {7},
  primaryclass = {cs.RO},
  title = {Learning to Move in Rhythm: Task-Conditioned Motion Policies with Orbital Stability Guarantees},
  url = {https://arxiv.org/abs/2507.10602},
  year = {2025}
}
@article{yao2025brain,
  abstract = {Whole brain neural oscillation activities exhibit multiple wave phase patterns that appear to be supported by common circuit network structures. We propose a {Hopfield-Kuramoto} model that is based entirely on heterogeneous connectivity strength rather than phase delay. This model can encode multiple wave phase patterns in heterogeneous connectivity networks using the {Hebbian} rule and retrieve them as attractors. The research systematically investigates how the model's dynamic landscape is influenced by attractors and their corresponding eigenvalues, as well as methods to control the stability of equilibrium points and the occurrence of high-dimensional bifurcations. The framework enables reproduction of dominant wave activity components in human brain functional {MRI} signals, providing a canonical model for multi-body physical system spatiotemporal pattern attractor dynamics.},
  author = {Yao, Ruwei and Li, Yichao and Yao, Xintong and Wang, Kang and Qu, Jingling and Zou, Xiaolong and Hong, Bo},
  doi = {10.1103/PhysRevE.111.044310},
  journal = {Physical Review E},
  month = {4},
  note = {Develops a {Hopfield-Kuramoto} model where multiple brain wave patterns are stored as attractors using a {Hebbian}-like rule for connectivity strength, providing a physics-based generative model for {fMRI} patterns.},
  number = {4-1},
  pages = {044310},
  publisher = {American Physical Society},
  title = {Brain wave dynamics in a {Hopfield-Kuramoto} model with heterogeneous connectivity strength},
  url = {https://doi.org/10.1103/PhysRevE.111.044310},
  volume = {111},
  year = {2025}
}
@article{clark2024theory,
  abstract = {We examine a recurrent-network model where neuronal units and synaptic couplings are interacting dynamic variables, with synaptic strengths influenced by neuronal activity through activity-dependent plasticity, and neuronal activity influenced by synaptic strengths through network dynamics. Using dynamical mean-field theory and other techniques, we systematically characterize the neuronal-synaptic dynamics, revealing a rich phase diagram. Adding {Hebbian} plasticity slows activity in already chaotic networks and can induce chaos in otherwise quiescent networks. Anti-{Hebbian} plasticity quickens activity and produces an oscillatory component. A new behavior called "frozen chaos" is identified, where synapses create fixed patterns of neuronal activity, potentially crucial for working memory.},
  archiveprefix = {arXiv},
  author = {Clark, David G. and Abbott, L. F.},
  doi = {10.1103/PhysRevX.14.021001},
  eprint = {2302.08985},
  journal = {Physical Review X},
  month = {4},
  note = {Explores networks where synapses are also dynamic variables, revealing novel dynamic regimes like "frozen chaos" and proposing a new physical mechanism for working memory based on synaptic stability.},
  pages = {021001},
  primaryclass = {q-bio.NC},
  publisher = {American Physical Society},
  title = {Theory of Coupled Neuronal-Synaptic Dynamics},
  url = {https://doi.org/10.1103/PhysRevX.14.021001},
  volume = {14},
  year = {2024}
}
@article{fan2024brain,
  abstract = {Note: This entry may refer to work related to {Hopfield-Kuramoto} models for brain wave dynamics. Research in this area proposes models based on heterogeneous connectivity strength rather than phase delay, where multiple wave phase patterns can be encoded in heterogeneous connectivity networks via {Hebbian} rule and retrieved as attractors. Such frameworks enable reproduction of dominant wave activity components in human brain functional {MRI} signals.},
  author = {Fan, Z. and Liu, Z. and Wang, R. and Li, C. and Wang, Y.},
  journal = {Physical Review E},
  note = {WARNING: Entry requires verification - complete publication details not found},
  title = {Brain wave dynamics in a {Hopfield-Kuramoto} model},
  year = {2024}
}
@misc{huang2025freezing,
  abstract = {Chaos is ubiquitous in high-dimensional neural dynamics. A strong chaotic fluctuation may be harmful to information processing. A traditional way to mitigate this issue is to introduce {Hebbian} plasticity, which can stabilize the dynamics. We introduce another distinct way without synaptic plasticity. Our approach involves adding an {Onsager} reaction term due to the feedback of the neuron itself to the vanilla recurrent dynamics, making the driving force a gradient form. The original unstable fixed points supporting the chaotic fluctuation can then be approached by further decreasing the kinetic energy of the dynamics. This freezing effect also holds in more biologically realistic networks, such as those composed of excitatory and inhibitory neurons.},
  archiveprefix = {arXiv},
  author = {Huang, Weizhong and Huang, Haiping},
  eprint = {2503.08069},
  month = {3},
  primaryclass = {q-bio.NC},
  title = {Freezing chaos without synaptic plasticity},
  url = {https://arxiv.org/abs/2503.08069},
  year = {2025}
}
@inproceedings{nguyen2024coupled,
  abstract = {We propose the {Kuramoto} Graph Neural Network ({KuramotoGNN}), a novel class of continuous-depth graph neural networks ({GNNs}) that employs the {Kuramoto} model to mitigate the over-smoothing phenomenon, in which node features in {GNNs} become indistinguishable as the number of layers increases. Under the view of coupled oscillators, we first show the connection between the {Kuramoto} model and basic {GNN}, and then demonstrate that the over-smoothing phenomenon in {GNNs} can be interpreted as phase synchronization in the {Kuramoto} model. The {KuramotoGNN} replaces this phase synchronization with frequency synchronization to prevent the node features from converging into each other while allowing the system to reach a stable synchronized state.},
  archiveprefix = {arXiv},
  author = {Nguyen, Tuan and Honda, Hirotada and Sano, Takashi and Nguyen, Vinh and Nakamura, Shugo and Nguyen, Tan Minh},
  booktitle = {Proceedings of The 27th International Conference on Artificial Intelligence and Statistics},
  eprint = {2311.03260},
  pages = {2710--2718},
  publisher = {{PMLR}},
  series = {Proceedings of Machine Learning Research},
  title = {From Coupled Oscillators to Graph Neural Networks: Reducing Over-smoothing via a {Kuramoto} Model-based Approach},
  url = {https://proceedings.mlr.press/v238/nguyen24c.html},
  volume = {238},
  year = {2024}
}
@misc{rohan2024deep,
  abstract = {We propose a novel, brain-inspired deep neural network model known as the Deep Oscillatory Neural Network (DONN). Deep neural networks like the Recurrent Neural Networks indeed possess sequence processing capabilities but the internal states of the network are not designed to exhibit brain-like oscillatory activity. With this motivation, the DONN is designed to have oscillatory internal dynamics. Neurons of the DONN are either nonlinear neural oscillators or traditional neurons with sigmoidal or ReLU activation. The neural oscillator used in the model is the Hopf oscillator, with the dynamics described in the complex domain. The sigmoid and ReLU neurons also use complex-valued extensions, and all the weight stages are also complex-valued.},
  archiveprefix = {arXiv},
  author = {Rohan, Nurani Rajagopal and C, Vigneswaran and Ghosh, Sayan and Rajendran, Kishore and A, Gaurav and Chakravarthy, V. Srinivasa},
  doi = {10.48550/arXiv.2405.03725},
  eprint = {2405.03725},
  month = {5},
  openalex = {W4396813460},
  pdf = {https://arxiv.org/pdf/2405.03725.pdf},
  primaryclass = {cs.NE},
  title = {Deep Oscillatory Neural Network},
  url = {https://arxiv.org/abs/2405.03725},
  year = {2024}
}
@article{zang2024structural,
  abstract = {Oscillations arise in many real-world systems and are associated with both functional and dysfunctional states. Whether a network can oscillate can be estimated if we know the strength of interaction between nodes. But in real-world networks (in particular in biological networks) it is usually not possible to know the exact connection weights. Therefore, it is important to determine the structural properties of a network necessary to generate oscillations. Here, we provide a proof that uses dynamical system theory to prove that an odd number of inhibitory nodes and strong enough connections are necessary to generate oscillations in a single cycle threshold-linear network. We illustrate these analytical results in a biologically plausible network with either firing-rate based or spiking neurons. Our work provides structural properties necessary to generate oscillations in a network. We use this knowledge to reconcile recent experimental findings about oscillations in basal ganglia with classical findings.},
  author = {Zang, Jie and Liu, Shenquan and Helson, Pascal and Kumar, Arvind},
  doi = {10.7554/eLife.88777},
  journal = {eLife},
  month = {3},
  openalex = {W4392761779},
  pages = {e88777},
  publisher = {eLife Sciences Publications},
  title = {Structural constraints on the emergence of oscillations in multi-population neural networks},
  url = {https://elifesciences.org/articles/88777},
  pdf={https://elifesciences.org/download/aHR0cHM6Ly9jZG4uZWxpZmVzY2llbmNlcy5vcmcvYXJ0aWNsZXMvODg3NzcvZWxpZmUtODg3NzctdjIucGRmP2Nhbm9uaWNhbFVyaT1odHRwczovL2VsaWZlc2NpZW5jZXMub3JnL2FydGljbGVzLzg4Nzc3/elife-88777-v2.pdf?_hash=azQSGfuklmfueQNijDmltsgO9tjYf4%2F%2BGav6B7sspSU%3D},
  volume = {13},
  year = {2024}
}
@misc{bassey2021survey,
  abstract = {Artificial neural networks (ANNs) based machine learning models and especially deep learning models have been widely applied in computer vision, signal processing, wireless communications, and many other domains, where complex numbers occur either naturally or by design. However, most of the current implementations of ANNs and machine learning frameworks are using real numbers rather than complex numbers. There are growing interests in building ANNs using complex numbers, and exploring the potential advantages of the so-called complex-valued neural networks (CVNNs) over their real-valued counterparts. In this paper, we present a survey of the recent development of CVNNs by performing a review of the works on CVNNs in the literature. We discuss various CVNNs in terms of activation function, learning and optimization, input and output representations, and their applications in tasks such as signal processing and computer vision, followed by a discussion on some pertinent challenges and future research directions.},
  archiveprefix = {arXiv},
  author = {Bassey, Joshua and Qian, Lijun and Li, Xianfang},
  eprint = {2101.12249},
  month = {1},
  pdf = {https://arxiv.org/pdf/2101.12249.pdf},
  primaryclass = {stat.ML},
  title = {A Survey of Complex-Valued Neural Networks},
  url = {https://arxiv.org/abs/2101.12249},
  year = {2021}
}
@inproceedings{he2024robust,
  abstract = {The angular synchronization problem aims to accurately estimate (up to a constant additive phase) a set of unknown angles θ₁, ..., θₙ ∈ [0, 2π) from m noisy measurements of their offsets θᵢ - θⱼ mod 2π. Applications include sensor network localization, phase retrieval, and distributed clock synchronization. An extension of the problem to the heterogeneous setting (dubbed k-synchronization) is to estimate k groups of angles simultaneously, given noisy observations (with unknown group assignment) from each group. Existing methods for angular synchronization usually perform poorly in high-noise regimes, which are common in applications. We leverage neural networks for the angular synchronization problem, and its heterogeneous extension, by proposing GNNSync, a theoretically-grounded end-to-end trainable framework using directed graph neural networks.},
  archiveprefix = {arXiv},
  author = {He, Yixuan and Reinert, Gesine and Wipf, David and Cucuringu, Mihai},
  booktitle = {The Twelfth International Conference on Learning Representations},
  eprint = {2310.05842},
  pdf = {https://arxiv.org/pdf/2310.05842.pdf},
  primaryclass = {cs.LG},
  title = {Robust Angular Synchronization via Directed Graph Neural Networks},
  url = {https://openreview.net/forum?id=5sjxMwWmk8},
  year = {2024}
}
@inproceedings{lanthaler2023neural,
  abstract = {Coupled oscillators are being increasingly used as the basis of machine learning (ML) architectures, for instance in sequence modeling, graph representation learning and in physical neural networks that are used in analog ML devices. We introduce an abstract class of neural oscillators that encompasses these architectures and prove that neural oscillators are universal, i.e, they can approximate any continuous and causal operator mapping between time-varying functions, to desired accuracy. Our universality result provides theoretical justification for the use of oscillator-based ML systems. The proof builds on a fundamental result of independent interest, which shows that a combination of forced harmonic oscillators with a nonlinear read-out suffices to approximate the underlying operators.},
  archiveprefix = {arXiv},
  author = {Lanthaler, Samuel and Rusch, T. Konstantin and Mishra, Siddhartha},
  booktitle = {Advances in Neural Information Processing Systems},
  editor = {Oh, A. and Naumann, T. and Globerson, A. and Saenko, K. and Hardt, M. and Levine, S.},
  eprint = {2305.08753},
  openalex = {W4376654394},
  pages = {46786--46806},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2023/file/923285deb805c3e14e1aeebc9854d644-Paper-Conference.pdf},
  publisher = {Curran Associates, Inc.},
  title = {Neural Oscillators are Universal},
  url = {https://proceedings.neurips.cc/paper_files/paper/2023/hash/923285deb805c3e14e1aeebc9854d644-Abstract-Conference.html},
  volume = {36},
  year = {2023}
}
@inproceedings{rusch2022graphcoupled,
  abstract = {We propose Graph-Coupled Oscillator Networks (GraphCON), a novel framework for deep learning on graphs. It is based on discretizations of a second-order system of ordinary differential equations (ODEs), which model a network of nonlinear controlled and damped oscillators, coupled via the adjacency structure of the underlying graph. The flexibility of our framework permits any basic GNN layer (e.g. convolutional or attentional) as the coupling function, from which a multi-layer deep neural network is built up via the dynamics of the proposed ODEs. We relate the oversmoothing problem, commonly encountered in GNNs, to the stability of steady states of the underlying ODE and show that zero-Dirichlet energy steady states are not stable for our proposed ODEs. This demonstrates that the proposed framework mitigates the oversmoothing problem. Moreover, we prove that GraphCON mitigates the exploding and vanishing gradients problem to facilitate training of deep multi-layer GNNs.},
  archiveprefix = {arXiv},
  author = {Rusch, T. Konstantin and Chamberlain, Ben P. and Rowbottom, James and Mishra, Siddhartha and Bronstein, Michael M.},
  booktitle = {Proceedings of the 39th International Conference on Machine Learning},
  editor = {Chaudhuri, Kamalika and Jegelka, Stefanie and Song, Le and Szepesv{\'a}ri, Csaba and Niu, Gang and Sabato, Sivan},
  eprint = {2202.02296},
  pages = {18888--18909},
  pdf = {https://proceedings.mlr.press/v162/rusch22a/rusch22a.pdf},
  publisher = {PMLR},
  series = {Proceedings of Machine Learning Research},
  title = {Graph-Coupled Oscillator Networks},
  url = {https://proceedings.mlr.press/v162/rusch22a.html},
  volume = {162},
  year = {2022}
}
@article{abernot2021digital,
  abstract = {Computing paradigm based on von Neuman architectures cannot keep up with the ever-increasing data growth (also called data deluge gap). This has resulted in investigating novel computing paradigms and design approaches at all levels from materials to system-level implementations and applications. An alternative computing approach based on artificial neural networks uses oscillators to compute, called Oscillatory Neural Networks (ONNs). ONNs can perform computations efficiently and can be used to build a more extensive neuromorphic system. We present a digital ONN implementation to show a proof-of-concept of the ONN approach of computing-in-phase for pattern recognition applications. To the best of our knowledge, this is the first attempt to implement an FPGA-based fully-digital ONN.},
  author = {Abernot, Madeleine and Gil, Thierry and Jim{\'e}nez, Manuel and N{\'u}{\~n}ez, Juan and Avellido, Mar{\'i}a J. and Linares-Barranco, Bernab{\'e} and Gonos, Th{\'e}ophile and Hardelin, Tanguy and Todri-Sanial, Aida},
  doi = {10.3389/fnins.2021.713054},
  journal = {Frontiers in Neuroscience},
  month = {8},
  openalex = {W3161228231},
  pages = {713054},
  publisher = {Frontiers Media SA},
  title = {Digital Implementation of Oscillatory Neural Network for Image Recognition Applications},
  url = {https://www.frontiersin.org/journals/neuroscience/articles/10.3389/fnins.2021.713054/full},
  volume = {15},
  year = {2021}
}
@inproceedings{chamberlain2021grand,
  abstract = {We present Graph Neural Diffusion (GRAND) that approaches deep learning on graphs as a continuous diffusion process and treats Graph Neural Networks (GNNs) as discretisations of an underlying PDE. In our model, the layer structure and topology correspond to the discretisation choices of temporal and spatial operators. Our approach allows a principled development of a broad new class of GNNs that are able to address the common plights of graph learning models such as depth, oversmoothing, and bottlenecks. Key to the success of our models are stability with respect to perturbations in the data and this is addressed for both implicit and explicit discretisation schemes.},
  archiveprefix = {arXiv},
  author = {Chamberlain, Ben and Rowbottom, James and Gorinova, Maria I. and Bronstein, Michael and Webb, Stefan and Rossi, Emanuele},
  booktitle = {Proceedings of the 38th International Conference on Machine Learning},
  editor = {Meila, Marina and Zhang, Tong},
  eprint = {2106.10934},
  pages = {1407--1418},
  pdf = {https://proceedings.mlr.press/v139/chamberlain21a/chamberlain21a.pdf},
  publisher = {PMLR},
  series = {Proceedings of Machine Learning Research},
  title = {{GRAND}: Graph Neural Diffusion},
  url = {https://proceedings.mlr.press/v139/chamberlain21a.html},
  volume = {139},
  year = {2021}
}
@inproceedings{trabelsi2018deep,
  author = {Trabelsi, Chiheb and Bilaniuk, Olexa and Zhang, Ying and Serdyuk, Dmitriy and Subramanian, Sandeep and Santos, Jo{\~a}o Felipe and Mehri, Soroush and Rostamzadeh, Negar and Bengio, Yoshua and Pal, Christopher J.},
  booktitle = {International Conference on Learning Representations (ICLR)},
  note = {TLDR: A foundational paper on modern deep complex-valued networks, introducing complex versions of standard components like convolutions and batch normalization.},
  title = {Deep Complex Networks},
  year = {2018},
  url = {https://openreview.net/forum?id=H1T2hmZAb},
  pdf = {https://openreview.net/pdf?id=H1T2hmZAb},
  abstract = {At present, the vast majority of building blocks, techniques, and architectures for deep learning are based on real-valued operations and representations. However, recent work on recurrent neural networks and older fundamental theoretical analysis suggests that complex numbers could have a richer representational capacity and could also facilitate noise-robust memory retrieval mechanisms. Despite these attractive properties, complex-valued deep learning has been marginalized due to the absence of the building blocks required to design such models. In this work, we provide the key atomic components for complex-valued deep neural networks and apply them to convolutional feed-forward networks and convolutional LSTMs. More precisely, we rely on complex convolutions and present algorithms for complex batch-normalization, complex weight initialization strategies for complex-valued neural nets with general multi-dimensional inputs and present algorithms for complex back-propagation. Finally, we present experimental results on several computer vision tasks, music transcription using the MusicNet dataset and Speech Spectrum Prediction using the TIMIT dataset.}
}
@article{ashwin2016mathematical,
  author = {Ashwin, Peter and Coombes, Stephen and Nicks, Rachel},
  doi = {10.1186/s13408-015-0033-6},
  journal = {Journal of Mathematical Neuroscience},
  note = {Provides mathematical frameworks for understanding oscillatory dynamics in neural networks from a neuroscience perspective.},
  openalex = {W2220951078},
  pages = {2},
  title = {Mathematical Frameworks for Oscillatory Network Dynamics in Neuroscience},
  url = {https://mathematical-neuroscience.springeropen.com/articles/10.1186/s13408-015-0033-6},
  pdf = {https://mathematical-neuroscience.springeropen.com/articles/10.1186/s13408-015-0033-6},
  volume = {6},
  year = {2016},
  abstract = {The tools of weakly coupled phase oscillator theory have had a profound impact on the neuroscience community, providing insight into a variety of network behaviours ranging from central pattern generation to synchronisation, as well as predicting novel network states such as chimeras. However, there are many instances where this theory is expected to break down, say in the presence of strong coupling, or must be carefully interpreted, as in the presence of stochastic forcing. There are also surprises in the dynamical complexity of the attractors that can robustly appear—for example, heteroclinic network attractors. In this review we present a set of mathematical tools that are suitable for addressing the dynamics of oscillatory neural networks, broadening from a standard phase oscillator perspective to provide a practical framework for further successful applications of mathematics to understanding network dynamics in neuroscience.}
}
@article{acebrn2005the,
  author = {Acebrón, Juan A. and Bonilla, Luis L. and Pérez Vicente, Conrad J. and Ritort, Félix and Spigler, Renato},
  journal = {Reviews of Modern Physics},
  note = {TLDR: A comprehensive review treating the Kuramoto model from a statistical physics perspective, covering its equilibrium and non-equilibrium properties and diverse applications.},
  title = {The {K}uramoto model: {A} simple paradigm for synchronization phenomena},
  year = {2005},
  volume = {77},
  pages = {137--185},
  doi = {10.1103/RevModPhys.77.137},
  url = {https://journals.aps.org/rmp/abstract/10.1103/RevModPhys.77.137},
  abstract = {Synchronization phenomena in large populations of interacting elements are the subject of intense research in physical, biological, chemical, and social systems. A successful approach to the problem of synchronization consists of modeling each member of the population as a phase oscillator. In this review, we analyze in detail the most successful model of coupled phase oscillators, the Kuramoto model, in which oscillators are coupled through the sine of their phase differences. We focus on the original model in which all-to-all coupling and coupling strength are uniform and where oscillator frequencies are taken from a prescribed probability distribution. Despite its simplicity, this model displays a rich variety of synchronization patterns found in real systems. We provide a rigorous mathematical treatment, survey numerical results, and discuss relevant applications in the contexts of neuroscience, Josephson junctions, arrays of lasers, and biochemical reactions.}
}
@article{strogatz2000from,
  author = {Strogatz, Steven H.},
  journal = {Physica D: Nonlinear Phenomena},
  note = {TLDR: A landmark review that contextualizes Kuramoto's work and details subsequent mathematical developments, providing a rigorous yet accessible overview of the field.},
  title = {From {K}uramoto to {C}rawford: exploring the onset of synchronization in populations of coupled oscillators},
  year = {2000},
  volume = {143},
  number = {1--4},
  pages = {1--20},
  doi = {10.1016/S0167-2789(00)00094-4},
  url = {https://www.sciencedirect.com/science/article/pii/S0167278900000944},
  abstract = {The Kuramoto model describes a large population of coupled limit-cycle oscillators whose natural frequencies are drawn from some prescribed distribution. If the coupling strength exceeds a certain threshold, the system exhibits a phase transition: some of the oscillators spontaneously synchronize, while others remain incoherent. The mathematical analysis of this bifurcation has proved both problematic and fascinating. We review 25 years of research on the Kuramoto model, highlighting the false turns as well as the successes, but mainly following the trail leading from Kuramoto's work to Crawford's recent contributions. It is a lovely winding road, with excursions through mathematical biology, statistical physics, kinetic theory, bifurcation theory, and plasma physics.}
}
