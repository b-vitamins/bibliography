  publisher={Frontiers Media SA},
  doi={10.3389/fnins.2023.1196796},
  url={https://www.frontiersin.org/journals/neuroscience/articles/10.3389/fnins.2023.1196796/full},
  pdf={https://www.frontiersin.org/articles/10.3389/fnins.2023.1196796/pdf},
  abstract={This paper focuses on Oscillatory Neural Networks (ONNs) as a neuromorphic computing paradigm for pattern recognition. Key contributions include adapting Hopfield Neural Network unsupervised learning rules to ONNs, developing a continual on-chip learning algorithm, proposing an implementation approach for on-chip learning with digital ONNs, and analyzing the scalability in terms of latency, precision, and resource utilization. The research addresses the need for continual learning algorithms that can adapt to changing environments with efficient on-chip implementation.},
  keywords={oscillatory neural networks, neuromorphic computing, on-chip learning, pattern recognition, continual learning, FPGA implementation},
  note={Section: Neuromorphic Engineering}
}
