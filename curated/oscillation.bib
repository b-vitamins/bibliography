@article{bittar2024exploring,
  title={Exploring neural oscillations during speech perception via surrogate gradient spiking neural networks},
  author={Bittar, Alexandre and Garner, Philip N.},
  journal={Frontiers in Neuroscience},
  volume={18},
  pages={1449181},
  year={2024},
  publisher={Frontiers},
  doi={10.3389/fnins.2024.1449181},
  url={https://www.frontiersin.org/journals/neuroscience/articles/10.3389/fnins.2024.1449181/full},
  pdf={https://arxiv.org/pdf/2404.14024},
  month={9},
  abstract={Understanding cognitive processes in the brain demands sophisticated models capable of replicating neural dynamics at large scales. We present a physiologically inspired speech recognition architecture, compatible and scalable with deep learning frameworks, and demonstrate that end-to-end gradient descent training leads to the emergence of neural oscillations in the central spiking neural network. Neural oscillations are spontaneously learned and observed via the dynamics of the adaptive membrane potential threshold. We investigate the frequency spectrum of these oscillations and also demonstrate significant cross-frequency couplings within and across network layers during speech processing, with no such interactions observed when handling background noise inputs. This indicates that the model learns to exploit the inherent temporal structure of speech signals. Since we observe neural oscillations that are also observed in humans (Gross et al., 2013; Ding and Simon, 2014; Giraud and Poeppel, 2012; Morillon and Schroeder, 2015), this provides evidence that our neuromorphic architecture represents a promising brain-inspired computing approach for speech perception tasks.},
  eprint={2404.14024},
  archivePrefix={arXiv},
  primaryClass={cs.SD}
}
@article{zhang2024collective,
  title={Collective dynamics and long-range order in thermal neuristor networks},
  author={Zhang, Yuan-Hang and Sipling, Chesson and Qiu, Erbin and Schuller, Ivan K. and Di Ventra, Massimiliano},
  journal={Nature Communications},
  volume={15},
  pages={6986},
  year={2024},
  publisher={Nature Publishing Group},
  doi={10.1038/s41467-024-51254-4},
  url={https://www.nature.com/articles/s41467-024-51254-4},
  pdf={https://arxiv.org/pdf/2312.12899},
  month={8},
  abstract={In the pursuit of scalable and energy-efficient neuromorphic devices, recent research has unveiled a novel category of spiking oscillators, termed 'thermal neuristors.' These devices function via thermal interactions among neighboring vanadium dioxide resistive memories, emulating biological neuronal behavior. We investigate networks of such neurons and reveal that the collective dynamical behavior showcases a rich phase structure, tunable by adjusting the thermal coupling and input voltage. Notably, we identify phases exhibiting long-range order that does not arise from criticality, but rather from the time non-local response of the system. We further demonstrate that these thermal neuristor arrays achieve high accuracy in image recognition and time series prediction through reservoir computing, without leveraging long-range order. Our findings reveal that criticality is not necessary for effective information processing in such systems, thus challenging the critical brain hypothesis. These results pave the way for efficient and scalable neuromorphic devices.},
  eprint={2312.12899},
  archivePrefix={arXiv},
  primaryClass={cond-mat.dis-nn}
}
