@misc{delacour2025lagrange,
  title={{Lagrange Oscillatory Neural Networks for Constraint Satisfaction and Optimization}},
  author={Delacour, Corentin and Haverkort, Bram F. and Sabo, Filip and Azemard, Nadine and Todri-Sanial, Aida},
  year={2025},
  eprint={2505.07179},
  archivePrefix={arXiv},
  primaryClass={cs.ET},
  url={https://arxiv.org/abs/2505.07179},
  pdf={https://arxiv.org/pdf/2505.07179.pdf},
  abstract={Physics-inspired computing paradigms are receiving renewed attention to enhance efficiency in compute-intensive tasks such as artificial intelligence and optimization. This paper introduces Lagrange Oscillatory Neural Network (LagONN), which augments traditional oscillatory neural networks with additional Lagrange oscillators to escape infeasible states and ensure constraint satisfaction. The method is demonstrated on the Max-3-SAT problem, solving random SATlib instances with up to 200 variables and 860 clauses.},
  keywords={Emerging Technologies, Neural and Evolutionary Computing, Constraint Satisfaction, Oscillatory Neural Networks, Lagrange Multipliers},
  pages={23}
}
@misc{tsormpatzoglou2025thermodynamicsinspired,
  title={{Thermodynamics-Inspired Computing with Oscillatory Neural Networks for Inverse Matrix Computation}},
  author={Tsormpatzoglou, George and Sabo, Filip and Todri-Sanial, Aida},
  year={2025},
  eprint={2507.22544},
  archivePrefix={arXiv},
  primaryClass={cs.LG},
  url={https://arxiv.org/abs/2507.22544},
  pdf={https://arxiv.org/pdf/2507.22544.pdf},
  abstract={We describe a thermodynamic-inspired computing paradigm based on oscillatory neural networks (ONNs). While ONNs have been widely studied as Ising machines for tackling complex combinatorial optimization problems, this work investigates their feasibility in solving linear algebra problems, specifically the inverse matrix. The authors analytically demonstrate that the linear approximation of the coupled Kuramoto oscillator model leads to the inverse matrix solution, with numerical simulations validating the theoretical framework.},
  keywords={Machine Learning, Oscillatory Neural Networks, Thermodynamics, Inverse Matrix, Kuramoto Oscillators},
  pages={9},
  note={9 pages, 8 figures}
}
@misc{porfir2025solving,
  title={{Solving Sudoku Using Oscillatory Neural Networks}},
  author={Porfir, Stefan and Haverkort, Bram F. and Sbravati, Federico and Todri-Sanial, Aida},
  year={2025},
  eprint={2508.02250},
  archivePrefix={arXiv},
  primaryClass={cond-mat.dis-nn},
  url={https://arxiv.org/abs/2508.02250},
  pdf={https://arxiv.org/pdf/2508.02250.pdf},
  abstract={This paper explores the application of Oscillatory Neural Networks (ONNs) to solving Sudoku puzzles using a biologically inspired approach based on phase synchronization. Each Sudoku cell is represented by an oscillator whose phase encodes a digit, with synchronization governed by the Kuramoto model. ONNs demonstrate high performance for puzzles with moderate difficulty and outperform Hopfield Neural Networks, especially for puzzles with up to 20 initially unknown values.},
  pages={5},
  note={5 pages, 7 figures. Funding: European Research Council ERC THERMODON project (101125031) and Dutch Research Council AiNed Fellowship AI-on-ONN project (NGF.1607.22.016)},
  keywords={Condensed Matter, Disordered Systems and Neural Networks, Oscillatory Neural Networks, Sudoku, Kuramoto Model, Constraint Satisfaction}
}
@article{rudner2024design,
  title={{Design of Oscillatory Neural Networks by Machine Learning}},
  author={Rudner, Tam\'{a}s and Porod, Wolfgang and Csaba, Gyorgy},
  journal={Frontiers in Neuroscience},
  volume={18},
  pages={1307525},
  year={2024},
  month={3},
  publisher={Frontiers Media SA},
  doi={10.3389/fnins.2024.1307525},
  url={https://www.frontiersin.org/journals/neuroscience/articles/10.3389/fnins.2024.1307525/full},
  pdf={https://www.ncbi.nlm.nih.gov/pmc/articles/PMC10944938/pdf/fnins-18-1307525.pdf},
  eprint={2309.02532},
  archivePrefix={arXiv},
  primaryClass={cond-mat.dis-nn},
  abstract={We demonstrate the utility of machine learning algorithms for the design of Oscillatory Neural Networks (ONNs). After constructing a circuit model of the oscillators in a machine-learning-enabled simulator and performing Backpropagation through time (BPTT) for determining the coupling resistances between the ring oscillators, we show the design of associative memories and multi-layered ONN classifiers. Machine learning-designed ONNs show superior performance compared to other design methods and achieve up to 96.7\% accuracy on MNIST dataset.},
  keywords={neuromorphic computing, oscillatory neural networks, machine learning design, ring oscillators, low-power computing}
}
@article{abernot2023oscillatory,
  title={{Oscillatory neural network learning for pattern recognition: an on-chip learning perspective and implementation}},
  author={Abernot, Madeleine and Az\'{e}mard, Nadine and Todri-Sanial, Aida},
  journal={Frontiers in Neuroscience},
  volume={17},
  pages={1196796},
  year={2023},
