@inproceedings{furst2022cloob,
  abstract = {CLIP yielded impressive results on zero-shot transfer learning tasks and is considered as a foundation model like BERT or GPT3. CLIP vision models that have a rich representation are pre-trained using the InfoNCE objective and natural language supervision before they are fine-tuned on particular tasks. Though CLIP excels at zero-shot transfer learning, it suffers from an explaining away problem, that is, it focuses on one or few features, while neglecting other relevant features. This problem is caused by insufficiently extracting the covariance structure in the original multi-modal data. We suggest to use modern Hopfield networks to tackle the problem of explaining away. Their retrieved embeddings have an enriched covariance structure derived from co-occurrences of features in the stored embeddings. However, modern Hopfield networks increase the saturation effect of the InfoNCE objective which hampers learning. We propose to use the InfoLOOB objective to mitigate this saturation effect. We introduce the novel "Contrastive Leave One Out Boost" (CLOOB), which uses modern Hopfield networks for covariance enrichment together with the InfoLOOB objective. In experiments we compare CLOOB to CLIP after pre-training on the Conceptual Captions and the YFCC dataset with respect to their zero-shot transfer learning performance on other datasets. CLOOB consistently outperforms CLIP at zero-shot transfer learning across all considered architectures and datasets.},
  author = {F{\"u}rst, Andreas and Rumetshofer, Elisabeth and Lehner, Johannes and Tran, Viet and Tang, Fei and Ramsauer, Hubert and Kreil, David and Kopp, Michael and Klambauer, G{\"u}nter and Bitto-Nemling, Angela and Hochreiter, Sepp},
  booktitle = {Advances in Neural Information Processing Systems},
  eprint = {2110.11316},
  file = {:/home/b/documents/inproceedings/furst2022cloob.pdf:pdf},
  note = {Blog: https://ml-jku.github.io/cloob/; GitHub: https://github.com/ml-jku/cloob},
  pdf = {https://arxiv.org/pdf/2110.11316},
  publisher = {Curran Associates, Inc.},
  title = {{CLOOB}: Modern Hopfield Networks with {InfoLOOB} Outperform {CLIP}},
  url = {https://proceedings.neurips.cc/paper/2022/hash/07842b88a6043328ee7c5d5bed58c771-Abstract-Conference.html},
  volume = {35},
  year = {2022}
}

@article{tang2025video,
  abstract = {With the burgeoning growth of online video platforms and the escalating volume of video content, the demand for proficient video understanding tools has intensified markedly. Recent advancements in video understanding that harness the power of large language models (LLMs) have demonstrated surprisingly advanced emergent capabilities, particularly their ability for open-ended multi-granularity (general, temporal, and spatiotemporal) reasoning combined with commonsense knowledge, suggesting a promising path for future video understanding. This survey provides a comprehensive overview of recent advances in video understanding that harness the capabilities of LLMs, referred to as Vid-LLMs. We categorize Vid-LLM approaches into four main types: LLM-based Video Agents, Vid-LLMs Pretraining, Vid-LLMs Instruction Tuning, and Hybrid Methods. We also present a comprehensive study of the tasks and datasets for Vid-LLMs, along with the methodologies employed for evaluation.},
  archiveprefix = {arXiv},
  author = {Tang, Yunlong and Bi, Jing and Xu, Siting and Song, Luchuan and Liang, Susan and Wang, Teng and Zhang, Daoan and An, Jie and Lin, Jingyang and Zhu, Rongyi and Vosoughi, Ali and Huang, Chao and Zhang, Zeliang and Liu, Pinxin and Feng, Mingqian and Zheng, Feng and Zhang, Jianguo and Luo, Ping and Luo, Jiebo and Xu, Chenliang},
  doi = {10.1109/TCSVT.2025.3566695},
  eprint = {2312.17432},
  file = {:/home/b/documents/article/tang2025video.pdf:pdf},
  journal = {IEEE Transactions on Circuits and Systems for Video Technology},
  month = {5},
  note = {Early Access},
  pdf = {https://arxiv.org/pdf/2312.17432.pdf},
  primaryclass = {cs.CV},
  publisher = {IEEE},
  title = {Video Understanding with Large Language Models: A Survey},
  url = {https://ieeexplore.ieee.org/document/10982110/},
  year = {2025}
}

@misc{wu2025survey,
  abstract = {Recent advancements in video temporal grounding (VTG) have significantly enhanced fine-grained video understanding, primarily driven by multimodal large language models (MLLMs). VTG approaches based on MLLMs (VTG-MLLMs) are gradually surpassing traditional fine-tuned methods, achieving competitive performance and excelling in generalization across zero-shot, multi-task, and multi-domain settings. Despite extensive surveys on general video-language understanding, comprehensive reviews specifically addressing VTG-MLLMs remain scarce. This survey provides a systematic review of recent advances in video temporal grounding using multimodal large language models, examining VTG through three key dimensions: functional roles of MLLMs, training paradigms, and video feature processing techniques. We analyze the capabilities and limitations of current approaches while identifying future research directions for this emerging field.},
  archiveprefix = {arXiv},
  author = {Wu, Jianlong and Liu, Wei and Liu, Ye and Liu, Meng and Nie, Liqiang and Lin, Zhouchen and Chen, Chang Wen},
  eprint = {2508.10922},
  file = {:/home/b/documents/misc/wu2025survey.pdf:pdf},
  month = {8},
  pdf = {https://arxiv.org/pdf/2508.10922.pdf},
  primaryclass = {cs.CV},
  title = {A Survey on Video Temporal Grounding with Multimodal Large Language Model},
  url = {https://arxiv.org/abs/2508.10922},
  year = {2025}
}

@misc{team2025vidi,
  abstract = {Humans naturally share information with those they are connected to, and video has become one of the dominant mediums for communication and expression on the Internet. To support the creation of high-quality large-scale video content, a modern pipeline requires a comprehensive understanding of both the raw input materials (e.g., the unedited footage captured by cameras) and the editing components (e.g., visual effects). We present Vidi, a family of Large Multimodal Models (LMMs) designed for a wide range of video understanding and editing scenarios. Our first release focuses on temporal retrieval, i.e., identifying the time ranges within the input videos corresponding to a given text query, which plays a critical role in intelligent editing. To address this, we curate datasets from diverse sources, implement video-specific model architecture and training strategies, and propose novel metrics for comprehensive evaluation. Extensive experiments demonstrate Vidi's exceptional capability in temporal retrieval on both dense captions and diverse video content. Models must process multiple modalities (e.g., vision, audio, text) with strong background knowledge and handle flexible input lengths (e.g., hour-long raw videos), which poses significant challenges for traditional models.},
  archiveprefix = {arXiv},
  author = {{Vidi Team} and Liu, Celong and Kuo, Chia-Wen and Du, Dawei and Chen, Fan and Chen, Guang and Yuan, Jiamin and Zhang, Lingxi and Guo, Lu and Li, Lusha and Wen, Longyin and Chen, Qingyu and Deng, Rachel and Zhu, Sijie and Siew, Stuart and Jin, Tong and Lu, Wei and Zhong, Wen and Shen, Xiaohui and Gu, Xin and Mei, Xing and Qu, Xueqiong and Chen, Zhenfang},
  eprint = {2504.15681},
  file = {:/home/b/documents/misc/team2025vidi.pdf:pdf},
  month = {4},
  pdf = {https://arxiv.org/pdf/2504.15681.pdf},
  primaryclass = {cs.CV},
  title = {Vidi: Large Multimodal Models for Video Understanding and Editing},
  url = {https://arxiv.org/abs/2504.15681},
  year = {2025}
}

@misc{zhang2025videollama,
  abstract = {In this paper, we propose {VideoLLaMA}3, a more advanced multimodal foundation model for image and video understanding. The core design philosophy of {VideoLLaMA}3 is vision-centric. The meaning of 'vision-centric' is two-fold: the vision-centric training paradigm and vision-centric framework design. The key insight of our vision-centric training paradigm is that high-quality image-text data is crucial for both image and video understanding. Instead of preparing massive video-text datasets, we focus on constructing large-scale and high-quality image-text datasets. {VideoLLaMA}3 has four training stages: 1) Vision Encoder Adaptation 2) Vision-Language Alignment 3) Multi-task Fine-tuning 4) Video-centric Fine-tuning. As for the framework design, to better capture fine-grained details in images, the pretrained vision encoder is adapted to encode images of varying sizes into vision tokens with corresponding numbers, rather than a fixed number of tokens. For video inputs, we reduce the number of vision tokens according to their similarity so that the representation of videos will be more precise and compact. Benefit from vision-centric designs, {VideoLLaMA}3 achieves compelling performances in both image and video understanding benchmarks.},
  archiveprefix = {arXiv},
  author = {Zhang, Boqiang and Li, Kehan and Cheng, Zesen and Hu, Zhiqiang and Yuan, Yuqian and Chen, Guanzheng and Leng, Sicong and Jiang, Yuming and Zhang, Hang and Li, Xin and Jin, Peng and Zhang, Wenqi and Wang, Fan and Bing, Lidong and Zhao, Deli},
  eprint = {2501.13106},
  file = {:/home/b/documents/misc/zhang2025videollama.pdf:pdf},
  month = {1},
  pdf = {https://arxiv.org/pdf/2501.13106.pdf},
  primaryclass = {cs.CV},
  title = {{VideoLLaMA} 3: {F}rontier {M}ultimodal {F}oundation {M}odels for {I}mage and {V}ideo {U}nderstanding},
  url = {https://arxiv.org/abs/2501.13106},
  year = {2025}
}

@misc{santos2025modern,
  abstract = {Recent research has established a connection between modern {H}opfield networks ({HN}s) and transformer attention heads, with guarantees of exponential storage capacity. However, these models still face challenges scaling storage efficiently. We propose compressing large discrete {H}opfield memories into smaller, continuous-time memories. Our approach leverages continuous attention with a modified energy function that changes the {H}opfield network update rule, replacing the traditional softmax-based probability mass function with a probability density over continuous memory. The framework assumes memories form a continuum, treating sequences of observations as samples from a smooth function over a continuous domain, which is reconstructed using linear combinations of basis functions. This formulation is grounded in modern perspectives on human executive function, creating a principled connection between attractor dynamics in working memory and resource-efficient memory allocation. Our framework maintains competitive performance with standard {H}opfield networks while using compressed memory, reducing computational costs across synthetic and video datasets.},
  archiveprefix = {arXiv},
  author = {Santos, Saul and Farinhas, António and McNamee, Daniel C. and Martins, André F. T.},
  eprint = {2502.10122},
  file = {:/home/b/documents/misc/santos2025modern.pdf:pdf},
  month = {2},
  pdf = {https://arxiv.org/pdf/2502.10122.pdf},
  primaryclass = {cs.LG},
  title = {Modern {H}opfield {N}etworks with {C}ontinuous-{T}ime {M}emories},
  url = {https://arxiv.org/abs/2502.10122},
  year = {2025}
}

@inproceedings{lai2025rethinking,
  abstract = {Video-Text Retrieval (VTR) is a core task in multi-modal understanding, drawing growing attention from both academia and industry. While numerous VTR methods have achieved success, most of them assume accurate visual-text correspondences during training, which is difficult to ensure in practice due to ubiquitous noise, known as noisy correspondences (NC). To address this challenge, we rethink how to mitigate the NC from the perspective of representative reference features (termed agents), and propose a novel relation-aware purified consistency (RPC) network. The proposed method constructs agents without correspondence supervision and uses ranking distribution-based alignment to improve robustness against noisy correspondences. The approach has been validated across five benchmark datasets.},
  author = {Lai, Huakai and Xiong, Guoxin and Mai, Huayu and Liu, Xiang and Zhang, Tianzhu},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition},
  file = {:/home/b/documents/inproceedings/lai2025rethinking.pdf:pdf},
  month = {6},
  pdf = {https://openaccess.thecvf.com/content/CVPR2025/papers/Lai_Rethinking_Noisy_Video-Text_Retrieval_via_Relation-aware_Alignment_CVPR_2025_paper.pdf},
  publisher = {IEEE},
  title = {Rethinking Noisy Video-Text Retrieval via Relation-aware Alignment},
  url = {https://cvpr.thecvf.com/virtual/2025/poster/32598},
  year = {2025}
}

@misc{qin2025taskaware,
  abstract = {Long-video understanding (LVU) remains a severe challenge for existing multimodal large language models (MLLMs), primarily due to the prohibitive computational cost. Recent approaches have explored KV compression to mitigate this issue, but they often suffer from significant information loss at high compression ratios. In this paper, we introduce Video-$X^2L$, which flexibly preserves critical video information for each LVU task. Video-$X^2L$ involves two key operations: 1. Bi-level KV compression: During the MLLM's pre-filling stage, Video-$X^2L$ generates two types of compressed KVs: Low-compression KVs (L-KVs) to capture fine-grained video details and High-compression KVs (H-KVs) to offer compact video representations. 2. Selective KV re-loading: During the MLLM's decoding stage, Video-$X^2L$ selectively re-loads L-KVs for the most critical video chunks while using H-KVs for other less important ones. This allows the MLLM to fully utilize task-specific information while maintaining the overall compactness. Video-$X^2L$ is simple yet effective: it is free from additional training and directly compatible with existing KV-compressible MLLMs. We evaluate Video-$X^2L$ with a variety of popular LVU benchmarks, including VideoMME, MLVU, LongVideoBench, and VNBench. Our experiment result shows that Video-$X^2L$ outperforms existing KV-compression methods by a huge advantage while substantially saving the computation cost.},
  archiveprefix = {arXiv},
  author = {Qin, Minghao and Shu, Yan and Zhang, Peitian and Lun, Kun and Yuan, Huaying and Zhou, Juenjie and Xiao, Shitao and Zhao, Bo and Liu, Zheng},
  eprint = {2506.21184},
  file = {:/home/b/documents/misc/qin2025taskaware.pdf:pdf},
  month = {6},
  pdf = {https://arxiv.org/pdf/2506.21184},
  primaryclass = {cs.CV},
  title = {Task-Aware {KV} Compression For Cost-Effective Long Video Understanding},
  url = {https://arxiv.org/abs/2506.21184},
  year = {2025}
}

@misc{zhang2025vsa,
  abstract = {Scaling video diffusion transformers (DiTs) is limited by their quadratic 3D attention, even though most of the attention mass concentrates on a small subset of positions. We turn this observation into VSA, a trainable, hardware-efficient sparse attention that replaces full attention at both training and inference. In VSA, a lightweight coarse stage pools tokens into tiles and identifies high-weight critical tokens; a fine stage computes token-level attention only inside those tiles subjecting to block computing layout to ensure hard efficiency. This leads to a single differentiable kernel that trains end-to-end, requires no post-hoc profiling, and sustains 85\% of FlashAttention3 MFU. We perform a large sweep of ablation studies and scaling-law experiments by pretraining DiTs from 60M to 1.4B parameters. VSA reaches a Pareto point that cuts training FLOPS by $2.53\times$ with no drop in diffusion loss. Retrofitting the open-source Wan-2.1 model speeds up attention time by $6\times$ and lowers end-to-end generation time from 31s to 18s with comparable quality. These results establish trainable sparse attention as a practical alternative to full attention and a key enabler for further scaling of video diffusion models.},
  archiveprefix = {arXiv},
  author = {Zhang, Peiyuan and Chen, Yongqi and Huang, Haofeng and Lin, Will and Liu, Zhengzhong and Stoica, Ion and Xing, Eric and Zhang, Hao},
  eprint = {2505.13389},
  file = {:/home/b/documents/misc/zhang2025vsa.pdf:pdf},
  month = {5},
  pdf = {https://arxiv.org/pdf/2505.13389},
  primaryclass = {cs.CV},
  title = {{VSA}: Faster Video Diffusion with Trainable Sparse Attention},
  url = {https://arxiv.org/abs/2505.13389},
  year = {2025}
}

@article{hu2025cos,
  abstract = {Multi-modal Large Language Models (MLLMs) struggle with long videos due to the need for excessive visual tokens. These tokens exceed massively the context length of MLLMs, resulting in filled by redundant task-irrelevant shots. How to select shots is an unsolved critical problem: sparse sampling risks missing key details, while exhaustive sampling overwhelms the model with irrelevant content, leading to video misunderstanding. To solve this problem, we propose Chain-of-Shot prompting (CoS). The key idea is to frame shot selection as test-time visual prompt optimisation, choosing shots adaptive to video understanding semantic task by optimising shots-task alignment. CoS has two key parts: (1) a binary video summary mechanism that performs pseudo temporal grounding, discovering a binary coding to identify task-relevant shots, and (2) a video co-reasoning module that iteratively refines shot selection and video comprehension, improving context focus and overall video understanding capabilities.},
  archiveprefix = {arXiv},
  author = {Hu, Jian and Cheng, Zixu and Si, Chenyang and Li, Wei and Gong, Shaogang},
  eprint = {2502.06428},
  file = {:/home/b/documents/article/hu2025cos.pdf:pdf},
  journal = {arXiv preprint arXiv:2502.06428},
  month = {2},
  pdf = {https://arxiv.org/pdf/2502.06428.pdf},
  primaryclass = {cs.CV},
  title = {CoS: Chain-of-Shot Prompting for Long Video Understanding},
  url = {https://arxiv.org/abs/2502.06428},
  year = {2025}
}

@inproceedings{liu2025mamba4d,
  abstract = {Point cloud videos can faithfully capture real-world spatial geometries and temporal dynamics, which are essential for enabling intelligent agents to understand the dynamically changing world. However, designing an effective 4D backbone remains challenging, mainly due to the irregular and unordered distribution of points and temporal inconsistencies across frames. Also, recent transformer-based 4D backbones commonly suffer from large computational costs due to their quadratic complexity, particularly for long video sequences. To address these challenges, we propose a novel point cloud video understanding backbone purely based on the State Space Models (SSMs). Specifically, we first disentangle space and time in 4D video sequences and then establish the spatio-temporal correlation with our designed Mamba blocks. The Intra-frame Spatial Mamba module is developed to encode locally similar geometric structures within a certain temporal stride. Subsequently, locally correlated tokens are delivered to the Inter-frame Temporal Mamba module, which integrates long-term point features across the entire video with linear complexity. Our proposed Mamba4d achieves competitive performance on the MSR-Action3D action recognition (+10.4% accuracy), HOI4D action segmentation (+0.7 F1 Score), and Synthia4D semantic segmentation (+0.19 mIoU) datasets. Especially, for long video sequences, our method has a significant efficiency improvement with 87.5% GPU memory reduction and 5.36 times speed-up. Codes will be released at https://github.com/IRMVLab/Mamba4D.},
  author = {Liu, Jiuming and Han, Jinru and Liu, Lihao and Aviles-Rivero, Angelica I. and Jiang, Chaokang and Liu, Zhe and Wang, Hesheng},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  file = {:/home/b/documents/inproceedings/liu2025mamba4d.pdf:pdf},
  pdf = {https://openaccess.thecvf.com/content/CVPR2025/papers/Liu_Mamba4D_Efficient_4D_Point_Cloud_Video_Understanding_with_Disentangled_Spatial-Temporal_CVPR_2025_paper.pdf},
  publisher = {IEEE},
  title = {{MAMBA4D}: Efficient Long-Sequence Point Cloud Video Understanding with Disentangled Spatial-Temporal State Space Models},
  url = {https://arxiv.org/abs/2405.14338},
  year = {2025}
}

@inproceedings{liu2025bolt,
  abstract = {Large video-language models (VLMs) face challenges in long-form video analysis due to limited context windows. We introduce BOLT, a method to boost Large VLMs without additional Training through a comprehensive study of frame selection strategies. By proposing a multi-source retrieval evaluation setting, we found that uniform sampling performs poorly in noisy contexts. Our key innovation is exploring frame selection strategies based on query-frame similarity, with inverse transform sampling yielding significant performance improvements - increasing accuracy on the Video-MME benchmark from 53.8% to 56.1% and MLVU benchmark from 58.9% to 63.4%. Our findings reveal that uniform sampling performs poorly in noisy contexts, underscoring the importance of selecting the right frames for effective long-form video understanding.},
  author = {Liu, Shuming and Zhao, Chen and Xu, Tianqi and Ghanem, Bernard},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  file = {:/home/b/documents/inproceedings/liu2025bolt.pdf:pdf},
  pdf = {https://arxiv.org/pdf/2503.21483.pdf},
  publisher = {IEEE},
  title = {{BOLT}: Boost Large Vision-Language Model Without Training for Long-Form Video Understanding},
  url = {https://arxiv.org/abs/2503.21483},
  year = {2025}
}

@inproceedings{tan2025allvb,
  abstract = {This paper introduces {ALLVB}, a comprehensive benchmark for evaluating multi-modal large language models on long video understanding tasks. The benchmark integrates multiple video understanding capabilities including video classification, scene recognition, object detection and tracking, action recognition, temporal action localization, event detection, video captioning, video emotion recognition, and narrative understanding. These tasks are converted into video question-answering formats to enable unified evaluation across different video understanding capabilities.},
  author = {Tan, Xiaoheng and Luo, Yiqi and Xu, Xiangxu and Che, Wentao and Li, Jie and Cao, Xiujun and Li, Kun and Hu, Xiao and Yao, Yuan and Wang, Yanjun and Wang, Chenkai and Lu, Shuo and Wang, Ziyu and Li, Jianguo and Leng, Shijie and Li, Lei and Zhang, Lei and Zha, Zheng-Jun},
  booktitle = {Proceedings of the AAAI Conference on Artificial Intelligence},
  file = {:/home/b/documents/inproceedings/tan2025allvb.pdf:pdf},
  note = {Authors and details need verification - similar arXiv paper arXiv:2503.07298 has different first author (Xichen Tan). PDF link points to the arXiv version by Xichen Tan et al.},
  pdf = {https://arxiv.org/pdf/2503.07298.pdf},
  title = {{ALLVB}: All-in-One Long Video Understanding Benchmark},
  year = {2025}
}

@misc{li2025videoscan,
  abstract = {This paper introduces VideoScan, an efficient vision-language model (VLM) inference framework designed for real-time video interaction that effectively comprehends and retains streamed video inputs while delivering rapid and accurate responses. A longstanding challenge in video understanding--particularly for long-term or real-time applications--stems from the substantial computational overhead caused by the extensive length of visual tokens. To address this, VideoScan employs a single semantic carrier token to represent each frame, progressively reducing computational and memory overhead during its two-phase inference process: prefilling and decoding. The embedding of the semantic carrier token is derived from an optimized aggregation of frame-level visual features, ensuring compact yet semantically rich representations. Critically, the corresponding key-value pairs are trained to retain contextual semantics from prior frames, enabling efficient memory management without sacrificing temporal coherence. During inference, the visual tokens of each frame are processed only once during the prefilling phase and subsequently discarded in the decoding stage, eliminating redundant computations. This design ensures efficient VLM inference even under stringent real-time constraints. Comprehensive experiments on diverse offline and online benchmarks demonstrate that LLaVA-Video, supported by our method, achieves up to speedups compared to its original version and previous efficient streaming video understanding approaches, respectively. Crucially, these improvements are attained while maintaining competitive performance and ensuring stable GPU memory consumption (consistently GB, independent of video duration).},
  archiveprefix = {arXiv},
  author = {Li, Ruanjun and Tan, Yuedong and Shi, Yuanming and Shao, Jiawei},
  doi = {10.48550/arXiv.2503.09387},
  eprint = {2503.09387},
  file = {:/home/b/documents/misc/li2025videoscan.pdf:pdf},
  month = {3},
  note = {11 pages, 4 figures},
  pdf = {https://arxiv.org/pdf/2503.09387.pdf},
  primaryclass = {cs.CV},
  title = {VideoScan: Enabling Efficient Streaming Video Understanding via Frame-level Semantic Carriers},
  url = {https://arxiv.org/abs/2503.09387},
  year = {2025}
}

@misc{schneider2025quickvideo,
  abstract = {Long-video understanding has emerged as a crucial capability in real-world applications such as video surveillance, meeting summarization, educational lecture analysis, and sports broadcasting. However, it remains computationally prohibitive for VideoLLMs, primarily due to two bottlenecks: 1) sequential video decoding, the process of converting the raw bit stream to RGB frames can take up to a minute for hour-long video inputs, and 2) costly prefilling of up to several million tokens for LLM inference, resulting in high latency and memory use. To address these challenges, we propose QuickVideo, a system-algorithm co-design that substantially accelerates long-video understanding to support real-time downstream applications. It comprises three key innovations: QuickDecoder, a parallelized CPU-based video decoder that achieves 2-3 times speedup by splitting videos into keyframe-aligned intervals processed concurrently; QuickPrefill, a memory-efficient prefilling method using KV-cache pruning to support more frames with less GPU memory; and an overlapping scheme that overlaps CPU video decoding with GPU inference. Together, these components reduce inference time by a minute on long video inputs, enabling scalable, high-quality video understanding even on limited hardware. Experiments show that QuickVideo generalizes across durations and sampling rates, making long video processing feasible in practice.},
  archiveprefix = {arXiv},
  author = {Schneider, Benjamin and Jiang, Dongfu and Du, Chao and Pang, Tianyu and Chen, Wenhu},
  doi = {10.48550/arXiv.2505.16175},
  eprint = {2505.16175},
  file = {:/home/b/documents/misc/schneider2025quickvideo.pdf:pdf},
  month = {5},
  note = {19 pages, 6 figures, 2 tables},
  pdf = {https://arxiv.org/pdf/2505.16175.pdf},
  primaryclass = {cs.CV},
  title = {QuickVideo: Real-Time Long Video Understanding with System Algorithm Co-Design},
  url = {https://arxiv.org/abs/2505.16175},
  year = {2025}
}

@inproceedings{shu2025videoxl,
  abstract = {Although current Multi-modal Large Language Models (MLLMs) demonstrate promising results in video understanding, processing extremely long videos remains an ongoing challenge. Typically, MLLMs struggle with handling thousands of tokens that exceed the maximum context length of LLMs, and they experience reduced visual clarity due to token aggregation. Another challenge is the high computational cost stemming from the large number of video tokens. To tackle these issues, we propose Video-XL, an extra-long vision language model designed for efficient hour-scale video understanding. Specifically, we argue that LLMs can be adapted as effective visual condensers and introduce Visual Context Latent Summarization, which condenses visual contexts into highly compact forms. We introduce a new special token, the Visual Summarization Token (VST), for each interval of the video, which summarizes the visual information within the interval as its associated KV. Extensive experiments demonstrate that our model achieves promising results on popular long video understanding benchmarks, despite being trained on limited image data.},
  archiveprefix = {arXiv},
  author = {Shu, Yan and Liu, Zheng and Zhang, Peitian and Qin, Minghao and Zhou, Junjie and Liang, Zhengyang and Huang, Tiejun and Zhao, Bo},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  eprint = {2409.14485},
  file = {:/home/b/documents/inproceedings/shu2025videoxl.pdf:pdf},
  month = {9},
  pdf = {https://openaccess.thecvf.com/content/CVPR2025/papers/Shu_Video-XL_Extra-Long_Vision_Language_Model_for_Hour-Scale_Video_Understanding_CVPR_2025_paper.pdf},
  primaryclass = {cs.CV},
  title = {{Video-XL}: Extra-Long Vision Language Model for Hour-Scale Video Understanding},
  url = {https://openaccess.thecvf.com/content/CVPR2025/html/Shu_Video-XL_Extra-Long_Vision_Language_Model_for_Hour-Scale_Video_Understanding_CVPR_2025_paper.html},
  year = {2025}
}

@inproceedings{zhang2025flashvstream,
  abstract = {This paper presents {Flash-VStream}, a video-language model that simulates the memory mechanism of humans and is able to process extremely long video streams in real-time while responding to user queries simultaneously. The system addresses the challenge that the 'dynamic' nature of online video streams poses for existing models, introducing problems such as the storage of extremely long-term information and interaction between continuous visual content and 'asynchronous' user questions. {Flash-VStream} features a novel Flash Memory mechanism consisting of two key components: a low-capacity Context Synopsis Memory ({CSM}) that encodes inter-frame features and clusters low-resolution feature maps, and a high-capacity Detail Augmentation Memory ({DAM}) that retrieves high-resolution feature maps focused on the most informative frames. The model achieves state-of-the-art performance in offline scenarios as well, demonstrating outstanding accuracy and efficiency on {EgoSchema}, {MLVU}, {LVBench}, {MVBench}, and {Video-MME} benchmarks. The team won 1st place at the Long-Term Video Question Answering Challenge of {LOVEU} Workshop@{CVPR}'24.},
  author = {Haoji Zhang and Yiqin Wang and Yansong Tang and Yong Liu and Jiashi Feng and Xiaojie Jin},
  booktitle = {Proceedings of the {IEEE/CVF} International Conference on Computer Vision ({ICCV})},
  doi = {10.48550/arXiv.2506.23825},
  eprint = {2506.23825},
  file = {:/home/b/documents/inproceedings/zhang2025flashvstream.pdf:pdf},
  month = {10},
  pdf = {https://arxiv.org/pdf/2506.23825.pdf},
  title = {{Flash-VStream}: Efficient Real-Time Understanding for Long Video Streams},
  url = {https://arxiv.org/abs/2506.23825},
  year = {2025}
}

@article{zhang2025lvbench,
  abstract = {Despite remarkable recent progress, existing long-form VideoQA datasets fall short of meeting the criteria for genuine long-form video understanding. This is primarily due to the use of short videos for question curation, and the reliance on limited-length sub-clips as clues to answer those questions. Meanwhile, previous datasets have limited focus on question type and modality. To remedy this, we introduce LvBench, a Long-form Video understanding Benchmark for versatile multi-modal question-answering. LvBench considers videos ranging from 70 seconds to 4 hours, covering single-scene, multi-scene, and full-scene contexts, and introduces six distinct question types that evaluate various perceptual and cognitive capabilities.},
  author = {Zhang, Hongjie and Dong, Lu and Liu, Yi and Huang, Yifei and Wang, Yali and Wang, Limin and Qiao, Yu},
  doi = {10.1007/s11263-025-02555-8},
  file = {:/home/b/documents/article/zhang2025lvbench.pdf:pdf},
  journal = {International Journal of Computer Vision},
  note = {arXiv preprint: \url{https://arxiv.org/abs/2312.04817}},
  pdf = {https://link.springer.com/content/pdf/10.1007/s11263-025-02555-8.pdf},
  publisher = {Springer},
  title = {LvBench: A Benchmark for Long-form Video Understanding with Versatile Multi-modal Question Answering},
  url = {https://link.springer.com/article/10.1007/s11263-025-02555-8},
  year = {2025}
}

@inproceedings{zohar2025apollo,
  abstract = {Despite the rapid integration of video perception capabilities into Large Multimodal Models (LMMs), the underlying mechanisms driving their video understanding remain poorly understood. Consequently, many design decisions in this domain are made without proper justification or analysis. The high computational cost of training and evaluating such models, coupled with limited open research, hinders the development of video-LMMs. To address this, we present a comprehensive study that helps uncover what effectively drives video understanding in LMMs. We begin by critically examining the primary contributors to the high computational requirements associated with video-LMM research and discover Scaling Consistency, wherein design and training decisions made on smaller models and datasets (up to a critical size) effectively transfer to larger models. Leveraging these insights, we explored many video-specific aspects of video-LMMs, including video sampling, architectures, data composition, training schedules, and more. For example, we demonstrated that fps sampling during training is vastly preferable to uniform frame sampling and which vision encoders are the best for video representation. Guided by these findings, we introduce Apollo, a state-of-the-art family of LMMs that achieve superior performance across different model sizes. Our models can perceive hour-long videos efficiently, with Apollo-3B outperforming most existing 7B models with an impressive 55.1 on LongVideoBench. Apollo-7B is state-of-the-art compared to 7B LMMs with a 70.9 on MLVU, and 63.3 on Video-MME.},
  author = {Zohar, Orr and Wang, Xiaohan and Dubois, Yann and Mehta, Nikhil and Xiao, Tong and Hansen-Estruch, Philippe and Yu, Licheng and Wang, Xiaofang and Juefei-Xu, Felix and Zhang, Ning and Yeung-Levy, Serena and Xia, Xide},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition},
  eprint = {2412.10360},
  file = {:/home/b/documents/inproceedings/zohar2025apollo.pdf:pdf},
  pages = {18891--18901},
  pdf = {https://openaccess.thecvf.com/content/CVPR2025/papers/Zohar_Apollo__An_Exploration_of_Video_Understanding_in_Large_Multimodal_CVPR_2025_paper.pdf},
  title = {Apollo: An Exploration of Video Understanding in Large Multimodal Models},
  url = {https://apollo-lmms.github.io/},
  year = {2025}
}

@inproceedings{jang2025videowebarena,
  abstract = {Videos are often used to learn or extract the necessary information to complete tasks in ways different than what text and static imagery alone can provide. However, many existing agent benchmarks neglect long-context video understanding, instead focusing on text or static image inputs. To bridge this gap, we introduce VideoWebArena (VideoWA), a benchmark for evaluating the capabilities of long-context multimodal agents for video understanding. VideoWA consists of 2,021 web agent tasks based on manually crafted video tutorials, which total almost four hours of content. We define a taxonomy of long-context video-based agent tasks with two areas of focus: skill retention and factual retention. While skill retention tasks evaluate whether an agent can use a given human demonstration to complete a task efficiently, factual retention tasks evaluate whether an agent can retrieve instruction-relevant information from a video to complete a task. Our results on VideoWA reveal significant performance gaps, with the best model achieving 13.3% success on skill retention tasks and 45.8% on factual retention QA pairs, far below human performance at 73.9% and 79.3%, respectively.},
  author = {Jang, Lawrence Keunho and Li, Yinheng and Zhao, Dan and Ding, Charles and Lin, Justin and Liang, Paul Pu and Bonatti, Rogerio and Koishida, Kazuhito},
  booktitle = {The Thirteenth International Conference on Learning Representations},
  doi = {10.48550/arXiv.2410.19100},
  eprint = {2410.19100},
  file = {:/home/b/documents/inproceedings/jang2025videowebarena.pdf:pdf},
  month = {5},
  pdf = {https://arxiv.org/pdf/2410.19100},
  title = {VideoWebArena: Evaluating Long Context Multimodal Agents with Video Understanding Web Tasks},
  url = {https://openreview.net/forum?id=unDQOUah0F},
  year = {2025}
}

@inproceedings{zhao2025mmvu,
  abstract = {This work introduces {MMVU}, a comprehensive expert-level, multi-discipline benchmark for evaluating foundation models in video understanding. {MMVU} includes 3,000 expert-annotated questions spanning 27 subjects across four core disciplines: Science, Healthcare, Humanities \& Social Sciences, and Engineering. The benchmark challenges models to apply domain-specific knowledge and perform expert-level reasoning to analyze specialized-domain videos, moving beyond basic visual perception typically assessed in current video benchmarks. We conducted an extensive evaluation of 32 frontier multimodal foundation models on {MMVU}, finding that the latest System-2-capable models, o1 and Gemini 2.0 Flash Thinking, achieve the highest performance but still fall short of matching human expertise.},
  author = {Zhao, Yilun and Xie, Lujing and Zhang, Haowei and Gan, Guo and Long, Yitao and Hu, Zhiyuan and Hu, Tongyan and Chen, Weiyuan and Li, Chuhan and Song, Junyang and Xu, Zhijian and Wang, Chengye and Pan, Weifeng and Shangguan, Ziyao and Tang, Xiangru and Liang, Zhenwen and Liu, Yixin and Zhao, Chen and Cohan, Arman},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition},
  doi = {10.48550/arXiv.2501.12380},
  eprint = {2501.12380},
  eprinttype = {arXiv},
  file = {:/home/b/documents/inproceedings/zhao2025mmvu.pdf:pdf},
  month = {6},
  pdf = {https://openaccess.thecvf.com/content/CVPR2025/papers/Zhao_MMVU_Measuring_Expert-Level_Multi-Discipline_Video_Understanding_CVPR_2025_paper.pdf},
  publisher = {IEEE},
  title = {{MMVU}: Measuring Expert-Level Multi-Discipline Video Understanding},
  url = {https://arxiv.org/abs/2501.12380},
  year = {2025}
}

@misc{zou2024seconds,
  abstract = {The integration of Large Language Models (LLMs) with visual encoders has recently shown promising performance in visual understanding tasks, leveraging their inherent capability to comprehend and generate human-like text for visual reasoning. Given the diverse nature of visual data, MultiModal Large Language Models (MM-LLMs) exhibit variations in model designing and training for understanding images, short videos, and long videos. While image and short video understanding have been extensively studied, long video understanding remains less explored, despite its significant challenges and substantial differences from short video understanding. Unlike static images, short videos encompass sequential frames with both spatial and within-event temporal information. Long videos consist of multiple events with between-event and long-term temporal information, featuring more fine-grained spatiotemporal details, dynamic events, and long-term dependencies. This survey aims to trace and summarize the advancements of MM-LLMs from image understanding to long video understanding, highlighting the unique challenges and approaches in processing extended temporal information.},
  archiveprefix = {arXiv},
  author = {Zou, Heqing and Luo, Tianze and Xie, Guiyang and Zhang, Victor Xiao Jie and Lv, Fengmao and Wang, Guangcong and Chen, Junyang and Wang, Zhuochen and Zhang, Hansheng and Zhang, Huaijian},
  eprint = {2409.18938},
  file = {:/home/b/documents/misc/zou2024seconds.pdf:pdf},
  month = {9},
  pdf = {https://arxiv.org/pdf/2409.18938.pdf},
  primaryclass = {cs.CV},
  title = {From Seconds to Hours: Reviewing MultiModal Large Language Models on Comprehensive Long Video Understanding},
  url = {https://arxiv.org/abs/2409.18938},
  year = {2024}
}

@misc{li2024multimodal,
  abstract = {This survey provides a comprehensive review of recent advancements in multimodal alignment and fusion within machine learning, driven by the growing diversity of data types including text, images, audio, and video. Multimodal integration improves model accuracy and broader applicability by leveraging complementary information across different modalities, and facilitates knowledge transfer in situations with limited data. We systematically categorize and analyze existing alignment and fusion techniques, drawing insights from an extensive review of more than 200 relevant papers. The survey addresses challenges of multimodal data integration including alignment issues, noise resilience, and disparities in feature representation while focusing on applications in domains like social media analysis, medical imaging, and emotion recognition. Our insights guide future research towards optimizing multimodal learning systems to enhance their scalability, robustness, and generalizability across various applications.},
  archiveprefix = {arXiv},
  author = {Li, Songtao and Tang, Hao},
  eprint = {2411.17040},
  file = {:/home/b/documents/misc/li2024multimodal.pdf:pdf},
  month = {11},
  pdf = {https://arxiv.org/pdf/2411.17040.pdf},
  primaryclass = {cs.CV},
  title = {Multimodal Alignment and Fusion: A Survey},
  url = {https://arxiv.org/abs/2411.17040},
  year = {2024}
}

@inproceedings{song2024moviechat,
  abstract = {Recently, integrating video foundation models and large language models to build a video understanding system can overcome the limitations of specific pre-defined vision tasks. Yet, existing systems can only handle videos with very few frames. In this paper, we propose {MovieChat} to address this issue. Specifically, {MovieChat} can handle videos with >10K frames on a 24GB graphics card. The key idea behind {MovieChat} is to represent the video using a sparse memory mechanism inspired by the Atkinson-Shiffrin memory model, which comprises ultra-short term, short-term, and long-term memory components. This design enables {MovieChat} to process lengthy videos efficiently while maintaining relevant information throughout the video. To evaluate long video understanding capability, we introduce {MovieChat-1K}, a new benchmark for long video understanding. {MovieChat-1K} contains 1K high quality video clips sourced from various movies and TV series with 14K manual annotations. Each video includes 1 dense caption for the whole video, 3 question-answering pairs for global mode and 10 question-answering pairs with timestamps for breakpoint mode. We provide comprehensive experimental results on both existing public benchmarks and our {MovieChat-1K} to demonstrate the effectiveness of {MovieChat}. Our method shows a clear advantage over existing approaches in terms of both computation efficiency and performance quality.},
  address = {Seattle, WA, USA},
  archiveprefix = {arXiv},
  author = {Song, Enxin and Chai, Wenhao and Wang, Guanhong and Zhang, Yucheng and Zhou, Haoyang and Wu, Feiyang and Chi, Haozhe and Guo, Xun and Ye, Tian and Zhang, Yanting and Lu, Yan and Hwang, Jenq-Neng and Wang, Gaoang},
  booktitle = {Proceedings of the {IEEE/CVF} Conference on Computer Vision and Pattern Recognition ({CVPR})},
  doi = {10.1109/CVPR52733.2024.01725},
  eprint = {2307.16449},
  file = {:/home/b/documents/inproceedings/song2024moviechat.pdf:pdf},
  month = {6},
  note = {Introduces {MovieChat-1K} benchmark with 1K long video clips and 14K annotations. Project page: \url{https://wenhaochai.com/MovieChat}},
  pages = {18345--18355},
  pdf = {https://openaccess.thecvf.com/content/CVPR2024/papers/Song_MovieChat_From_Dense_Token_to_Sparse_Memory_for_Long_Video_CVPR_2024_paper.pdf},
  primaryclass = {cs.CV},
  publisher = {IEEE},
  title = {{MovieChat}: From Dense Token to Sparse Memory for Long Video Understanding},
  url = {https://github.com/rese1f/MovieChat},
  year = {2024}
}

@misc{rawal2024cinepile,
  abstract = {Current datasets for long-form video understanding often fall short of providing genuine long-form comprehension challenges, as many tasks derived from these datasets can be successfully tackled by analyzing just one or a few random frames from a video. To address this issue, we present {CinePile}, a question-answer dataset specifically curated to necessitate genuine long-form video understanding. {CinePile} contains 305,000 multiple-choice questions derived from 9,396 long video clips sourced from movies and TV shows. Our innovative approach to creating this dataset leverages advanced {LLMs} with human-in-the-loop and builds upon human-generated raw data in the form of audio descriptions that were created to assist the vision impaired community. Audio descriptions naturally capture important visual details and temporal progression of scenes, making them a valuable resource for training models to understand long-form video content. We validate {CinePile} through comprehensive experiments and benchmarking with state-of-the-art video-centric {LLMs}, revealing that these models significantly lag behind human performance in genuine long-form video comprehension by 26\% to 70\%. We also demonstrate that {CinePile} has been specifically designed to benchmark genuine long-form video understanding, as models trained on it do not learn the common exploits found in other long-form video datasets.},
  archiveprefix = {arXiv},
  author = {Rawal, Ruchit and Saifullah, Khalid and Basri, Ronen and Jacobs, David and Somepalli, Gowthami and Goldstein, Tom},
  eprint = {2405.08813},
  file = {:/home/b/documents/misc/rawal2024cinepile.pdf:pdf},
  month = {5},
  note = {Dataset contains 305K multiple-choice questions from 9.4K long video clips. Dataset: \url{https://huggingface.co/datasets/tomg-group-umd/cinepile}. Submitted to ICLR 2025},
  pdf = {https://arxiv.org/pdf/2405.08813.pdf},
  primaryclass = {cs.CV},
  title = {{CinePile}: A Long Video Question Answering Dataset and Benchmark},
  url = {https://ruchitrawal.github.io/cinepile/},
  year = {2024}
}

@inproceedings{zhang2024llama,
  abstract = {With the rising tide of large language models ({LLM}s), there has been a growing interest in developing general-purpose instruction-following models, e.g., {ChatGPT}. To this end, we present {LLaMA}-{A}dapter, a lightweight adaption method for efficient instruction tuning of {LLaMA}. Using 52K self-instruct demonstrations, {LLaMA}-{A}dapter only introduces 1.2M learnable parameters upon the frozen {LLaMA} 7B model, and costs less than one hour for fine-tuning. Specifically, a zero-initialized attention mechanism is proposed. It adopts a learnable zero gating to adaptively inject the instructional cues into {LLaMA} within self-attention layers, contributing to a stable training process and superior final performance. In this way, {LLaMA}-{A}dapter can generate high-quality responses to diverse language instructions, comparable to {A}lpaca with fully fine-tuned 7B parameters. Besides language commands, by incorporating an image encoder, our approach can be simply extended to a multi-modal {LLM} for image-conditioned instruction following, which achieves superior multi-modal reasoning capacity on several popular benchmarks ({MME}, {MMBench}, {LVLM}-e{H}ub). Furthermore, we also verify the proposed zero-initialized attention mechanism for fine-tuning other pre-trained models ({ViT}, {RoBERTa}, {CLIP}) on traditional vision and language tasks, demonstrating the effectiveness and generalizability of our approach.},
  author = {Zhang, Renrui and Han, Jiaming and Liu, Chris and Zhou, Aojun and Lu, Pan and Qiao, Yu and Li, Hongsheng and Gao, Peng},
  booktitle = {The Twelfth International Conference on Learning Representations},
  file = {:/home/b/documents/inproceedings/zhang2024llama.pdf:pdf},
  month = {5},
  note = {arXiv:2303.16199},
  pdf = {https://openreview.net/pdf?id=d4UiXAHN2W},
  publisher = {OpenReview.net},
  title = {{LLaMA}-{A}dapter: {E}fficient {F}ine-tuning of {L}anguage {M}odels with {Z}ero-init {A}ttention},
  url = {https://openreview.net/forum?id=d4UiXAHN2W},
  year = {2024}
}

@inproceedings{maaz2024videochatgpt,
  abstract = {Conversation agents fueled by {L}arge {L}anguage {M}odels ({LLM}s) are providing a new way to interact with visual data. While there have been initial attempts for image-based conversation models, this work addresses the under-explored field of video-based conversation by introducing Video-{ChatGPT}. It is a multimodal model that merges a video-adapted visual encoder with an {LLM}. The resulting model is capable of understanding and generating detailed conversations about videos. We introduce a new dataset of 100,000 video-instruction pairs used to train Video-{ChatGPT} acquired via manual and semi-automated pipeline that is easily scalable and robust to label noise. We also develop a quantitative evaluation framework for video-based dialogue models to objectively analyze the strengths and weaknesses of video-based dialogue models.},
  address = {Bangkok, Thailand},
  author = {Maaz, Muhammad and Rasheed, Hanoona and Khan, Salman and Khan, Fahad Shahbaz},
  booktitle = {Proceedings of the 62nd Annual Meeting of the Association for Computational Linguistics (Volume 1: Long Papers)},
  doi = {10.18653/v1/2024.acl-long.679},
  editor = {Ku, Lun-Wei and Martins, Andre and Srikumar, Vivek},
  file = {:/home/b/documents/inproceedings/maaz2024videochatgpt.pdf:pdf},
  month = {8},
  note = {arXiv:2306.05424},
  pages = {12585--12602},
  pdf = {https://aclanthology.org/2024.acl-long.679.pdf},
  publisher = {Association for Computational Linguistics},
  title = {Video-{ChatGPT}: {T}owards {D}etailed {V}ideo {U}nderstanding via {L}arge {V}ision and {L}anguage {M}odels},
  url = {https://aclanthology.org/2024.acl-long.679},
  year = {2024}
}

@inproceedings{piergiovanni2024mirasol3b,
  abstract = {One of the main challenges of multimodal learning is the need to combine heterogeneous modalities (e.g., video, audio, text). For example, video and audio are obtained at much higher rates than text and are roughly aligned in time. They are often not synchronized with text, which comes as a global context, e.g., a title, or a description. Furthermore, video and audio inputs are of much larger volumes, and grow as the video length increases, which naturally requires more compute dedicated to these modalities and makes modeling of long-range dependencies harder. We here decouple the multimodal modeling, dividing it into separate, focused autoregressive models, processing the inputs according to the characteristics of the modalities. We propose a multimodal model, called Mirasol3B, consisting of an autoregressive component for the time-synchronized modalities (audio and video), and an autoregressive component for the context modalities which are not necessarily aligned in time but are still sequential. To address the long-sequences of the video-audio inputs, we propose to further partition the video and audio sequences in consecutive snippets and autoregressively process their representations. To that end, we propose a Combiner mechanism, which models the audio-video information jointly within a timeframe. The Combiner learns to extract audio and video features from raw spatio-temporal signals, and then learns to fuse these features producing compact but expressive representations per snippet. Our approach achieves the state-of-the-art on well established multimodal benchmarks, outperforming much larger models.},
  address = {Seattle, WA, USA},
  author = {Piergiovanni, A. J. and Noble, Isaac and Kim, Dahun and Ryoo, Michael S. and Gomes, Victor and Angelova, Anelia},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition},
  file = {:/home/b/documents/inproceedings/piergiovanni2024mirasol3b.pdf:pdf},
  month = {6},
  note = {arXiv:2311.05698},
  pages = {26804--26814},
  pdf = {https://openaccess.thecvf.com/content/CVPR2024/papers/Piergiovanni_Mirasol3B_A_Multimodal_Autoregressive_Model_for_Time-Aligned_and_Contextual_Modalities_CVPR_2024_paper.pdf},
  publisher = {IEEE},
  title = {Mirasol3B: A Multimodal Autoregressive Model for Time-Aligned and Contextual Modalities},
  url = {https://openaccess.thecvf.com/content/CVPR2024/html/Piergiovanni_Mirasol3B_A_Multimodal_Autoregressive_Model_for_Time-Aligned_and_Contextual_Modalities_CVPR_2024_paper.html},
  year = {2024}
}

@inproceedings{li2024videomamba,
  abstract = {Addressing the dual challenges of local redundancy and global dependencies in video understanding, this work innovatively adapts the {Mamba} to the video domain. The proposed {VideoMamba} overcomes the limitations of existing 3D convolution neural networks and video transformers. Its linear-complexity operator enables efficient long-term modeling, which is crucial for high-resolution long video understanding. Extensive experiments show that {VideoMamba} achieves the four core abilities in video understanding: (1) scalability in the visual domain without extensive dataset pretraining, thanks to a novel self-distillation technique; (2) sensitivity for recognizing short-term actions even with fine-grained motion differences; (3) superiority in long-term video understanding, showcasing significant advancements over traditional feature-based models; and (4) compatibility with other modalities, demonstrating robustness in multi-modal contexts. Through these distinct advantages, {VideoMamba} sets a new benchmark for video understanding, offering a scalable and efficient solution for comprehensive video understanding.},
  address = {Cham},
  author = {Li, Kunchang and Li, Xinhao and Wang, Yi and He, Yinan and Wang, Yali and Wang, Limin and Qiao, Yu},
  booktitle = {Computer Vision -- {ECCV} 2024: 18th European Conference on Computer Vision, Milan, Italy, September 29 -- October 4, 2024, Proceedings},
  doi = {10.1007/978-3-031-73347-5_14},
  file = {:/home/b/documents/inproceedings/li2024videomamba.pdf:pdf},
  isbn = {978-3-031-73347-5},
  month = {9},
  note = {arXiv:2403.06977},
  pages = {233--249},
  pdf = {https://www.ecva.net/papers/eccv_2024/papers_ECCV/papers/03773.pdf},
  publisher = {Springer Nature Switzerland},
  series = {Lecture Notes in Computer Science},
  title = {{VideoMamba}: {S}tate {S}pace {M}odel for {E}fficient {V}ideo {U}nderstanding},
  url = {https://link.springer.com/chapter/10.1007/978-3-031-73347-5_14},
  volume = {15063},
  year = {2024}
}

@inproceedings{gritsenko2024endtoend,
  abstract = {The most performant spatio-temporal action localisation models use external person proposals and complex external memory banks. We propose a fully end-to-end transformer based model that directly ingests an input video and outputs tubelets -- a sequence of bounding boxes and the action classes at each frame. Our flexible model can be trained with either sparse bounding-box supervision on individual frames or full tubelet annotations. And in both cases it predicts coherent tubelets as the output. Moreover our end-to-end model requires no additional pre-processing in the form of proposals or post-processing in terms of non-maximal suppression. We perform extensive ablation experiments and significantly advance the state-of-the-art on five different spatio-temporal action localisation benchmarks with both sparse keyframes and full tubelet annotations.},
  author = {Gritsenko, Alexey A. and Xiong, Xuehan and Djolonga, Josip and Dehghani, Mostafa and Sun, Chen and Lucic, Mario and Schmid, Cordelia and Arnab, Anurag},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition},
  doi = {10.1109/CVPR52733.2024.01556},
  file = {:/home/b/documents/inproceedings/gritsenko2024endtoend.pdf:pdf},
  month = {6},
  pages = {18373--18383},
  pdf = {https://openaccess.thecvf.com/content/CVPR2024/papers/Gritsenko_End-to-End_Spatio-Temporal_Action_Localisation_with_Video_Transformers_CVPR_2024_paper.pdf},
  publisher = {IEEE},
  title = {End-to-End Spatio-Temporal Action Localisation with Video Transformers},
  url = {https://openaccess.thecvf.com/content/CVPR2024/html/Gritsenko_End-to-End_Spatio-Temporal_Action_Localisation_with_Video_Transformers_CVPR_2024_paper.html},
  year = {2024}
}

@misc{lan2024vidcompress,
  abstract = {Video-based multimodal large language models (Video-LLMs) possess significant potential for video understanding tasks. However, most Video-LLMs treat videos as a sequential set of individual frames, which results in insufficient temporal-spatial interaction that hinders fine-grained comprehension and difficulty in processing longer videos due to limited visual token capacity. To address these challenges, we propose {VidCompress}, a novel Video-LLM featuring memory-enhanced temporal compression. {VidCompress} employs a dual-compressor approach: a memory-enhanced compressor captures both short-term and long-term temporal relationships in videos and compresses the visual tokens using a multiscale transformer with a memory-cache mechanism, while a text-perceived compressor generates condensed visual tokens by utilizing Q-Former and integrating temporal contexts into query embeddings with cross attention. Experiments on several {VideoQA} datasets and comprehensive benchmarks demonstrate that {VidCompress} efficiently models complex temporal-spatial relations and significantly outperforms existing Video-LLMs.},
  archiveprefix = {arXiv},
  author = {Lan, Xiaohan and Yuan, Yitian and Jie, Zequn and Ma, Lin},
  eprint = {2410.11417},
  file = {:/home/b/documents/misc/lan2024vidcompress.pdf:pdf},
  month = {10},
  pdf = {https://arxiv.org/pdf/2410.11417},
  primaryclass = {cs.CV},
  title = {{VidCompress}: Memory-Enhanced Temporal Compression for Video Understanding in Large Language Models},
  url = {https://arxiv.org/abs/2410.11417},
  year = {2024}
}



@inproceedings{wang2024internvideo2,
  abstract = {We introduce InternVideo2, a new family of video foundation models (ViFM) that achieve the state-of-the-art results in video recognition, video-text tasks, and video-centric dialogue. Our core design is a progressive training approach that unifies the masked video modeling, crossmodal contrastive learning, and next token prediction, scaling up the video encoder size to 6B parameters. At the data level, we prioritize spatiotemporal consistency by semantically segmenting videos and generating video-audio-speech captions. This improves the alignment between video and text. Through extensive experiments, we validate our designs and demonstrate superior performance on over 60 video and audio tasks. Notably, our model outperforms others on various video-related dialogue and long video understanding benchmarks, highlighting its ability to reason and comprehend longer contexts.},
  author = {Wang, Yi and Li, Yinan and He, Kunchang and Li, Jiashuo and Liu, Xinhao and Chen, Guo and Pei, Baoqi and Zheng, Rongkun and Xu, Jilan and Wang, Zun and Shi, Yansong and Jiang, Tianxiang and Li, Songze and Zhang, Hongjie and Huang, Yifei and Qiao, Yu and Wang, Yali and Wang, Limin},
  booktitle = {European Conference on Computer Vision},
  file = {:/home/b/documents/inproceedings/wang2024internvideo2.pdf:pdf},
  note = {arXiv:2403.15377},
  pages = {395--413},
  pdf = {https://arxiv.org/pdf/2403.15377.pdf},
  publisher = {Springer},
  title = {{InternVideo2}: Scaling Video Foundation Models for Multimodal Video Understanding},
  url = {https://link.springer.com/chapter/10.1007/978-3-031-73013-9_23},
  year = {2024}
}



@inproceedings{li2024mvbench,
  abstract = {With the rapid development of Multi-modal Large Language Models (MLLMs), a number of diagnostic benchmarks have recently emerged to evaluate the comprehension capabilities of these models. However, most existing benchmarks predominantly assess spatial understanding in static image tasks while overlooking temporal understanding in dynamic video tasks. In this work, we introduce MVBench, a comprehensive Multi-modal Video understanding Benchmark. It covers 20 challenging video tasks that cannot be effectively solved with a single frame, systematically evaluating the temporal understanding abilities of MLLMs. We develop a novel static-to-dynamic method to adapt static image tasks with dynamic evolution for temporal understanding. Furthermore, we develop VideoChat2, a robust video MLLM baseline, by progressive multi-modal training with diverse instruction-tuning data. Our extensive evaluation reveals that existing MLLMs are far from satisfactory in temporal understanding, while VideoChat2 largely surpasses leading models by over 15\% on MVBench.},
  author = {Li, Kunchang and Wang, Yali and He, Yinan and Li, Yizhuo and Wang, Yi and Liu, Yi and Wang, Zun and Xu, Jilan and Chen, Guo and Luo, Ping and Wang, Limin and Qiao, Yu},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  file = {:/home/b/documents/inproceedings/li2024mvbench.pdf:pdf},
  pages = {22195--22206},
  pdf = {https://openaccess.thecvf.com/content/CVPR2024/papers/Li_MVBench_A_Comprehensive_Multi-modal_Video_Understanding_Benchmark_CVPR_2024_paper.pdf},
  title = {MVBench: A Comprehensive Multi-modal Video Understanding Benchmark},
  url = {https://openaccess.thecvf.com/content/CVPR2024/html/Li_MVBench_A_Comprehensive_Multi-modal_Video_Understanding_Benchmark_CVPR_2024_paper.html},
  year = {2024}
}

@article{cheng2024videollama,
  abstract = {In this paper, we present the VideoLLaMA 2, a set of Video Large Language Models (Video-LLMs) designed to enhance spatial-temporal modeling and audio understanding in video and audio-oriented tasks. Building upon its predecessor, VideoLLaMA 2 incorporates a tailor-made Spatial-Temporal Convolution (STC) connector, which effectively captures the intricate spatial and temporal dynamics of video data. Additionally, the model integrates an Audio Branch through joint training, thereby enriching the multimodal understanding capabilities by seamlessly incorporating audio cues. Comprehensive evaluations on multiple-choice video question answering (MC-VQA), open-ended video question answering (OE-VQA), and video captioning (VC) tasks demonstrate that VideoLLaMA 2 consistently achieves competitive results among open-source models and even gets close to some proprietary models on several benchmarks.},
  author = {Cheng, Zesen and Leng, Sicong and Zhang, Hang and Xin, Yifei and Li, Xin and Chen, Guanzheng and Zhu, Yongxin and Zhang, Wenqi and Luo, Ziyang and Zhao, Deli and Bing, Lidong},
  doi = {10.48550/arXiv.2406.07476},
  file = {:/home/b/documents/article/cheng2024videollama.pdf:pdf},
  journal = {arXiv preprint arXiv:2406.07476},
  month = {6},
  pdf = {https://arxiv.org/pdf/2406.07476},
  title = {VideoLLaMA 2: Advancing Spatial-Temporal Modeling and Audio Understanding in Video-LLMs},
  url = {https://arxiv.org/abs/2406.07476},
  year = {2024}
}

@inproceedings{ren2024timechat,
  abstract = {This work proposes {TimeChat}, a time-sensitive multimodal large language model specifically designed for long video understanding. Our model incorporates two key architectural contributions: (1) a timestamp-aware frame encoder that binds visual content with the timestamp of each frame, and (2) a sliding video {Q-Former} that produces a video token sequence of varying lengths to accommodate videos of various durations. Additionally, we construct an instruction-tuning dataset, encompassing 6 tasks and a total of 125K instances, to further enhance {TimeChat}'s instruction-following performance. Experiment results across various video understanding tasks, such as dense captioning, temporal grounding, and highlight detection, demonstrate {TimeChat}'s strong zero-shot temporal localization and reasoning capabilities. For example, it achieves +9.2 {F1} score and +2.8 {CIDEr} on {YouCook2}, +5.8 {HIT}@1 on {QVHighlights}, and +27.5 {R}@1 ({IoU}=0.5) on {Charades-STA}, compared to state-of-the-art video large language models, holding the potential to serve as a versatile video assistant for long-form video comprehension tasks and satisfy realistic user requirements.},
  archiveprefix = {arXiv},
  author = {Ren, Shuhuai and Yao, Linli and Li, Shicheng and Sun, Xu and Hou, Lu},
  booktitle = {Proceedings of the {IEEE}/{CVF} Conference on Computer Vision and Pattern Recognition ({CVPR})},
  eprint = {2312.02051},
  file = {:/home/b/documents/inproceedings/ren2024timechat.pdf:pdf},
  pages = {14313--14323},
  pdf = {https://openaccess.thecvf.com/content/CVPR2024/papers/Ren_TimeChat_A_Time-sensitive_Multimodal_Large_Language_Model_for_Long_Video_CVPR_2024_paper.pdf},
  publisher = {IEEE},
  title = {{TimeChat}: A Time-sensitive Multimodal Large Language Model for Long Video Understanding},
  url = {https://openaccess.thecvf.com/content/CVPR2024/html/Ren_TimeChat_A_Time-sensitive_Multimodal_Large_Language_Model_for_Long_Video_CVPR_2024_paper.html},
  year = {2024}
}

@inproceedings{weng2024longvlm,
  abstract = {Current Video-based Large Language Models ({VideoLLMs}) encode video representations through pooling or query aggregation over visual tokens, making the computational costs affordable but often overlooking local information in long-term videos. To address this challenge, we introduce {LongVLM}, a simple yet effective {VideoLLM} for long video understanding. The key insight is that long videos often consist of sequential key events, complex actions, and camera movements. Our approach decomposes long videos into multiple short-term segments and encodes local features for each segment via a hierarchical token merging module. The features are then concatenated in temporal order to maintain the storyline across sequential short-term segments, with global semantics integrated into each local feature to enhance context understanding. This enables the encoding of video representations that incorporate both local and global information. Experimental results on {VideoChatGPT} benchmark and zero-shot video question-answering datasets demonstrate the superior capabilities of our model over previous state-of-the-art methods. Qualitative examples show that our model produces more precise responses for long video understanding tasks.},
  archiveprefix = {arXiv},
  author = {Weng, Yuetian and Han, Mingfei and He, Haoyu and Chang, Xiaojun and Zhuang, Bohan},
  booktitle = {Proceedings of the European Conference on Computer Vision ({ECCV})},
  doi = {10.1007/978-3-031-73414-4_26},
  eprint = {2404.03384},
  file = {:/home/b/documents/inproceedings/weng2024longvlm.pdf:pdf},
  pdf = {https://arxiv.org/pdf/2404.03384.pdf},
  publisher = {Springer},
  series = {Lecture Notes in Computer Science},
  title = {{LongVLM}: Efficient Long Video Understanding via Large Language Models},
  url = {https://link.springer.com/chapter/10.1007/978-3-031-73414-4_26},
  volume = {15091},
  year = {2024}
}



@inproceedings{he2024malmm,
  abstract = {Existing large multimodal models can only process a limited number of frames for short video understanding. This work focuses on designing an efficient model for long-term video understanding by processing videos in an online manner and storing past video information in a memory bank to reference historical content without exceeding context length constraints. The proposed memory bank is a plug-and-play module that can be integrated into existing large multimodal models and achieves state-of-the-art performance on video understanding tasks including video question answering and video captioning.},
  author = {He, Bo and Li, Hengduo and Jang, Young Kyun and Jia, Menglin and Cao, Xuefei and Shah, Ashish and Shrivastava, Abhinav and Lim, Ser-Nam},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  file = {:/home/b/documents/inproceedings/he2024malmm.pdf:pdf},
  pages = {13504--13514},
  pdf = {https://openaccess.thecvf.com/content/CVPR2024/papers/He_MA-LMM_Memory-Augmented_Large_Multimodal_Model_for_Long-Term_Video_Understanding_CVPR_2024_paper.pdf},
  title = {MA-LMM: Memory-Augmented Large Multimodal Model for Long-Term Video Understanding},
  url = {https://openaccess.thecvf.com/content/CVPR2024/html/He_MA-LMM_Memory-Augmented_Large_Multimodal_Model_for_Long-Term_Video_Understanding_CVPR_2024_paper.html},
  year = {2024}
}

@article{chen2024video,
  abstract = {Understanding videos is one of the fundamental directions in computer vision research, with extensive efforts dedicated to exploring various architectures such as RNN, 3D CNN, and Transformers. The newly proposed state space model architecture, Mamba, shows promising traits to extend its success in long sequence modeling to video modeling. This work categorizes Mamba into four roles for modeling videos, deriving a Video Mamba Suite composed of 14 models/modules, and evaluates them on 12 video understanding tasks to reveal the strong potential of Mamba on both video-only and video-language tasks while showing promising efficiency-performance trade-offs.},
  author = {Chen, Guo and Huang, Yifei and Xu, Jilan and Pei, Baoqi and Chen, Zhe and Li, Zhiqi and Wang, Jiahao and Li, Kunchang and Lu, Tong and Wang, Limin},
  file = {:/home/b/documents/article/chen2024video.pdf:pdf},
  journal = {arXiv preprint arXiv:2403.09626},
  month = {3},
  pdf = {https://arxiv.org/pdf/2403.09626.pdf},
  title = {Video Mamba Suite: State Space Model as a Versatile Alternative for Video Understanding},
  url = {https://arxiv.org/abs/2403.09626},
  year = {2024}
}



@article{zhou2024mlvu,
  abstract = {MLVU is proposed as a comprehensive benchmark for multi-task long video understanding, addressing limitations in existing video understanding benchmarks. The benchmark features videos of diversified lengths ranging from 3 minutes to 2 hours (average 12 minutes), includes various video genres such as movies, surveillance footage, egocentric videos, cartoons, and game videos. It covers 9 comprehensive task categories including Topic Reasoning, Anomaly Recognition, Video Summarization, Needle Question Answering, Ego Reasoning, Plot Question Answering, Sub-Scene Captioning, Action Count, and Action Order, comprising 2593 evaluation tasks. Evaluation of 23 popular MLLMs reveals that long-video understanding remains technically challenging, with GPT-4o achieving only 54.5% average score in multi-choice tasks.},
  author = {Zhou, Junjie and Shu, Yan and Zhao, Bo and Wu, Bingquan and Xiao, Junyu and Yang, Xi and Xiong, Yann and Zhang, Bo and Huang, Tiejun and Yin, Baobao},
  file = {:/home/b/documents/article/zhou2024mlvu.pdf:pdf},
  journal = {arXiv preprint arXiv:2406.04264},
  month = {6},
  note = {Accepted by CVPR 2025},
  pdf = {https://arxiv.org/pdf/2406.04264.pdf},
  title = {MLVU: A Comprehensive Benchmark for Multi-Task Long Video Understanding},
  url = {https://arxiv.org/abs/2406.04264},
  year = {2024}
}

@article{zeng2024timesuite,
  abstract = {Multimodal Large Language Models (MLLMs) have demonstrated impressive performance in short video understanding, but understanding long-form videos remains challenging. This work proposes TimeSuite, a collection of designs to improve long video understanding capability of existing short-form MLLMs through grounded tuning. The approach introduces VideoChat-T with token shuffling to compress video tokens and Temporal Adaptive Position Encoding (TAPE) for temporal awareness. TimePro, a comprehensive grounding-centric instruction tuning dataset with 349k high-quality annotations across 9 tasks, is developed for training. Experimental results show improvements of 5.6% and 6.8% on EgoSchema and VideoMME benchmarks respectively, with robust zero-shot temporal grounding capabilities.},
  author = {Zeng, Xiangyu and Li, Kunchang and Wang, Chenting and Li, Xinhao and Jiang, Tianxiang and Yan, Ziang and Li, Songze and Shi, Yansong and Yue, Zhengrong and Wang, Yi and Wang, Yali and Qiao, Yu and Wang, Limin},
  file = {:/home/b/documents/article/zeng2024timesuite.pdf:pdf},
  journal = {arXiv preprint arXiv:2410.19702},
  month = {10},
  note = {Accepted by ICLR 2025},
  pdf = {https://arxiv.org/pdf/2410.19702.pdf},
  title = {TimeSuite: Improving MLLMs for Long Video Understanding via Grounded Tuning},
  url = {https://arxiv.org/abs/2410.19702},
  year = {2024}
}

@article{song2024moviellm,
  abstract = {This paper proposes MovieLLM, a novel framework designed to create synthetic, high-quality data for long video understanding. The framework leverages GPT-4 and text-to-image models to generate detailed movie scripts and corresponding visuals, addressing the lack of high-quality diverse video data for training multimodal models. Rather than relying on conventional data sources, MovieLLM harnesses GPT-4 to produce synthesized data by providing specific themes, overviews, and styles to generate movie-level keyframe descriptions. The approach uses textual inversion to maintain style consistency while generating diverse scenes under unified aesthetics. Extensive experiments validate that MovieLLM-generated data significantly improves multimodal model performance in understanding complex video narratives.},
  author = {Song, Zhende and Wang, Chenchen and Sheng, Jiamu and Zhang, Chi and Yu, Gang and Fan, Jiayuan and Chen, Tao},
  file = {:/home/b/documents/article/song2024moviellm.pdf:pdf},
  journal = {arXiv preprint arXiv:2403.01422},
  month = {3},
  pdf = {https://arxiv.org/pdf/2403.01422.pdf},
  title = {MovieLLM: Enhancing Long Video Understanding with AI-Generated Movies},
  url = {https://arxiv.org/abs/2403.01422},
  year = {2024}
}



@article{fang2024mmbenchvideo,
  abstract = {The advent of large vision-language models ({LVLMs}) has spurred research into their applications in multi-modal contexts, particularly in video understanding. Traditional {VideoQA} benchmarks, despite providing quantitative metrics, often fail to encompass the full spectrum of video content and inadequately assess models' temporal comprehension. To address these limitations, we introduce {MMBench-Video}, a quantitative benchmark designed to rigorously evaluate {LVLMs}' proficiency in video understanding. {MMBench-Video} incorporates lengthy videos from {YouTube} and employs free-form questions, mirroring practical use cases. The benchmark is meticulously crafted to probe the models' temporal reasoning skills, with all questions human-annotated according to a carefully constructed ability taxonomy. We employ {GPT-4} for automated assessment, demonstrating superior accuracy and robustness over earlier {LLM}-based evaluations. Utilizing {MMBench-Video}, we have conducted comprehensive evaluations that include both proprietary and open-source {LVLMs} for images and videos. {MMBench-Video} stands as a valuable resource for the research community, facilitating improved evaluation of {LVLMs} and catalyzing progress in the field of video understanding. The evalutation code of {MMBench-Video} will be integrated into {VLMEvalKit}: https://github.com/open-compass/VLMEvalKit.},
  author = {Fang, Xinyu and Mao, Kangrui and Duan, Haodong and Zhao, Xiangyu and Li, Yining and Lin, Dahua and Chen, Kai},
  file = {:/home/b/documents/article/fang2024mmbenchvideo.pdf:pdf},
  journal = {arXiv preprint arXiv:2406.14515},
  month = {6},
  note = {cs.CV, Accepted at NeurIPS 2024 Datasets and Benchmarks Track},
  pdf = {https://arxiv.org/pdf/2406.14515},
  title = {{MMBench-Video}: A Long-Form Multi-Shot Benchmark for Holistic Video Understanding},
  url = {https://arxiv.org/abs/2406.14515},
  year = {2024}
}

@article{chen2024timemarker,
  abstract = {Rapid development of large language models (LLMs) has significantly advanced multimodal large language models (LMMs), particularly in vision-language tasks. However, existing video-language models often overlook precise temporal localization and struggle with videos of varying lengths. We introduce TimeMarker, a versatile Video-LLM designed for high-quality dialogue based on video content, emphasizing temporal localization. TimeMarker integrates Temporal Separator Tokens to enhance temporal awareness, accurately marking specific moments within videos. It employs the AnyLength mechanism for dynamic frame sampling and adaptive token merging, enabling effective handling of both short and long videos. Additionally, TimeMarker utilizes diverse datasets, including further transformed temporal-related video QA datasets, to bolster its temporal understanding capabilities. Image and interleaved data are also employed to further enhance the model's semantic perception ability. Evaluations demonstrate that TimeMarker achieves state-of-the-art performance across multiple benchmarks, excelling in both short and long video categories.},
  author = {Chen, Shimin and Lan, Xiaohan and Yuan, Yitian and Jie, Zequn and Ma, Lin},
  file = {:/home/b/documents/article/chen2024timemarker.pdf:pdf},
  journal = {arXiv preprint arXiv:2411.18211},
  month = {11},
  pdf = {https://arxiv.org/pdf/2411.18211.pdf},
  title = {{TimeMarker}: A Versatile Video-{LLM} for Long and Short Video Understanding with Superior Temporal Localization Ability},
  url = {https://arxiv.org/abs/2411.18211},
  year = {2024}
}

@article{lee2024look,
  abstract = {Current video-LMMs face critical challenges when applied to longer video sequences, as the attention mechanism incurs memory load and computational costs that scale quadratically with sequence length. This becomes prohibitive for processing extended video sequences, where sequence lengths often exceed 128K tokens. To address this challenge, we introduce Video-Ma2mba, a novel architecture that incorporates State Space Models (SSMs) within the Mamba-2 framework, replacing the attention mechanisms. This allows the LMMs to scale linearly in terms of time and memory requirements, making it feasible to handle long-duration video content. Additionally, we present Multi-Axis Gradient Checkpointing (MA-GC), a new method that strategically manages memory by retaining only essential activations across multiple computational axes. This approach significantly reduces the memory footprint compared to standard gradient checkpointing while maintaining training efficiency for long video sequences.},
  author = {Lee, Hosu and Kim, Junho and Kim, Je Hyeong},
  file = {:/home/b/documents/article/lee2024look.pdf:pdf},
  journal = {arXiv preprint arXiv:2411.19460},
  month = {11},
  pdf = {https://arxiv.org/pdf/2411.19460.pdf},
  title = {Look Every Frame All at Once: Video-Ma$^2$mba for Efficient Long-form Video Understanding with Multi-Axis Gradient Checkpointing},
  url = {https://arxiv.org/abs/2411.19460},
  year = {2024}
}

@inproceedings{wang2024videoclipxl,
  abstract = {Contrastive Language-Image Pre-training ({CLIP}) has been widely studied and applied in numerous applications. However, the emphasis on brief summary texts during pre-training prevents {CLIP} from understanding long descriptions. This issue is particularly acute regarding videos given that videos often contain abundant detailed contents. In this work, we propose {VideoCLIP-XL} (e{X}tra Length), which aims to unleash the long-description understanding capability of video {CLIP} models. We establish an automatic data collection system and gather a large-scale {VILD} pre-training dataset with {VI}deo and Long-{D}escription pairs. We then propose Text-similarity-guided Primary Component Matching ({TPCM}) to better learn the distribution of feature space while expanding the long description capability. To evaluate long-description understanding capability, we construct a Long Video Description Ranking ({LVDR}) benchmark. Meanwhile, we propose two new tasks: Detail-aware Description Ranking ({DDR}) and Hallucination-aware Description Ranking ({HDR}) to evaluate the model's ability to perceive video details and distinguish hallucinated content. Experimental results show that {VideoCLIP-XL} achieves significantly better long-description understanding while maintaining satisfactory performance on conventional short-text tasks.},
  address = {Miami, Florida, USA},
  author = {Wang, Jia-Peng and Wang, Chengyu and Luo, Xiangyu and Zhang, Jun and Yin, Hong and Wang, Shuo and Zhang, Yong},
  booktitle = {Proceedings of the 2024 Conference on Empirical Methods in Natural Language Processing (EMNLP)},
  doi = {10.18653/v1/2024.emnlp-main.898},
  file = {:/home/b/documents/inproceedings/wang2024videoclipxl.pdf:pdf},
  pages = {16061--16075},
  pdf = {https://aclanthology.org/2024.emnlp-main.898.pdf},
  publisher = {Association for Computational Linguistics},
  title = {{VideoCLIP-XL}: Advancing Long Description Understanding for Video {CLIP} Models},
  url = {https://aclanthology.org/2024.emnlp-main.898/},
  year = {2024}
}

@article{kim2024videoicl,
  abstract = {Recent advancements in video large multimodal models ({LMMs}) have significantly improved their video understanding and reasoning capabilities. However, their performance drops on out-of-distribution ({OOD}) tasks that are underrepresented in training data. Traditional methods like fine-tuning on {OOD} datasets are impractical due to high computational costs. While In-context learning ({ICL}) with demonstration examples has shown promising generalization performance in language tasks and image-language tasks without fine-tuning, applying {ICL} to video-language tasks faces challenges due to the limited context length in Video {LMMs}, as videos require longer token lengths. To address these issues, we propose {VideoICL}, a novel video in-context learning framework for {OOD} tasks that introduces a similarity-based relevant example selection strategy and a confidence-based iterative inference approach. This allows to select the most relevant examples and rank them based on similarity, to be used for inference. If the generated response has low confidence, our framework selects new examples and performs inference again, iteratively refining the results until a high-confidence response is obtained. This approach improves {OOD} video understanding performance by extending effective context length without incurring high costs. The experimental results on multiple benchmarks demonstrate significant performance gains, especially in domain-specific scenarios, laying the groundwork for broader video comprehension applications.},
  archiveprefix = {arXiv},
  author = {Kim, Kangsan and Park, Geon and Lee, Youngwan and Yeo, Woongyeong and Hwang, Sung Ju},
  eprint = {2412.02186},
  file = {:/home/b/documents/article/kim2024videoicl.pdf:pdf},
  journal = {arXiv preprint arXiv:2412.02186},
  month = {December},
  pdf = {https://arxiv.org/pdf/2412.02186},
  primaryclass = {cs.CV},
  title = {{VideoICL}: Confidence-based Iterative In-context Learning for Out-of-Distribution Video Understanding},
  url = {https://arxiv.org/abs/2412.02186},
  year = {2024}
}

@article{liu2024world,
  abstract = {Enabling long-context understanding remains a key challenge in scaling existing sequence models -- a crucial component in developing generally intelligent models that can process and operate over long temporal horizons that potentially consist of millions of tokens. We explore the development of 1M context language and video-language models by presenting our data curation process, training methodology, and open-source implementation for long sequence training. We introduce a family of 7B parameter models capable of processing documents and videos over 1M tokens, demonstrating strong performance on difficult retrieval tasks and long video understanding benchmarks. Our approach utilizes {RingAttention} to scalably train on long sequences and achieves high model flops utilization with optimized {Jax} implementations.},
  author = {Liu, Hao and Yan, Wilson and Zaharia, Matei and Abbeel, Pieter},
  doi = {10.48550/arXiv.2402.08268},
  file = {:/home/b/documents/article/liu2024world.pdf:pdf},
  journal = {arXiv preprint arXiv:2402.08268},
  month = {2},
  note = {Code and models available at https://largeworldmodel.github.io/},
  pdf = {https://arxiv.org/pdf/2402.08268},
  title = {World Model on Million-Length Video And Language With {Blockwise RingAttention}},
  url = {https://arxiv.org/abs/2402.08268},
  year = {2024}
}

@inproceedings{xu2024multi,
  abstract = {Video-and-language understanding has a variety of applications in the industry, such as video question answering, text-video retrieval, and multi-label classification. Existing video-and-language understanding methods generally adopt heavy multi-modal encoders and feature fusion modules, which consume high computational costs. To address this issue, we propose {MuLTI}, a highly accurate and memory-efficient video-and-language understanding model that achieves efficient and effective feature fusion through innovative sampling and attention mechanisms. The model introduces a Text-Guided {MultiWay-Sampler} to condense textual features and a Multiple Choice Modeling pre-training task to enhance performance. Experimental results demonstrate state-of-the-art performance on multiple video-language understanding benchmarks while maintaining computational efficiency.},
  author = {Xu, Jiaqi and Liu, Bo and Xia, Qiang and Yin, Yifeng and Li, Xinglong and Qiu, Xin and Zhang, Dan and Xiong, Hui},
  booktitle = {Proceedings of the AAAI Conference on Artificial Intelligence},
  doi = {10.1609/aaai.v38i6.28395},
  file = {:/home/b/documents/inproceedings/xu2024multi.pdf:pdf},
  number = {6},
  pages = {5903--5911},
  pdf = {https://arxiv.org/pdf/2303.05707v2},
  publisher = {AAAI Press},
  title = {{MuLTI}: Efficient Video-and-Language Understanding with Text-Guided {MultiWay-Sampler} and Multiple Choice Modeling},
  url = {https://ojs.aaai.org/index.php/AAAI/article/view/28395},
  volume = {38},
  year = {2024}
}

