  month = {11},
  pages = {10031--10045},
  pdf = {https://aclanthology.org/2024.emnlp-main.559.pdf},
  publisher = {Association for Computational Linguistics},
  title = {{OmAgent}: A Multi-modal Agent Framework for Complex Video Understanding with Task Divide-and-Conquer},
  url = {https://aclanthology.org/2024.emnlp-main.559/},
  year = {2024}
}

@inproceedings{ding2024pvuw,
  abstract = {This paper reports on the Pixel-level Video Understanding in the Wild Challenge ({PVUW}) 2024, which focuses on complex video understanding. Two new tracks were added: Complex Video Object Segmentation Track based on {MOSE} dataset and Motion Expression guided Video Segmentation track based on {MeViS} dataset. The {MOSE} challenge had 140 registered teams with 12 final submissions, while the {MeViS} challenge had 225 registered teams with 5 final submissions. These tracks foster the development of comprehensive and robust pixel-level understanding of video scenes in complex environments, featuring challenging elements such as disappearance and reappearance of objects, inconspicuous small objects, heavy occlusions, and crowded environments.},
  author = {Ding, Henghui and Liu, Chang and Wei, Yunchao and Ravi, Nikhila and He, Shuting and Bai, Song and Torr, Philip},
  booktitle = {IEEE/CVF Conference on Computer Vision and Pattern Recognition Workshops},
  doi = {10.48550/arXiv.2406.17005},
  eprint = {2406.17005},
  eprinttype = {arXiv},
  file = {:/home/b/documents/inproceedings/ding2024pvuw.pdf:pdf},
  month = {6},
  note = {Pixel-level Video Understanding in the Wild Challenge report},
  pdf = {https://arxiv.org/pdf/2406.17005.pdf},
  publisher = {IEEE},
  series = {CVPR '24 Workshops},
  title = {{PVUW} 2024 Challenge on Complex Video Understanding: Methods and Results},
  url = {https://arxiv.org/abs/2406.17005},
  year = {2024}
}

@inproceedings{suglia2024alanavlm,
  abstract = {{AI} personal assistants deployed via robots or wearables require embodied understanding to collaborate with humans effectively. {AlanaVLM} is presented, a 7B parameter {VLM} trained using parameter-efficient methods on {EVUD} (Egocentric Video Understanding Dataset), which achieves state-of-the-art performance, outperforming open-source models including strong Socratic models using {GPT}-4 as a planner by 3.6\%. The model showcases competitive results compared to Gemini Pro 1.5 and {GPT}-4V, even surpassing the latter in spatial reasoning, paving the way for building efficient {VLMs} that can be deployed in robots or wearables for seamless human collaboration.},
  address = {Miami, Florida, USA},
  author = {Suglia, Alessandro and Greco, Claudio and Baker, Katie and Part, Jose L. and Papaioannou, Ioannis and Eshghi, Arash and Konstas, Ioannis and Lemon, Oliver},
  booktitle = {Findings of the Association for Computational Linguistics: EMNLP 2024},
  doi = {10.18653/v1/2024.findings-emnlp.649},
  eprint = {2406.13807},
  eprinttype = {arXiv},
  file = {:/home/b/documents/inproceedings/suglia2024alanavlm.pdf:pdf},
