}

@inproceedings{mckinzie2024mm1,
  abstract = {In this work, we discuss building performant Multimodal Large Language Models (MLLMs). In particular, we study the importance of various architecture components and data choices. Through careful and comprehensive ablations of the image encoder, the vision language connector, and various pre-training data choices, we identify several crucial design lessons. For example, we demonstrate that for large-scale multimodal pre-training using a careful mix of image-caption, interleaved image-text, and text-only data is crucial for achieving state-of-the-art (SOTA) few-shot results across multiple benchmarks, compared to other data balances. We also show that the image encoder together with image resolution and image token count has substantial impact, while the vision-language connector design is of comparatively negligible importance. By scaling up to 30B parameters, MM1 achieves competitive performance compared to other multimodal models of similar scale, and shows appealing properties such as enhanced in-context learning, and multi-image reasoning, enabling few-shot chain-of-thought prompting.},
  author = {McKinzie, Brandon and Gan, Zhe and Fauconnier, Jean-Philippe and Dodge, Sam and Zhang, Bowen and Dufter, Philipp and Shah, Dhruti and Du, Xianzhi and Peng, Futang and Weers, Floris and Belyi, Anton and Zhang, Haotian and Singh, Karanjeet and Kang, Doug and Jain, Ankur and He, Hongyu and Schwarzer, Max and Gunter, Tom and Kong, Xiang and Zhang, Aonan and Wang, Jianyu and Wang, Chong and Du, Nan and Lei, Tao and Wiseman, Sam and Yin, Guoli and Lee, Mark and Wang, Zirui and Pang, Ruoming and Grasch, Peter and Toshev, Alexander and Yang, Yinfei},
  booktitle = {Computer Vision -- ECCV 2024},
  doi = {10.1007/978-3-031-73397-0_18},
  file = {:/home/b/documents/inproceedings/mckinzie2024mm1.pdf:pdf},
  pdf = {https://arxiv.org/pdf/2403.09611.pdf},
  publisher = {Springer},
  series = {Lecture Notes in Computer Science},
  title = {{MM1}: Methods, Analysis \& Insights from Multimodal {LLM} Pre-training},
  url = {https://link.springer.com/chapter/10.1007/978-3-031-73397-0_18},
  year = {2024}
}

@inproceedings{chen2023vast,
  abstract = {Vision and text have been fully explored in contemporary video-text foundational models, while other modalities such as audio and subtitles in videos have not received sufficient attention. In this paper, we establish connections between multi-modality video tracks, including Vision, Audio, and Subtitle, and Text by exploring an automatically generated large-scale omni-modality video caption dataset called VAST-27M. Specifically, to generate high-quality omni-modality captions, we propose the following steps: (1) Collect 27 million open-domain video clips and separately train a vision and an audio captioner to generate vision and audio captions. (2) Employ an off-the-shelf Large Language Model (LLM) to integrate the generated captions, together with subtitles and instructional prompts into omni-modality captions. Based on the proposed VAST-27M dataset, we train an omni-modality video-text foundational model named VAST, which can perceive and process vision, audio, and subtitle modalities from video, and generate omni-modality captions. VAST achieves 22 new state-of-the-art results on various cross-modality benchmarks.},
  author = {Chen, Sihan and Li, Handong and Wang, Qunbo and Zhao, Zijia and Sun, Mingzhen and Zhu, Xinxin and Liu, Jing},
  booktitle = {Advances in Neural Information Processing Systems 36 (NeurIPS 2023)},
  file = {:/home/b/documents/inproceedings/chen2023vast.pdf:pdf},
  pdf = {https://arxiv.org/pdf/2305.18500.pdf},
  title = {{VAST}: A Vision-Audio-Subtitle-Text Omni-Modality Foundation Model and Dataset},
  url = {https://openreview.net/forum?id=scYa9DYUAy},
  year = {2023}
}

@inproceedings{chen2024davse,
  abstract = {This paper presents a novel diffusion model-based approach for audio-visual speech enhancement that uses complementary audio and visual modality information. The method leverages score-based diffusion models conditioned on visual embeddings and integrates audio and visual features using cross-attention modules. Experimental evaluations demonstrate that the proposed approach significantly enhances speech quality and reduces generative artifacts compared to audio-only systems.},
  author = {Chia-Wei Chen and Jen-Cheng Hou and Yu Tsao and Jun-Cheng Chen and Shao-Yi Chien},
  booktitle = {3rd COG-MHEAR Workshop on Audio-Visual Speech Enhancement (AVSEC)},
  file = {:/home/b/documents/inproceedings/chen2024davse.pdf:pdf},
  pages = {71--72},
  pdf = {https://www.isca-archive.org/avsec_2024/chen24b_avsec.pdf},
  title = {{DAVSE}: A Diffusion-Based Generative Approach for Audio-Visual Speech Enhancement},
  url = {https://www.isca-archive.org/avsec_2024/chen24b_avsec.html},
  year = {2024}
}

@inproceedings{araujo2025cavmae,
  abstract = {Recent advances in audio-visual learning have shown promising results in learning representations across modalities. However, most approaches rely on global audio representations that fail to capture fine-grained temporal correspondences with visual frames. Additionally, existing methods often struggle with conflicting optimization objectives when trying to jointly learn reconstruction and cross-modal alignment. In this work, we propose CAV-MAE Sync as a simple yet effective extension of the original CAV-MAE framework for self-supervised audio-visual learning. We address the granularity mismatch between modalities by treating audio as a temporal sequence aligned with video frames, rather than using global representations. We resolve conflicting optimization goals by separating contrastive and reconstruction objectives through dedicated global tokens.},
  archiveprefix = {arXiv},
  author = {Edson Araujo and Andrew Rouditchenko and Yuan Gong and Saurabhchand Bhati and Samuel Thomas and Brian Kingsbury and Leonid Karlinsky and Rogerio Feris and James R. Glass and Hilde Kuehne},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  eprint = {2505.01237},
  file = {:/home/b/documents/inproceedings/araujo2025cavmae.pdf:pdf},
  pages = {18794--18803},
  pdf = {https://arxiv.org/pdf/2505.01237.pdf},
  title = {{CAV-MAE} Sync: Improving Contrastive Audio-Visual Mask Autoencoders via Fine-Grained Alignment},
  url = {https://openaccess.thecvf.com/content/CVPR2025/html/Araujo_CAV-MAE_Sync_Improving_Contrastive_Audio-Visual_Mask_Autoencoders_via_Fine-Grained_Alignment_CVPR_2025_paper.html},
  year = {2025}
}

@inproceedings{wu2025avfmae,
  abstract = {This paper focuses on Affective Video Facial Analysis (AVFA) and addresses data scarcity challenges in emotion-aware AI. We introduce AVF-MAE++, a self-supervised learning approach that proposes a novel audio-visual dual masking strategy with an improved modality encoder. The method includes an Iteratively Audio-Visual Correlations Learning Module to improve correlations capture within the SSL framework. To support smooth adaptation and mitigate overfitting, we introduce a progressive semantics injection strategy. Extensive experiments across 17 datasets spanning three key AVFA tasks demonstrate the superior performance of AVF-MAE++, establishing new state-of-the-art results.},
  author = {Xuecheng Wu and Heli Sun and Yifan Wang and Jiayu Nie and Jie Zhang and Yabing Wang and Junxiao Xue and Liang He},
  booktitle = {Proceedings of the IEEE/CVF Conference on Computer Vision and Pattern Recognition (CVPR)},
  file = {:/home/b/documents/inproceedings/wu2025avfmae.pdf:pdf},
  note = {CVPR 2025 accepted paper. Supplemental materials available. Main PDF likely available on CVPR OpenAccess repository.},
  pdf = {https://openaccess.thecvf.com/content/CVPR2025/papers/Wu_AVF-MAE_Scaling_Affective_Video_Facial_Masked_Autoencoders_via_Efficient_Audio-Visual_CVPR_2025_paper.pdf},
  title = {{AVF-MAE++}: Scaling Affective Video Facial Masked Autoencoders via Efficient Audio-Visual Self-Supervised Learning},
  url = {https://cvpr.thecvf.com/virtual/2025/poster/34205},
  url-supplemental = {https://openaccess.thecvf.com/content/CVPR2025/supplemental/Wu_AVF-MAE_Scaling_Affective_CVPR_2025_supplemental.pdf},
  year = {2025}
}

@inproceedings{ishikawa2025languageguided,
  abstract = {This paper proposes Language-Guided Contrastive Audio-Visual Masked Autoencoders (LG-CAV-MAE) to improve audio-visual representation learning. The method integrates a pretrained text encoder into contrastive audio-visual masked autoencoders and introduces an automatic method to generate audio-visual-text triplets from unlabeled videos. We first generate frame-level captions using an image captioning model and then apply CLAP-based filtering to ensure strong alignment between audio and captions. The method achieves up to a 5.6\% improvement in recall@10 for retrieval tasks and a 3.2\% improvement for classification tasks.},
  archiveprefix = {arXiv},
  author = {Yuchi Ishikawa and Shota Nakada and Hokuto Munakata and Kazuhiro Saito and Tatsuya Komatsu and Yoshimitsu Aoki},
  booktitle = {Proceedings of Interspeech},
  eprint = {2507.11967},
  file = {:/home/b/documents/inproceedings/ishikawa2025languageguided.pdf:pdf},
  pdf = {https://arxiv.org/pdf/2507.11967.pdf},
  title = {Language-Guided Contrastive Audio-Visual Masked Autoencoder with Automatically Generated Audio-Visual-Text Triplets from Videos},
  url = {https://arxiv.org/abs/2507.11967},
  year = {2025}
}

@inproceedings{zverev2025vggsounder,
  abstract = {We introduce VGGSounder, a comprehensively re-annotated, multi-label test set that extends VGGSound and is specifically designed to evaluate audio-visual foundation models. VGGSounder provides multi-label annotations with detailed metadata indicating the presence of background music, voice-over, or static images, and merging of classes to address overlapping categories. The dataset features detailed modality annotations enabling precise analyses of modality-specific performance, revealing that more than a quarter of labels are audible but not visible. VGGSounder provides a robust foundation-model-ready benchmark enabling structured analysis of whether models rely on audio or visual cues.},
  archiveprefix = {arXiv},
  author = {Daniil Zverev and Thaddäus Wiedemer and Ameya Prabhu and Matthias Bethge and Wieland Brendel and A. Sophia Koepke},
  booktitle = {Proceedings of the IEEE/CVF International Conference on Computer Vision (ICCV)},
  eprint = {2508.08237},
  file = {:/home/b/documents/inproceedings/zverev2025vggsounder.pdf:pdf},
  pdf = {https://arxiv.org/pdf/2508.08237.pdf},
  title = {{VGGSounder}: Audio-Visual Evaluations for Foundation Models},
  url = {https://vggsounder.github.io/},
  year = {2025}
}

@article{zhang2025audiovisual,
  abstract = {Audio-visual representation learning is crucial for advancing multimodal speech processing tasks, such as lipreading and audio-visual speech recognition. Recently, speech foundation models (SFMs) have shown remarkable generalization capabilities across various speech-related tasks. Building on this progress, we propose an audio-visual representation learning model that leverages cross-modal knowledge distillation from SFMs. In our method, SFMs serve as teachers, from which multi-layer hidden representations are extracted using clean audio inputs. We also introduce a multi-teacher ensemble method to distill the student, which receives audio-visual data as inputs.},
  archiveprefix = {arXiv},
  author = {Jing-Xuan Zhang and Genshun Wan and Jianqing Gao and Zhen-Hua Ling},
  eprint = {2502.05766},
  file = {:/home/b/documents/article/zhang2025audiovisual.pdf:pdf},
  journal = {Pattern Recognition},
  pdf = {https://arxiv.org/pdf/2502.05766.pdf},
  title = {Audio-Visual Representation Learning via Knowledge Distillation from Speech Foundation Models},
  url = {https://www.sciencedirect.com/science/article/abs/pii/S0031320325000925},
  volume = {162},
  year = {2025}
}

@inproceedings{owens2016ambient,
  abstract = {We demonstrate that ambient sounds can be used as a supervisory signal for learning visual models. To demonstrate this, we train a convolutional neural network to predict a statistical summary of the sound associated with a video frame. Through this process, the network learns a representation that conveys information about objects and scenes. We evaluate this representation on several recognition tasks, finding that its performance is comparable to that of other state-of-the-art unsupervised learning methods. The visualizations show that the network learns units that are selective to objects that are often associated with characteristic sounds.},
  archiveprefix = {arXiv},
  author = {Andrew Owens and Jiajun Wu and Josh H. McDermott and William T. Freeman and Antonio Torralba},
  booktitle = {Computer Vision -- ECCV 2016},
  doi = {10.1007/978-3-319-46448-0_48},
  eprint = {1608.07017},
  file = {:/home/b/documents/inproceedings/owens2016ambient.pdf:pdf},
  pages = {801--816},
  pdf = {https://arxiv.org/pdf/1608.07017.pdf},
  publisher = {Springer},
  series = {Lecture Notes in Computer Science},
  title = {Ambient Sound Provides Supervision for Visual Learning},
  url = {https://link.springer.com/chapter/10.1007/978-3-319-46448-0_48},
  volume = {9905},
  year = {2016}
}

@inproceedings{owens2016visually,
  abstract = {Objects make distinctive sounds when they are hit or scratched. These sounds reveal aspects of an object's material properties, as well as the actions that produced them. We propose the task of predicting what sound an object makes when struck as a way of studying physical interactions within a visual scene. We present an algorithm that synthesizes sound from silent videos of people hitting and scratching objects with a drumstick. The algorithm uses a recurrent neural network to predict sound features from videos and then produces a waveform from these features with an example-based synthesis procedure. The sounds predicted by our model are realistic enough to fool participants in a real or fake psychophysical experiment.},
  archiveprefix = {arXiv},
  author = {Andrew Owens and Phillip Isola and Josh McDermott and Antonio Torralba and Edward H. Adelson and William T. Freeman},
  booktitle = {Proceedings of the IEEE Conference on Computer Vision and Pattern Recognition (CVPR)},
  eprint = {1512.08512},
  file = {:/home/b/documents/inproceedings/owens2016visually.pdf:pdf},
  pages = {2405--2413},
  pdf = {https://openaccess.thecvf.com/content_cvpr_2016/papers/Owens_Visually_Indicated_Sounds_CVPR_2016_paper.pdf},
  title = {Visually Indicated Sounds},
  url = {https://openaccess.thecvf.com/content_cvpr_2016/html/Owens_Visually_Indicated_Sounds_CVPR_2016_paper.html},
  year = {2016}
}

@inproceedings{korbar2018cooperative,
  abstract = {We leverage the natural correlation between visual and auditive elements of a video to learn general and effective models for both audio and video analysis from self-supervised temporal synchronization. We demonstrate that a calibrated curriculum learning scheme, a careful choice of negative examples, and the use of a contrastive loss are critical ingredients to obtain powerful multi-sensory representations from models optimized to discern temporal synchronization of audio-video pairs. Without further finetuning, the resulting audio features achieve performance superior or comparable to the state-of-the-art on established audio classification benchmarks. The visual subnet provides a very effective initialization that yields a remarkable gain of +19.9\% in action recognition accuracy on UCF101 and a boost of +17.7\% on HMDB51 compared to learning from scratch.},
  archiveprefix = {arXiv},
  author = {Bruno Korbar and Du Tran and Lorenzo Torresani},
  booktitle = {Advances in Neural Information Processing Systems 31 (NeurIPS)},
  eprint = {1807.00230},
  file = {:/home/b/documents/inproceedings/korbar2018cooperative.pdf:pdf},
  pdf = {https://proceedings.neurips.cc/paper/2018/file/c4616f5a24a66668f11ca4fa80525dc4-Paper.pdf},
  title = {Cooperative Learning of Audio and Video Models from Self-Supervised Synchronization},
  url = {https://proceedings.neurips.cc/paper/2018/hash/c4616f5a24a66668f11ca4fa80525dc4-Abstract.html},
  year = {2018}
}

@article{xiao2020audiovisual,
  abstract = {We present Audiovisual SlowFast Networks (AVSlowFast), an architecture for integrated audiovisual perception that has Slow and Fast visual pathways deeply integrated with a Faster Audio pathway to model vision and sound in a unified representation. We fuse audio and visual features at multiple layers, enabling audio to contribute to the formation of hierarchical audiovisual concepts. To overcome training difficulties from different learning dynamics for audio and visual modalities, we introduce DropPathway, which randomly drops the Audio pathway during training as an effective regularization technique. Inspired by neuroscience studies, we perform hierarchical audiovisual synchronization to learn joint audiovisual features. We report state-of-the-art results on six video action classification and detection datasets and show the generalization of AVSlowFast to learn self-supervised audiovisual features.},
  archiveprefix = {arXiv},
  author = {Fanyi Xiao and Yong Jae Lee and Kristen Grauman and Jitendra Malik and Christoph Feichtenhofer},
  eprint = {2001.08740},
  file = {:/home/b/documents/article/xiao2020audiovisual.pdf:pdf},
  journal = {arXiv preprint arXiv:2001.08740},
  pdf = {https://arxiv.org/pdf/2001.08740.pdf},
  title = {Audiovisual {SlowFast} Networks for Video Recognition},
  url = {https://arxiv.org/abs/2001.08740},
  year = {2020}
}

@inproceedings{lin2021unsupervised,
  abstract = {Sound localization aims to find the source of the audio signal in the visual scene. However, it is labor-intensive to annotate the correlations between the signals sampled from the audio and visual modalities, thus making it difficult to supervise the learning of a machine for this task. We propose an iterative contrastive learning framework that requires no data annotations. At each iteration, the method takes localization results in images predicted in the previous iteration, and semantic relationships inferred from the audio signals as pseudo-labels. These pseudo-labels are then used to learn the correlation between visual and audio signals sampled from the same video as well as associations between those extracted across videos. The iterative strategy gradually encourages the localization of sounding objects and reduces the correlation between non-sounding regions and the reference audio.},
  author = {Lin, Yan-Bo and Tseng, Hung-Yu and Lee, Hsin-Ying and Lin, Yen-Yu and Yang, Ming-Hsuan},
  booktitle = {Proceedings of the {IEEE}/CVF Winter Conference on Applications of Computer Vision},
  file = {:/home/b/documents/inproceedings/lin2021unsupervised.pdf:pdf},
  pages = {3350--3359},
  pdf = {https://arxiv.org/pdf/2104.00315.pdf},
  title = {Unsupervised Sound Localization via Iterative Contrastive Learning},
  url = {https://arxiv.org/abs/2104.00315},
  year = {2021}
}

@inproceedings{gao2018learning,
  abstract = {Learning to separate audio sources is an important goal for artificial audition. Recent approaches have leveraged visual information alongside audio to improve separation performance. However, most work assumes access to clean audio-visual training data, in which the correspondence between audio and visual components is perfect. In this paper, we propose to learn audio-visual object models from unlabeled video, then exploit the visual context to perform audio source separation in novel videos. Our deep multi-instance multi-label learning framework disentangles the audio frequency bases that map to individual visual objects, even without observing/hearing those objects in isolation. We then use the learned object-specific bases to perform audio source separation in novel videos. Our approach is the first to study audio source separation in large-scale general "in the wild" videos.},
  author = {Gao, Ruohan and Feris, Rogerio and Grauman, Kristen},
  booktitle = {Proceedings of the European Conference on Computer Vision (ECCV)},
  file = {:/home/b/documents/inproceedings/gao2018learning.pdf:pdf},
  pdf = {https://arxiv.org/pdf/1804.01665.pdf},
  title = {Learning to Separate Object Sounds by Watching Unlabeled Video},
  url = {https://arxiv.org/abs/1804.01665},
  year = {2018}
}

@inproceedings{li2022audiovisual,
  abstract = {This paper proposes an audio-visual multi-channel speech separation, dereverberation and recognition approach featuring a full incorporation of visual information into all system components. Accurate recognition of cocktail party speech is challenging due to overlapping speakers, background noise and room reverberation. A novel mask-based MVDR approach is developed to model long-range dependencies and leverage visual information for speech separation. DNN-WPE or spectral mapping based dereverberation methods are employed to handle room reverberation. A Conformer ASR system is trained on both clean and enhanced features. Experiments on the AVSpeech dataset demonstrate the efficacy of visual information incorporation in all three stages.},
  address = {Singapore},
  author = {Li, Guinan and Yu, Jianwei and Deng, Jiajun and Liu, Xunying and Meng, Helen},
  booktitle = {Proceedings of the {IEEE} International Conference on Acoustics, Speech and Signal Processing (ICASSP)},
  doi = {10.1109/ICASSP43922.2022.9747237},
  file = {:/home/b/documents/inproceedings/li2022audiovisual.pdf:pdf},
  pages = {6857--6861},
  pdf = {https://arxiv.org/pdf/2204.01977.pdf},
  title = {Audio-visual multi-channel speech separation, dereverberation and recognition},
  url = {https://arxiv.org/abs/2204.01977},
  year = {2022}
}

@article{sadok2023vector,
  abstract = {Self-supervised learning (SSL) approaches for audiovisual speech emotion recognition (SER) have received limited attention despite the recent remarkable progress of SSL methods and their application to emotion recognition from speech only. In this paper, we propose VQ-MAE-AV, a self-supervised multimodal model that leverages masked autoencoders to learn representations of audiovisual speech without labels. The approach utilizes vector quantized variational autoencoders to compress audio and visual speech data into discrete tokens, and employs global tokens that are learned using contrastive learning to capture sequence-wise information. The VQ-MAE-AV model achieves state-of-the-art emotion recognition results across several datasets in both controlled and in-the-wild conditions.},
  author = {Sadok, Samir and Leglaive, Simon and Séguier, Renaud},
  file = {:/home/b/documents/article/sadok2023vector.pdf:pdf},
  journal = {arXiv preprint arXiv:2305.03568},
  pdf = {https://arxiv.org/pdf/2305.03568.pdf},
  title = {A Vector Quantized Masked Autoencoder for Audiovisual Speech Emotion Recognition},
  url = {https://arxiv.org/abs/2305.03568},
  year = {2023}
}

@inproceedings{lin2024siamese,
  abstract = {We present AVSiam, an audio-visual siamese network that leverages a single shared vision transformer backbone to process both audio and visual inputs. This approach improves parameter efficiency, reduces GPU memory footprint, and allows scaling to larger datasets and model sizes. We pretrain AVSiam using a contrastive audio-visual matching objective with a multi-ratio random masking scheme.},
  author = {Lin, Yan-Bo and Bertasius, Gedas},
  booktitle = {European Conference on Computer Vision},
  file = {:/home/b/documents/inproceedings/lin2024siamese.pdf:pdf},
  note = {Original entry claimed different authors (Lopes, Kung, Faghri) and venue (ICML 2023) - corrected to actual paper},
  pdf = {https://arxiv.org/pdf/2403.19638.pdf},
  publisher = {Springer},
  title = {Siamese Vision Transformers are Scalable Audio-visual Learners},
  url = {https://arxiv.org/abs/2403.19638},
  year = {2024}
}

@inproceedings{alayrac2020selfsupervised,
  abstract = {Videos are a rich source of multi-modal supervision. In this work, we learn representations using self-supervision by leveraging three modalities naturally present in videos: visual, audio and language streams. We introduce MultiModal Versatile (MMV) networks that can ingest multiple modalities and whose representations enable downstream tasks in multiple modalities. We explore how best to combine the modalities, such that fine-grained representations of the visual and audio modalities can be maintained, whilst also integrating text into a common embedding. We introduce a novel process of deflation, so that the networks can be effortlessly applied to the visual data in the form of video or a static image. Networks trained on large collections of unlabelled video data can be applied on video, video-text, image and audio tasks. We obtain state-of-the-art performance on multiple challenging benchmarks including UCF101, HMDB51, Kinetics600, AudioSet and ESC-50 when compared to previous self-supervised work.},
  author = {Alayrac, Jean-Baptiste and Recasens, Adrià and Schneider, Rosalia and Arandjelović, Relja and Ramapuram, Jason and De Fauw, Jeffrey and Smaira, Lucas and Dieleman, Sander and Zisserman, Andrew},
  booktitle = {Advances in Neural Information Processing Systems},
  file = {:/home/b/documents/inproceedings/alayrac2020selfsupervised.pdf:pdf},
  pages = {25--37},
  pdf = {https://arxiv.org/pdf/2006.16228.pdf},
  title = {Self-Supervised MultiModal Versatile Networks},
  url = {https://proceedings.neurips.cc/paper/2020/hash/0060ef47b12160b9198302ebdb144dcf-Abstract.html},
  volume = {33},
  year = {2020}
}

@inproceedings{wang2024decoupling,
  abstract = {The increasing availability of multi-sensor data sparks wide interest in multimodal self-supervised learning. However, most existing approaches learn only common representations across modalities while ignoring intra-modal training and modality-unique representations. We propose Decoupling Common and Unique Representations (DeCUR), a simple yet effective method for multimodal self-supervised learning that can integrate complementary information across different modalities by distinguishing inter- and intra-modal embeddings through multimodal redundancy reduction. We evaluate DeCUR in three common multimodal scenarios: radar-optical, RGB-elevation, and RGB-depth, demonstrating consistent improvement regardless of architectures and for both multimodal and modality-missing settings.},
  author = {Wang, Yi and Albrecht, Conrad M. and Braham, Nassim Ait Ali and Liu, Chenying and Xiong, Zhitong and Zhu, Xiao Xiang},
  booktitle = {Computer Vision -- ECCV 2024},
  file = {:/home/b/documents/inproceedings/wang2024decoupling.pdf:pdf},
  pdf = {https://www.ecva.net/papers/eccv_2024/papers_ECCV/papers/04236.pdf},
  publisher = {Springer},
  series = {Lecture Notes in Computer Science},
  title = {Decoupling Common and Unique Representations for Multimodal Self-Supervised Learning},
  url = {https://arxiv.org/abs/2309.05300},
  volume = {15087},
  year = {2024}
}

@inproceedings{su2023towards,
  abstract = {To effectively exploit the potential of large-scale models, various pre-training strategies supported by massive data from different sources are proposed. However, current works adopt a multi-stage pre-training system, where the complex pipeline may increase uncertainty and instability. We propose a general multi-modal mutual information formula as a unified optimization target and demonstrate that all existing approaches are special cases of our framework. We then propose an all-in-one single-stage pre-training approach, named Maximizing Multi-modal Mutual Information Pre-training (M3I Pre-training). The approach achieves better performance than previous pre-training methods on various vision benchmarks, including ImageNet classification, COCO object detection, LVIS long-tailed object detection, and ADE20k semantic segmentation.},
  author = {Su, Weijie and Zhu, Xizhou and Tao, Chenxin and Lu, Lewei and Li, Bin and Huang, Gao and Qiao, Yu and Wang, Xiaogang and Zhou, Jie and Dai, Jifeng},
  booktitle = {Proceedings of the {IEEE}/{CVF} Conference on Computer Vision and Pattern Recognition},
  file = {:/home/b/documents/inproceedings/su2023towards.pdf:pdf},
  pages = {15888--15899},
  pdf = {https://openaccess.thecvf.com/content/CVPR2023/papers/Su_Towards_All-in-One_Pre-Training_via_Maximizing_Multi-Modal_Mutual_Information_CVPR_2023_paper.pdf},
  title = {Towards All-in-One Pre-Training via Maximizing Multi-Modal Mutual Information},
  url = {https://openaccess.thecvf.com/content/CVPR2023/html/Su_Towards_All-in-One_Pre-Training_via_Maximizing_Multi-Modal_Mutual_Information_CVPR_2023_paper.html},
  year = {2023}
}

@inproceedings{chung2016out,
  abstract = {The goal of this work is to determine the audio-video synchronisation between mouth motion and speech in a video. We propose a two-stream ConvNet architecture that enables the mapping between the sound and the mouth images to be trained end-to-end from unlabelled data. The trained network is used to determine the lip-sync error in a video and is applied to active speaker detection and lip reading tasks.},
  author = {Chung, Joon Son and Zisserman, Andrew},
  booktitle = {Computer Vision -- ACCV 2016 Workshops},
  file = {:/home/b/documents/inproceedings/chung2016out.pdf:pdf},
