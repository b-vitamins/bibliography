  publisher = {MIT Press},
  title = {Finite-Dimensional Approximation of Gaussian Processes},
  url = {https://proceedings.neurips.cc/paper_files/paper/1998/hash/55c567fd4395ecef6d936cf77b8d5b2b-Abstract.html},
