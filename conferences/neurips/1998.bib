  file = {:/home/b/documents/inproceedings/mcgovern1998scheduling.pdf:pdf},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/1998/file/596f713f9a7376fe90a62abaaedecc2d-Paper.pdf},
