  publisher = {MIT Press},
  title = {Infinite Mixtures of Gaussian Process Experts},
  url = {https://proceedings.neurips.cc/paper_files/paper/2001/hash/9afefc52942cb83c7c1f14b2139b09ba-Abstract.html},
