  volume = {4},
  year = {1991}
}

@inproceedings{zador1991nonlinear,
  abstract = {The dendritic trees of cortical pyramidal neurons seem ideally suited to perfonn local processing on inputs. To explore some of the implications of this complexity for the computational power of neurons, we simulated a realistic biophysical model of a hippocampal pyramidal cell in which a "cold spot"-a high density patch of inhibitory Ca-dependent K channels and a colocalized patch of Ca channels-was present at a dendritic branch point. The cold spot induced a non monotonic relationship be(cid:173) tween the strength of the synaptic input and the probability of neuronal fIring. This effect could also be interpreted as an analog stochastic XOR.},
  author = {Zador, Anthony and Claiborne, Brenda and Brown, Thomas},
