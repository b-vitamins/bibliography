  title = {Multimodular Architecture for Remote Sensing Operations.},
  url = {https://proceedings.neurips.cc/paper_files/paper/1991/hash/258be18e31c8188555c2ff05b4d542c3-Abstract.html},
  volume = {4},
  year = {1991}
}

