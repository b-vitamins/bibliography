  title = {Single Neuron Model: Response to Weak Modulation in the Presence of Noise},
  url = {https://proceedings.neurips.cc/paper_files/paper/1991/hash/559cb990c9dffd8675f6bc2186971dc2-Abstract.html},
  volume = {4},
  year = {1991}
}

