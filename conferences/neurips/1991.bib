@inproceedings{obermayer1991comparison,
  abstract = {Recently, high resolution images of the simultaneous representation of orientation preference, orientation selectivity and ocular dominance have been obtained for large areas in monkey striate cortex by optical imaging [1-3]. These data allow for the first time a "local" as well as "global" description of the spatial patterns and provide strong evidence for corre(cid:173) lations between orientation selectivity and ocular dominance. A quantitative analysis reveals that these correlations arise when a five(cid:173) dimensional feature space (two dimensions for retinotopic space, one each for orientation preference, orientation specificity, and ocular dominance) is mapped into the two available dimensions of cortex while locally preserving topology. These results provide strong evidence for the concept of topology preserving maps which have been suggested as a basic design principle of striate cortex [4-7].},
  author = {Obermayer, K. and Schulten, K. and Blasdel, G. G.},
