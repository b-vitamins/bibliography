  url = {https://proceedings.neurips.cc/paper_files/paper/1991/hash/2d6cc4b2d139a53512fb8cbb3086ae2e-Abstract.html},
  volume = {4},
  year = {1991}
}

@inproceedings{bengio1991neural,
  abstract = {The subject of this paper is the integration of multi-layered Artificial Neu(cid:173) ral Networks (ANN) with probability density functions such as Gaussian mixtures found in continuous density Hidden Markov Models (HMM). In the first part of this paper we present an ANN/HMM hybrid in which all the parameters of the the system are simultaneously optimized with respect to a single criterion. In the second part of this paper, we study the relationship between the density of the inputs of the network and the density of the outputs of the networks. A few experiments are presented to explore how to perform density estimation with ANNs.},
