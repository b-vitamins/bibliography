  publisher = {Morgan-Kaufmann},
  title = {Input Reconstruction Reliability Estimation},
  url = {https://proceedings.neurips.cc/paper_files/paper/1992/hash/b7bb35b9c6ca2aee2df08cf09d7016c2-Abstract.html},
