  year = {2003},
  volume = {16},
  url = {https://proceedings.neurips.cc/paper_files/paper/2003/hash/31c97cbb941d3e92d0e6f9925e9bc4d7-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2003/file/31c97cbb941d3e92d0e6f9925e9bc4d7-Paper.pdf},
  abstract = {Why are sensory modalities segregated the way they are? In this paper we show that sensory modalities are well designed for self-supervised cross-modal learning. Using the Minimizing-Disagreement algorithm on an unsupervised speech categorization task with visual (moving lips) and auditory (sound signal) inputs, we show that very informative auditory dimensions actually harm performance when moved to the visual side of the network. It is better to throw them away than to consider them part of the “visual input”. We explain this ﬁnding in terms of the statistical structure in sensory inputs.},
