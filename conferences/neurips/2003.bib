  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {MIT Press},
  year = {2003},
  volume = {16},
  url = {https://proceedings.neurips.cc/paper_files/paper/2003/hash/300891a62162b960cf02ce3827bb363c-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2003/file/300891a62162b960cf02ce3827bb363c-Paper.pdf},
  abstract = {Optimal solutions to Markov Decision Problems (MDPs) are very sen- sitive with respect to the state transition probabilities. In many practi- cal problems, the estimation of those probabilities is far from accurate. Hence, estimation errors are limiting factors in applying MDPs to real- world problems. We propose an algorithm for solving ﬁnite-state and ﬁnite-action MDPs, where the solution is guaranteed to be robust with respect to estimation errors on the state transition probabilities. Our al- gorithm involves a statistically accurate yet numerically efﬁcient repre- sentation of uncertainty, via Kullback-Leibler divergence bounds. The worst-case complexity of the robust algorithm is the same as the origi- nal Bellman recursion. Hence, robustness can be added at practically no extra computing cost.},
  file = {:/home/b/data/neurips/pdfs/jdwqemub22bg26n3rsfjqnbon74p2kclwirmnuo3wbnpgzpl46wq.pdf:pdf},
  editor = {S. Thrun and L. Saul and B. Schölkopf}
}

@inproceedings{sa2003sensory,
