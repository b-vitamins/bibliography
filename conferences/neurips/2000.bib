  volume = {13},
  url = {https://proceedings.neurips.cc/paper_files/paper/2000/hash/09fb05dd477d4ae6479985ca56c5a12d-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2000/file/09fb05dd477d4ae6479985ca56c5a12d-Paper.pdf},
  abstract = {The principle of maximizing mutual information is applied to learning overcomplete and recurrent representations. The underlying model con(cid:173) sists of a network of input units driving a larger number of output units with recurrent interactions. In the limit of zero noise, the network is de(cid:173) terministic and the mutual information can be related to the entropy of the output units. Maximizing this entropy with respect to both the feed(cid:173) forward connections as well as the recurrent interactions results in simple learning rules for both sets of parameters. The conventional independent components (ICA) learning algorithm can be recovered as a special case where there is an equal number of output units and no recurrent con(cid:173) nections. The application of these new learning rules is illustrated on a simple two-dimensional input example.},
  file = {:/home/b/data/neurips/pdfs/5f6xof4wereyngfnt2e7onxzw6aaf6rib7y6he4z43gnkpgmrhaa.pdf:pdf},
  editor = {T. Leen and T. Dietterich and V. Tresp}
}

@inproceedings{tong2000active,
