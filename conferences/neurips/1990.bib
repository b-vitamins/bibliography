  publisher = {Morgan-Kaufmann},
  title = {A Delay-Line Based Motion Detection Chip},
  url = {https://proceedings.neurips.cc/paper_files/paper/1990/hash/142949df56ea8ae0be8b5306971900a4-Abstract.html},
