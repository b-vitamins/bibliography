  publisher = {Morgan-Kaufmann},
  title = {Stereopsis by a Neural Network Which Learns the Constraints},
  url = {https://proceedings.neurips.cc/paper_files/paper/1990/hash/f9b902fc3289af4dd08de5d1de54f68f-Abstract.html},
  volume = {3},
  year = {1990}
}

