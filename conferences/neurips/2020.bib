@inproceedings{heim2020neural,
  author = {Heim, Niklas and Pevny, Tomas and Smidl, Vasek},
  title = {Neural Power Units},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
