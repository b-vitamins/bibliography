  title = {Finite-Time Analysis for Double Q-learning},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/c20bb2d9a50d5ac1f713f8b34d9aac5a-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/c20bb2d9a50d5ac1f713f8b34d9aac5a-Paper.pdf},
  abstract = {Although Q-learning is one of the most successful algorithms for finding the best action-value function (and thus the optimal policy) in reinforcement learning, its implementation often suffers from large overestimation of Q-function values incurred by random sampling. The double Q-learning algorithm proposed in~i̧tethasselt2010double overcomes such an overestimation issue by randomly switching the update between two Q-estimators, and has thus gained significant popularity in practice. However, the theoretical understanding of double Q-learning is rather limited. So far only the asymptotic convergence has been established, which does not characterize how fast the algorithm converges. In this paper, we provide the first non-asymptotic (i.e., finite-time) analysis for double Q-learning. We show that both synchronous and asynchronous double Q-learning are guaranteed to converge to an $ε$-accurate neighborhood of the global optimum by taking $\tildeØmegałeft(łeft( \frac1(1-γ)^6ε^2i̊ght)^\frac1ømega +łeft(\frac11-γ\g̊ht)^\frac11-ømega\rh̊t)$ iterations, where $ømegaın(0,1)$ is the decay parameter of the learning rate, and $γ$ is the discount factor. Our analysis develops novel techniques to derive finite-time bounds on the difference between two inter-connected stochastic processes, which is new to the literature of stochastic approximation.},
  file = {:/home/b/data/neurips/pdfs/bzwydvleyp3y6xnxer3xykm3cswsjxli54o7x5fjoukiljdw4zvq.pdf:pdf;:/home/b/data/neurips/pdfs/qlzmobv73oa76iabb4u5c5d3tklugqbzpz2bkljwd7bp7ssduqbq.pdf:pdf},
  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/2009.14257},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2009.14257},
  primaryclass = {cs.LG}
}

@inproceedings{zhang2020selfsupervised,
  author = {Zhang, Xiao and Maire, Michael},
