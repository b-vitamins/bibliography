  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {1910.02822},
  primaryclass = {cs.LG}
}

@inproceedings{karagulyan2020penalized,
  author = {Karagulyan, Avetik and Dalalyan, Arnak},
  title = {Penalized Langevin dynamics with vanishing penalty  for smooth and log-concave targets},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/cc75c256acc04ce25a291c4b7a9856c0-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/cc75c256acc04ce25a291c4b7a9856c0-Paper.pdf},
  abstract = {We study the problem of sampling from a probability distribution on $\mathbb R^p$ defined via a convex and smooth potential function. We first consider a continuous-time diffusion-type process, termed Penalized Langevin dynamics (PLD), the drift of which is the negative gradient of the potential plus a linear penalty that vanishes when time goes to infinity. An upper bound on the Wasserstein-2 distance between the distribution of the PLD at time $t$ and the target is established. This upper bound highlights the influence of the speed of decay of the penalty on the accuracy of approximation. As a consequence, in the case of low-temperature limit we infer a new result on the convergence of the penalized gradient flow for the optimization problem.},
  file = {:/home/b/data/neurips/pdfs/nw7b7sg7qtnximfgool77ozcvgsidoc7556awlt6crrntnltveca.pdf:pdf;:/home/b/data/neurips/pdfs/4k22vqaebhhqxe6jxxnrqwjwwecklvpfc6p7bhzysj77tv3el5za.pdf:pdf},
