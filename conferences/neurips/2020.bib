}

@inproceedings{ziyin2020neural,
  author = {Ziyin, Liu and Hartwig, Tilman and Ueda, Masahito},
  title = {Neural Networks Fail to Learn Periodic Functions and How to Fix It},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/1160453108d3e537255e9f7b931f4e90-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/1160453108d3e537255e9f7b931f4e90-Paper.pdf},
  abstract = {Previous literature offers limited clues on how to learn a periodic function using modern neural networks. We start with a study of the extrapolation properties of neural networks; we prove and demonstrate experimentally that the standard activations functions, such as ReLU, tanh, sigmoid, along with their variants, all fail to learn to extrapolate simple periodic functions. We hypothesize that this is due to their lack of a ``periodic" inductive bias. As a fix of this problem, we propose a new activation, namely, $x + \sin^2(x)$, which achieves the desired periodic inductive bias to learn a periodic function while maintaining a favorable optimization property of the $e̊lu$-based activations. Experimentally, we apply the proposed method to temperature and financial data prediction.},
  file = {:/home/b/data/neurips/pdfs/kqpqlbxjym46poqlnmhusaagmttufv5fr7k4eoh2gxoc5b7ruuza.pdf:pdf;:/home/b/data/neurips/pdfs/jj7cbmi6gmk7iveggu4x7flduk4zsv7kccnxqeqtbatslgplqz2a.pdf:pdf},
