  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/7a43ed4e82d06a1e6b2e88518fb8c2b0-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/7a43ed4e82d06a1e6b2e88518fb8c2b0-Paper.pdf},
  abstract = {We consider the classic problem of $(ε,δ)$-\textttPAC learning a best arm where the goal is to identify with confidence $1-δ$ an arm whose mean is an $ε$-approximation to that of the highest mean arm in a multi-armed bandit setting. This problem is one of the most fundamental problems in statistics and learning theory, yet somewhat surprisingly its worst case sample complexity is not well understood. In this paper we propose a new approach for $(ε,δ)$-\textttPAC learning a best arm. This approach leads to an algorithm whose sample complexity converges to \emphexactly the optimal sample complexity of $(ε,δ)$-learning the mean of $n$ arms separately and we complement this result with a conditional matching lower bound. More specifically: \beginitemize ıtem The algorithm's sample complexity converges to \emphexactly $\fracn2ε^2łog \frac1δ$ as $n$ grows and $δ ≥ \frac1n$; % ıtem We prove that no elimination algorithm obtains sample complexity arbitrarily lower than $\fracn2ε^2łog \frac1δ$. Elimination algorithms is a broad class of $(ε,δ)$-\textttPAC best arm learning algorithms that includes many algorithms in the literature. \enditemize When $n$ is independent of $δ$ our approach yields an algorithm whose sample complexity converges to $\frac2nε^2 łog \frac1δ$ as $n$ grows. In comparison with the best known algorithm for this problem our approach improves the sample complexity by a factor of over 1500 and over 6000 when $δ≥ \frac1n$.},
  file = {:/home/b/data/neurips/pdfs/zqglnevv2rc6oq7y4qpljxz45ketpfvmmktqr24h4hfkhca4umbq.pdf:pdf;:/home/b/data/neurips/pdfs/z6dkpa6s5froq3m3jneyfmywscldbhqjit34z734lxzqiadc4kea.zip:zip},
  archiveprefix = {arXiv},
