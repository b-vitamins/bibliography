  eprint = {2102.12660},
  primaryclass = {cs.LG}
}

@inproceedings{cho2020fair,
  author = {Cho, Jaewoong and Hwang, Gyeongjo and Suh, Changho},
  title = {A Fair Classifier Using Kernel Density Estimation},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/ac3870fcad1cfc367825cda0101eee62-Abstract.html},
