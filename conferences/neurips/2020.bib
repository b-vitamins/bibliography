  author = {Jamroż, Michał  and Kurdziel, Marcin and Opala, Mateusz},
  title = {A Bayesian Nonparametrics View into Deep Representations},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
