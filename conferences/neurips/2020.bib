}

@inproceedings{xie2020cser,
  author = {Xie, Cong and Zheng, Shuai and Koyejo, Sanmi and Gupta, Indranil and Li, Mu and Lin, Haibin},
  title = {CSER: Communication-efficient SGD with Error Reset},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/94cb02feb750f20bad8a85dfe7e18d11-Abstract.html},
