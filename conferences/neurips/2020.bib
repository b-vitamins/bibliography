  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2010.13064},
  primaryclass = {stat.ML}
}

@inproceedings{chowdhury2020faster,
  author = {Chowdhury, Agniva and London, Palma and Avron, Haim and Drineas, Petros},
  title = {Faster Randomized Infeasible Interior Point Methods for Tall/Wide Linear Programs},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/630eff1b380505a67570dff952ce4ad7-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/630eff1b380505a67570dff952ce4ad7-Paper.pdf},
  abstract = {Linear programming (LP) is used in many machine learning applications, such as $\ell_1$-regularized SVMs, basis pursuit, nonnegative matrix factorization, etc. Interior Point Methods (IPMs) are one of the most popular methods to solve LPs both in theory and in practice. Their underlying complexity is dominated by the cost of solving a system of linear equations at each iteration. In this paper, we consider \emphinfeasible IPMs for the special case where the number of variables is much larger than the number of constraints (i.e., wide), or vice-versa (i.e., tall) by taking the dual. Using tools from Randomized Linear Algebra, we present a preconditioning technique that, when combined with the Conjugate Gradient iterative solver, provably guarantees that infeasible IPM algorithms (suitably modified to account for the error incurred by the approximate solver), converge to a feasible, approximately optimal solution, without increasing their iteration complexity. Our empirical evaluations verify our theoretical results on both real and synthetic data.},
  file = {:/home/b/data/neurips/pdfs/rxo4y2tgilo27scumhl55cqkbzkynyqgxguycyvvfzvujyubdcqa.pdf:pdf;:/home/b/data/neurips/pdfs/mbzwmtpm2pkc3sbv3ix2iib4vbersdvcwsb6tktjfguuth37nega.zip:zip},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin}
}

@inproceedings{zhu2020bridging,
  author = {Zhu, Guangxiang and Zhang, Minghao and Lee, Honglak and Zhang, Chongjie},
  title = {Bridging Imagination and Reality for Model-Based Deep Reinforcement Learning},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/661b1e76b95cc50a7a11a85619a67d95-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/661b1e76b95cc50a7a11a85619a67d95-Paper.pdf},
  abstract = {Sample efficiency has been one of the major challenges for deep reinforcement learning. Recently, model-based reinforcement learning has been proposed to address this challenge by performing planning on imaginary trajectories with a learned world model. However, world model learning may suffer from overfitting to training trajectories, and thus model-based value estimation and policy search will be prone to be sucked in an inferior local policy. In this paper, we propose a novel model-based reinforcement learning algorithm, called BrIdging Reality and Dream (BIRD). It maximizes the mutual information between imaginary and real trajectories so that the policy improvement learned from imaginary trajectories can be easily generalized to real trajectories. We demonstrate that our approach improves sample efficiency of model-based planning, and achieves state-of-the-art performance on challenging visual control benchmarks.},
  file = {:/home/b/data/neurips/pdfs/lpwevy3za4pd4pm6mhmvk4pffpeeyjaygiss6wobb6mgw2xo5zsa.pdf:pdf;:/home/b/data/neurips/pdfs/ybjb5natumlgblsjso3rbibjzortpslvss2t6vh3anaw5lqw6bwa.pdf:pdf},
