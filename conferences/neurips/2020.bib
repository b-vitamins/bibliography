@inproceedings{scaman2020robustness,
  author = {Scaman, Kevin and Malherbe, Cedric},
  title = {Robustness Analysis of Non-Convex Stochastic Gradient Descent using Biased Expectations},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/bd4d08cd70f4be1982372107b3b448ef-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/bd4d08cd70f4be1982372107b3b448ef-Paper.pdf},
  abstract = {This work proposes a novel analysis of stochastic gradient descent (SGD) for non-convex and smooth optimization. Our analysis sheds light on the impact of the probability distribution of the gradient noise on the convergence rate of the norm of the gradient. In the case of sub-Gaussian and centered noise, we prove that, with probability $1-δ$, the number of iterations to reach a precision $ɛ$ for the squared gradient norm is $O(ɛ^-2łn(1/δ))$. In the case of centered and integrable heavy-tailed noise, we show that, while the expectation of the iterates may be infinite, the squared gradient norm still converges with probability $1-δ$ in $O(ɛ^-pδ^-q)$ iterations, where $p,q > 2$. This result shows that heavy-tailed noise on the gradient slows down the convergence of SGD without preventing it, proving that SGD is robust to gradient noise with unbounded variance, a setting of interest for Deep Learning. In addition, it indicates that choosing a step size proportional to $T^-1/b$ where $b$ is the tail-parameter of the noise and $T$ is the number of iterations leads to the best convergence rates. Both results are simple corollaries of a unified analysis using the novel concept of biased expectations, a simple and intuitive mathematical tool to obtain concentration inequalities. Using this concept, we propose a new quantity to measure the amount of noise added to the gradient, and discuss its value in multiple scenarios.},
  file = {:/home/b/data/neurips/pdfs/aahvh6islljwfdlrhqt4ansdovwu4jluuug4ovgpsheep63ptrza.pdf:pdf;:/home/b/data/neurips/pdfs/oyhaig553ecfr6mbzelm4xrldnfdzrbciqrigmihgqavaf7wjzqq.pdf:pdf},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin}
}

@inproceedings{nie2020skeletonbridged,
  author = {Nie, Yinyu and Lin, Yiqun and Han, Xiaoguang and Guo, Shihui and Chang, Jian and Cui, Shuguang and Zhang, Jian.J},
  title = {Skeleton-bridged Point Completion: From Global Inference to Local Adjustment},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/ba036d228858d76fb89189853a5503bd-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/ba036d228858d76fb89189853a5503bd-Paper.pdf},
  abstract = {Point completion refers to complete the missing geometries of objects from partial point clouds. Existing works usually estimate the missing shape by decoding a latent feature encoded from the input points. However, real-world objects are usually with diverse topologies and surface details, which a latent feature may fail to represent to recover a clean and complete surface. To this end, we propose a skeleton-bridged point completion network (SK-PCN) for shape completion. Given a partial scan, our method first predicts its 3D skeleton to obtain the global structure, and completes the surface by learning displacements from skeletal points. We decouple the shape completion into structure estimation and surface reconstruction, which eases the learning difficulty and benefits our method to obtain on-surface details. Besides, considering the missing features during encoding input points, SK-PCN adopts a local adjustment strategy that merges the input point cloud to our predictions for surface refinement. Comparing with previous methods, our skeleton-bridged manner better supports point normal estimation to obtain the full surface mesh beyond point clouds. The qualitative and quantitative experiments on both point cloud and mesh completion show that our approach outperforms the existing methods on various object categories.},
  file = {:/home/b/data/neurips/pdfs/p7t6khgd2zrmj7lbgaimycp3gob54uu4r5j22c5rmmmohfymxlaa.pdf:pdf},
  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/2010.07428},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2010.07428},
  primaryclass = {cs.CV}
}

@inproceedings{jiang2020when,
  author = {Jiang, Nan and Jin, Sheng and Duan, Zhiyao and Zhang, Changshui},
  title = {When Counterpoint Meets Chinese Folk Melodies},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/bae876e53dab654a3d9d9768b1b7b91a-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/bae876e53dab654a3d9d9768b1b7b91a-Paper.pdf},
  abstract = {Counterpoint is an important concept in Western music theory. In the past century, there have been significant interests in incorporating counterpoint into Chinese folk music composition. In this paper, we propose a reinforcement learning-based system, named FolkDuet, towards the online countermelody generation for Chinese folk melodies. With no existing data of Chinese folk duets, FolkDuet employs two reward models based on out-of-domain data, i.e. Bach chorales, and monophonic Chinese folk melodies. An interaction reward model is trained on the duets formed from outer parts of Bach chorales to model counterpoint interaction, while a style reward model is trained on monophonic melodies of Chinese folk songs to model melodic patterns. With both rewards, the generator of FolkDuet is trained to generate countermelodies while maintaining the Chinese folk style. The entire generation process is performed in an online fashion, allowing real-time interactive human-machine duet improvisation. Experiments show that the proposed algorithm achieves better subjective and objective results than the baselines.},
  file = {:/home/b/data/neurips/pdfs/h6jucyw6vr7dslpecmnpw7i2dlgo5zftmpt7zwufvjjn77kqxc4a.pdf:pdf;:/home/b/data/neurips/pdfs/r4zmibq2hrr76zlt3dq4s7tngnupxqida6fkt3w4aqe2j3jq6peq.zip:zip},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin}
}

@inproceedings{flamich2020compressing,
  author = {Flamich, Gergely and Havasi, Marton and Hernández-Lobato, José Miguel},
  title = {Compressing Images by Encoding Their Latent Representations with Relative Entropy Coding},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/ba053350fe56ed93e64b3e769062b680-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/ba053350fe56ed93e64b3e769062b680-Paper.pdf},
  abstract = {Variational Autoencoders (VAEs) have seen widespread use in learned image compression. They are used to learn expressive latent representations on which downstream compression methods can operate with high efficiency. Recently proposed 'bits-back' methods can indirectly encode the latent representation of images with codelength close to the relative entropy between the latent posterior and the prior. However, due to the underlying algorithm, these methods can only be used for lossless compression, and they only achieve their nominal efficiency when compressing multiple images simultaneously; they are inefficient for compressing single images. As an alternative, we propose a novel method, Relative Entropy Coding (REC), that can directly encode the latent representation with codelength close to the relative entropy for single images, supported by our empirical results obtained on the Cifar10, ImageNet32 and Kodak datasets. Moreover, unlike previous bits-back methods, REC is immediately applicable to lossy compression, where it is competitive with the state-of-the-art on the Kodak dataset.},
  file = {:/home/b/data/neurips/pdfs/oxkft7motkiwgxm2gwikykvi33jdaydpvkoclhy53ht4nhxc623a.pdf:pdf;:/home/b/data/neurips/pdfs/huh4ts45dea3f45w4w3jad42geit7ecbbpdf6gx6tsy7u3j6riga.zip:zip},
  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/2010.01185},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2010.01185},
  primaryclass = {cs.IT}
}

