  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2010.07494},
  primaryclass = {cs.LG}
}

@inproceedings{sadeghi2020single,
  author = {Sadeghi, Omid and Raut, Prasanna and Fazel, Maryam},
  title = {A Single Recipe for Online Submodular Maximization with Adversarial or Stochastic Constraints},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/a8e5a72192378802318bf51063153729-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/a8e5a72192378802318bf51063153729-Paper.pdf},
  abstract = {In this paper, we consider an online optimization problem in which the reward functions are DR-submodular, and in addition to maximizing the total reward, the sequence of decisions must satisfy some convex constraints on average. Specifically, at each round $tın\1,\dots,T\$, upon committing to an action $x_t$, a DR-submodular utility function $f_t(·)$ and a convex constraint function $g_t(·)$ are revealed, and the goal is to maximize the overall utility while ensuring the average of the constraint functions $\frac1T∑_t=1^T g_t(x_t)$ is non-positive. Such cumulative constraints arise naturally in applications where the average resource consumption is required to remain below a prespecified threshold. We study this problem under an adversarial model and a stochastic model for the convex constraints, where the functions $g_t$ can vary arbitrarily or according to an i.i.d. process over time slots $tın\1,\dots,T\$, respectively. We propose a single algorithm which achieves sub-linear (with respect to $T$) regret as well as sub-linear constraint violation bounds in both settings, without prior knowledge of the regime. Prior works have studied this problem in the special case of linear constraint functions. Our results not only improve upon the existing bounds under linear cumulative constraints, but also give the first sub-linear bounds for general convex long-term constraints.},
  file = {:/home/b/data/neurips/pdfs/hlrsfdb3u5zlj4mhmpxobwg2yrg6t3voan537sqt53weovautcna.pdf:pdf;:/home/b/data/neurips/pdfs/lzmuf2othse2gkadgjww6aygy3rxe6mf7jkdovlo6k5o66wkwb7q.zip:zip},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin}
}

@inproceedings{tian2020learningfeature,
