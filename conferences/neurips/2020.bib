}

@inproceedings{chen2020stochastic,
  author = {Chen, Hao and Zheng, Lili and AL Kontar, Raed and Raskutti, Garvesh},
  title = {Stochastic Gradient Descent in Correlated Settings: A Study on Gaussian Processes},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/1cb524b5a3f3f82be4a7d954063c07e2-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/1cb524b5a3f3f82be4a7d954063c07e2-Paper.pdf},
  abstract = {Stochastic gradient descent (SGD) and its variants have established themselves as the go-to algorithms for large-scale machine learning problems with independent samples due to their generalization performance and intrinsic computational advantage. However, the fact that the stochastic gradient is a biased estimator of the full gradient with correlated samples has led to the lack of theoretical understanding of how SGD behaves under correlated settings and hindered its use in such cases. In this paper, we focus on the Gaussian process (GP) and take a step forward towards breaking the barrier by proving minibatch SGD converges to a critical point of the full loss function, and recovers model hyperparameters with rate $O(\frac1K)$ up to a statistical error term depending on the minibatch size. Numerical studies on both simulated and real datasets demonstrate that minibatch SGD has better generalization over state-of-the-art GP methods while reducing the computational burden and opening a new, previously unexplored, data size regime for GPs.},
  file = {:/home/b/data/neurips/pdfs/e5iufo3h2orfgqje3huemflt5bkabgqntwncgg4i25dds3eylvyq.pdf:pdf;:/home/b/data/neurips/pdfs/ahjh3kismyuapa74f4qcd7jwgos3httpbp6kbbmhhot2jd2xzpea.pdf:pdf},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin}
}

@inproceedings{jiang2020minimax,
  author = {Jiang, Nan and Huang, Jiawei},
  title = {Minimax Value Interval for Off-Policy Evaluation and Policy Optimization},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/1cd138d0499a68f4bb72bee04bbec2d7-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/1cd138d0499a68f4bb72bee04bbec2d7-Paper.pdf},
  abstract = {We study minimax methods for off-policy evaluation (OPE) using value functions and marginalized importance weights. Despite that they hold promises of overcoming the exponential variance in traditional importance sampling, several key problems remain: (1) They require function approximation and are generally biased. For the sake of trustworthy OPE, is there anyway to quantify the biases? (2) They are split into two styles (“weight-learning” vs “value-learning”). Can we unify them? In this paper we answer both questions positively. By slightly altering the derivation of previous methods (one from each style), we unify them into a single value interval that comes with a special type of double robustness: when either the value-function or the importance-weight class is well specified, the interval is valid and its length quantifies the misspecification of the other class. Our interval also provides a unified view of and new insights to some recent methods, and we further explore the implications of our results on exploration and exploitation in off-policy policy optimization with insufficient data coverage.},
  file = {:/home/b/data/neurips/pdfs/ggzzf3mpqxce6f7pa3z7krdtuxa6fsqmt7lob5ns5ynxsdk5bmyq.pdf:pdf;:/home/b/data/neurips/pdfs/aguqfkc246q4nwhbnmuexyz2jkhe7xdduc5izvbnxemofy2szcwa.pdf:pdf},
  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/2002.02081},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2002.02081},
  primaryclass = {cs.LG}
}

