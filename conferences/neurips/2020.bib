  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2012.02295},
  primaryclass = {cs.IR}
}

@inproceedings{mamakoukas2020memoryefficient,
  author = {Mamakoukas, Giorgos (' Yorgos' ) and Xherija, Orest and Murphey, Todd},
