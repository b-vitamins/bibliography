@inproceedings{liao2020random,
  author = {Liao, Zhenyu and Couillet, Romain and Mahoney, Michael W},
  title = {A random matrix analysis of random Fourier features: beyond the Gaussian kernel, a precise phase transition, and the corresponding double descent},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/a03fa30821986dff10fc66647c84c9c3-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/a03fa30821986dff10fc66647c84c9c3-Paper.pdf},
  abstract = {This article characterizes the exact asymptotics of random Fourier feature (RFF) regression, in the realistic setting where the number of data samples $n$, their dimension $p$, and the dimension of feature space $N$ are all large and comparable. In this regime, the random RFF Gram matrix no longer converges to the well-known limiting Gaussian kernel matrix (as it does when $N \to ınfty$ alone), but it still has a tractable behavior that is captured by our analysis. This analysis also provides accurate estimates of training and test regression errors for large $n,p,N$. Based on these estimates, a precise characterization of two qualitatively different phases of learning, including the phase transition between them, is provided; and the corresponding double descent test error curve is derived from this phase transition behavior. These results do not depend on strong assumptions on the data distribution, and they perfectly match empirical results on real-world data sets.},
  file = {:/home/b/data/neurips/pdfs/zposjcfhnrs4jpgmaokyvcsckyxaxpgxwjovsoheulijqplf4fja.pdf:pdf;:/home/b/data/neurips/pdfs/bdjdkl3f2rvufs53zprk666udmfh6pn2lsdnranq72drtv7gnwkq.pdf:pdf},
  archiveprefix = {arXiv},
