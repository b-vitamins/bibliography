  author = {Kaddour, Jean and Saemundsson, Steindor and Deisenroth (he/him), Marc},
  title = {Probabilistic Active Meta-Learning},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/ef0d17b3bdb4ee2aa741ba28c7255c53-Abstract.html},
