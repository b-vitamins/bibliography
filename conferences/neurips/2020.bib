}

@inproceedings{muraleekrishnan2020coded,
  author = {Muralee Krishnan, Nikhil Krishnan and Hosseini, Seyederfan and Khisti, Ashish},
  title = {Coded Sequential Matrix Multiplication For Straggler Mitigation},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/b8fd7211e5247891e4d4f0562418868a-Abstract.html},
