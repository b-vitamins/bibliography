}

@inproceedings{sun2020faithful,
  author = {Sun, Haitian and Arnold, Andrew and Bedrax Weiss, Tania and Pereira, Fernando and Cohen, William W},
  title = {Faithful Embeddings for Knowledge Base Queries},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/fe74074593f21197b7b7be3c08678616-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/fe74074593f21197b7b7be3c08678616-Paper.pdf},
  abstract = {The deductive closure of an ideal knowledge base (KB) contains exactly the logical queries that the KB can answer. However, in practice KBs are both incomplete and over-specified, failing to answer some queries that have real-world answers. \emphQuery embedding (QE) techniques have been recently proposed where KB entities and KB queries are represented jointly in an embedding space, supporting relaxation and generalization in KB inference. However, experiments in this paper show that QE systems may disagree with deductive reasoning on answers that do not require generalization or relaxation. We address this problem with a novel QE method that is more faithful to deductive reasoning, and show that this leads to better performance on complex queries to incomplete KBs. Finally we show that inserting this new QE module into a neural question-answering system leads to substantial improvements over the state-of-the-art.},
  file = {:/home/b/data/neurips/pdfs/4y6rlhozod5lvpwm376rhqxah7yrsyugb6gomg2a77cg2qbkj7pq.pdf:pdf;:/home/b/data/neurips/pdfs/wwkbf4kahl7l7ofeijv4dwih2ehdmppp6gridjn6tnxoxw3rdauq.pdf:pdf},
  archiveprefix = {arXiv},
