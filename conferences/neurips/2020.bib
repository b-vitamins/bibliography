@inproceedings{meng2020sufficient,
  author = {Meng, Cheng and Yu, Jun and Zhang, Jingyi and Ma, Ping and Zhong, Wenxuan},
  title = {Sufficient dimension reduction for classification using principal optimal transport direction},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
