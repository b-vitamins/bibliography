  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/2002.09169},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2002.09169},
  primaryclass = {cs.LG}
}

@inproceedings{meronen2020stationary,
  author = {Meronen, Lassi and Irwanto, Christabella and Solin, Arno},
  title = {Stationary Activations for Uncertainty Calibration in Deep Learning},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/18a411989b47ed75a60ac69d9da05aa5-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/18a411989b47ed75a60ac69d9da05aa5-Paper.pdf},
  abstract = {We introduce a new family of non-linear neural network activation functions that mimic the properties induced by the widely-used Matérn family of kernels in Gaussian process (GP) models. This class spans a range of locally stationary models of various degrees of mean-square differentiability. We show an explicit link to the corresponding GP models in the case that the network consists of one infinitely wide hidden layer. In the limit of infinite smoothness the Mat\ŕn family results in the RBF kernel, and in this case we recover RBF activations. Mat\'ń activation functions result in similar appealing properties to their counterparts in GP models, and we demonstrate that the local stationarity property together with limited mean-square differentiability shows both good performance and uncertainty calibration in Bayesian deep learning tasks. In particular, local stationarity helps calibrate out-of-distribution (OOD) uncertainty. We demonstrate these properties on classification and regression benchmarks and a radar emitter classification task.},
  file = {:/home/b/data/neurips/pdfs/pf3q4ky6hx4q3bbthpiyjb27chabg7hdszwaneet7ml3lp6fluoq.pdf:pdf;:/home/b/data/neurips/pdfs/jpp64fh2n3gcbsxjrz7k6pd3waszn42q3gxffafd7l52yudst5cq.pdf:pdf},
  archiveprefix = {arXiv},
