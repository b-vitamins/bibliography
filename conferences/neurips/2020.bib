}

@inproceedings{chandak2020towards,
  author = {Chandak, Yash and Jordan, Scott and Theocharous, Georgios and White, Martha and Thomas, Philip S.},
  title = {Towards Safe Policy Improvement for Non-Stationary MDPs},
