}

@inproceedings{xu2020cotgan,
  author = {Xu, Tianlin and Wenliang, Li Kevin and Munn, Michael and Acciaio, Beatrice},
  title = {COT-GAN: Generating Sequential Data via Causal Optimal Transport},
