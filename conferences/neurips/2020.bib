  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2002.02547},
  primaryclass = {cs.LG}
}

@inproceedings{bhaskara2020online,
  author = {Bhaskara, Aditya and Karbasi, Amin and Lattanzi, Silvio and Zadimoghaddam, Morteza},
