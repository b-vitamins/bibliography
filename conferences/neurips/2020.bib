  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/dba4c1a117472f6aca95211285d0587e-Paper.pdf},
  abstract = {Consider an oracle which takes a point x and returns the minimizer of a convex function f in an l 2 ball of radius r around x. It is straightforward to show that roughly r^-1łog(1/epsilon) calls to the oracle suffice to find an ε-approximate minimizer of f in an l 2 unit ball. Perhaps surprisingly, this is not optimal: we design an accelerated algorithm which attains an epsilon-approximate minimizer with roughly r^-2/3 łog(1/epsilon) oracle queries, and give a matching lower bound. Further, we implement ball optimization oracles for functions with a locally stable Hessian using a variant of Newton's method and, in certain cases, stochastic first-order methods. The resulting algorithms apply to a number of problems of practical and theoretical import, improving upon previous results for logistic and l infinity regression and achieving guarantees comparable to the state-of-the-art for l p regression.},
  file = {:/home/b/data/neurips/pdfs/rqbdnxypvaqknrsehjcufjq6nbk3shejcbqzoiab7w47qfi6hqjq.pdf:pdf;:/home/b/data/neurips/pdfs/uuyku2sx6dtk5nduenh4ojlel7akwi3qxqdkxiodv3vhnjtz7lwa.pdf:pdf},
  archiveprefix = {arXiv},
