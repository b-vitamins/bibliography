}

@inproceedings{feldman2020continuous,
  author = {Feldman, Moran and Karbasi, Amin},
  title = {Continuous Submodular Maximization: Beyond DR-Submodularity},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/0f34132b15dd02f282a11ea1e322a96d-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/0f34132b15dd02f282a11ea1e322a96d-Paper.pdf},
  abstract = {In this paper, we propose the first continuous optimization algorithms that achieve a constant factor approximation guarantee for the problem of monotone continuous submodular maximization subject to a linear constraint. We first prove that a simple variant of the vanilla coordinate ascent, called \COORDINATE-ASCENT+, achieves a $(\frace-12e-1-\eps)$-approximation guarantee while performing $O(n/ε)$ iterations, where the computational complexity of each iteration is roughly $O(n/\sqrtε+nłog n)$ (here, $n$ denotes the dimension of the optimization problem). We then propose \COORDINATE-ASCENT++, that achieves the tight $(1-1/e-\eps)$-approximation guarantee while performing the same number of iterations, but at a higher computational complexity of roughly $O(n^3/\eps^2.5 + n^3 łog n / \eps^2)$ per iteration. However, the computation of each round of \COORDINATE-ASCENT++ can be easily parallelized so that the computational cost per machine scales as $O(n/\sqrtε+nłog n)$.},
  file = {:/home/b/data/neurips/pdfs/har5j2lsuyjuil4mcicqw3xbvlb4bbrtckk7phnqutsohq5cftfq.pdf:pdf;:/home/b/data/neurips/pdfs/dcpiqdluzyi3bcpqisgsyrbvp7jy4aissemvnenygvzvf445ye7a.pdf:pdf},
  archiveprefix = {arXiv},
