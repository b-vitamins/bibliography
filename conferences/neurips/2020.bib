  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2010.06808},
  primaryclass = {cs.LG}
}

@inproceedings{li2020delving,
  author = {Li, Yuxi and Xu, Ning and Peng, Jinlong and See, John and Lin, Weiyao},
