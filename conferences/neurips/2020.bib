@inproceedings{deng2020gametheoretic,
  author = {Deng, Xiaotie and Lavi, Ron and Lin, Tao and Qi, Qi and WANG, Wenwei and Yan, Xiang},
  title = {A Game-Theoretic Analysis of the Empirical Revenue Maximization Algorithm with Endogenous Sampling},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/37e79373884f0f0b70b5cb91fb947148-Abstract.html},
