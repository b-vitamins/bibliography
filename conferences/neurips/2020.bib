}

@inproceedings{li2020residual,
  author = {Li, Guilin and Zhang, Junlei and Wang, Yunhe and Liu, Chuanjian and Tan, Matthias and Lin, Yunfeng and Zhang, Wei and Feng, Jiashi and Zhang, Tong},
  title = {Residual Distillation: Towards Portable Deep Neural Networks without Shortcuts},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
