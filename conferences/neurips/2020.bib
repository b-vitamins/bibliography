@inproceedings{amberbirhabtegebrial2020generative,
  author = {Amberbir Habtegebrial, Tewodros and Jampani, Varun and Gallo, Orazio and Stricker, Didier},
  title = {Generative View Synthesis: From Single-view Semantics to Novel-view Images},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/3295c76acbf4caaed33c36b1b5fc2cb1-Abstract.html},
