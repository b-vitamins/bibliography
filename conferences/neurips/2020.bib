  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/e2e5096d574976e8f115a8f1e0ffb52b-Paper.pdf},
  abstract = {For the gradient computation across the time domain in Spiking Neural Networks (SNNs) training, two different approaches have been independently studied. The first is to compute the gradients with respect to the change in spike activation (activation-based methods), and the second is to compute the gradients with respect to the change in spike timing (timing-based methods). In this work, we present a comparative study of the two methods and propose a new supervised learning method that combines them. The proposed method utilizes each individual spike more effectively by shifting spike timings as in the timing-based methods as well as generating and removing spikes as in the activation-based methods. Experimental results showed that the proposed method achieves higher performance in terms of both accuracy and efficiency than the previous approaches.},
  file = {:/home/b/data/neurips/pdfs/blstau6cpscxmqeu5e6tawcv7d45bnp7jmijnly5q6kcfcjtan4q.pdf:pdf;:/home/b/data/neurips/pdfs/m2oo52w22ec2z3o6ml5cukx5kiq6owgahq65sacst2nyui364n7q.pdf:pdf},
  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/2006.02642},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2006.02642},
  primaryclass = {cs.NE}
}

@inproceedings{smith2020flajoletmartin,
  author = {Smith, Adam and Song, Shuang and Guha Thakurta, Abhradeep},
  title = {The Flajolet-Martin Sketch Itself Preserves Differential Privacy: Private Counting with Minimal Space},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/e3019767b1b23f82883c9850356b71d6-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/e3019767b1b23f82883c9850356b71d6-Paper.pdf},
  abstract = {We revisit the problem of counting the number of distinct elements $\dist$ in a data stream $D$, over a domain $[u]$. We propose an $(ε,δ)$-differentially private algorithm that approximates $\dist$ within a factor of $(1±γ)$, and with additive error of $O(\sqrtłn(1/δ)/ε)$, using space $O(łn(łn(u)/γ)/γ^2)$. We improve on the prior work at least quadratically and up to exponentially, in terms of both space and additive error. Our additive error guarantee is optimal up to a factor of $O(\sqrtłn(1/δ))$, and the space bound is optimal up to a factor of $Ołeft(\minłeft\łnłeft(\fracłn(u)γi̊ght), \frac1γ^2\g̊ht\\rh̊t)$. We assume the existence of an ideal uniform random hash function, and ignore the space required to store it. We later relax this requirement by assuming pseudorandom functions and appealing to a computational variant of differential privacy, SIM-CDP. Our algorithm is built on top of the celebrated Flajolet-Martin (FM) sketch. We show that FM-sketch is differentially private as is, as long as there are $≈ \sqrtłn(1/δ)/(εγ)$ distinct elements in the data set. Along the way, we prove a structural result showing that the maximum of $k$ i.i.d. random variables is statistically close (in the sense of $ε$-differential privacy) to the maximum of $(k+1)$ i.i.d. samples from the same distribution, as long as $k=Ømegałeft(\frac1ε\rit̊)$. Finally, experiments show that our algorithms introduces error within an order of magnitude of the non-private analogues for streams with thousands of distinct elements, even while providing strong privacy guarantee ($\epsłeq 1$).},
  file = {:/home/b/data/neurips/pdfs/6xw3qgmqroewsirgy4wlz66bkdoyyw7phhcfyr5ygqfctws25b6a.pdf:pdf;:/home/b/data/neurips/pdfs/3hawf4o3s5wcp324gxrw3xbqbbinitcei4x7dwgtnaf3xgp4jdra.pdf:pdf},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin}
}

@inproceedings{chewi2020exponential,
  author = {Chewi, Sinho and Le Gouic, Thibaut and Lu, Chen and Maunu, Tyler and Rigollet, Philippe and Stromme, Austin},
  title = {Exponential ergodicity of mirror-Langevin diffusions},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/e3251075554389fe91d17a794861d47b-Abstract.html},
