  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin}
}

@inproceedings{liu2020adam,
  author = {Liu, Rui and Wu, Tianyi and Mozafari, Barzan},
  title = {Adam with Bandit Sampling for Deep Learning},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/3a077e8acfc4a2b463c47f2125fdfac5-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/3a077e8acfc4a2b463c47f2125fdfac5-Paper.pdf},
  abstract = {Adam is a widely used optimization method for training deep learning models. It computes individual adaptive learning rates for different parameters. In this paper, we propose a generalization of Adam, called Adambs, that allows us to also adapt to different training examples based on their importance in the model's convergence. To achieve this, we maintain a distribution over all examples, selecting a mini-batch in each iteration by sampling according to this distribution, which we update using a multi-armed bandit algorithm. This ensures that examples that are more beneficial to the model training are sampled with higher probabilities. We theoretically show that Adambs improves the convergence rate of Adam---$O(\sqrt\fracłog nT )$ instead of $O(\sqrt\fracnT)$ in some cases. Experiments on various models and datasets demonstrate Adambs's fast convergence in practice.},
  file = {:/home/b/data/neurips/pdfs/z4f3w7cv6syfg2d4yubw7oyro3oak3fbxf2kgo7ucpyfb5bk32ca.pdf:pdf;:/home/b/data/neurips/pdfs/hdnhoxsobgk43ttzzb5ifhraztlcv4w3yzgecor7lsfy5j7nkdaq.pdf:pdf},
