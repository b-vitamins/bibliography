@inproceedings{waudbysmith2020confidence,
  author = {Waudby-Smith, Ian and Ramdas, Aaditya},
  title = {Confidence sequences for sampling without replacement},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/e96c7de8f6390b1e6c71556e4e0a4959-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/e96c7de8f6390b1e6c71556e4e0a4959-Paper.pdf},
  abstract = {Many practical tasks involve sampling sequentially without replacement (WoR) from a finite population of size $N$, in an attempt to estimate some parameter $þeta^⋆$. Accurately quantifying uncertainty throughout this process is a nontrivial task, but is necessary because it often determines when we stop collecting samples and confidently report a result. We present a suite of tools for designing \textitconfidence sequences (CS) for $þeta^⋆$. A CS is a sequence of confidence sets $(C_n)_n=1^N$, that shrink in size, and all contain $þeta^⋆$ simultaneously with high probability. We first exploit a relationship between Bayesian posteriors and martingales to construct a (frequentist) CS for the parameters of a hypergeometric distribution. We then present Hoeffding- and empirical-Bernstein-type time-uniform CSs and fixed-time confidence intervals for sampling WoR which improve on previous bounds in the literature.},
  file = {:/home/b/data/neurips/pdfs/rnjmagjlj3o7bwtleobf5bytz5t2im2hsewljs37u22yue2niyia.pdf:pdf;:/home/b/data/neurips/pdfs/3s7xvxiaoehzf7xfevdsaajmob6dtg3vk2ulb7w3cipqsyxluboq.pdf:pdf},
