  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2006.00558},
  primaryclass = {math.OC}
}

@inproceedings{bozic2020neural,
  author = {Bozic, Aljaz and Palafox, Pablo and Zollhöfer, Michael  and Dai, Angela and Thies, Justus and Niessner, Matthias},
  title = {Neural Non-Rigid Tracking},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/d93ed5b6db83be78efb0d05ae420158e-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/d93ed5b6db83be78efb0d05ae420158e-Paper.pdf},
  abstract = {We introduce a novel, end-to-end learnable, differentiable non-rigid tracker that enables state-of-the-art non-rigid reconstruction by a learned robust optimization. Given two input RGB-D frames of a non-rigidly moving object, we employ a convolutional neural network to predict dense correspondences and their confidences. These correspondences are used as constraints in an as-rigid-as-possible (ARAP) optimization problem. By enabling gradient back-propagation through the weighted non-linear least squares solver, we are able to learn correspondences and confidences in an end-to-end manner such that they are optimal for the task of non-rigid tracking. Under this formulation, correspondence confidences can be learned via self-supervision, informing a learned robust optimization, where outliers and wrong correspondences are automatically down-weighted to enable effective tracking. Compared to state-of-the-art approaches, our algorithm shows improved reconstruction performance, while simultaneously achieving 85 times faster correspondence prediction than comparable deep-learning based methods.},
