}

@inproceedings{ito2020tightlower,
  author = {Ito, Shinji},
  title = {A Tight Lower Bound and Efficient Reduction for Swap Regret},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/d79c8788088c2193f0244d8f1f36d2db-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/d79c8788088c2193f0244d8f1f36d2db-Paper.pdf},
  abstract = {Swap regret, a generic performance measure of online decision-making algorithms, plays an important role in the theory of repeated games, along with a close connection to correlated equilibria in strategic games. This paper shows an $Ømega( \sqrtT NłogN )$-lower bound for swap regret, where $T$ and $N$ denote the numbers of time steps and available actions, respectively. Our lower bound is tight up to a constant, and resolves an open problem mentioned, e.g., in the book by Nisan et al. (2007). Besides, we present a computationally efficient reduction method that converts no-external-regret algorithms to no-swap-regret algorithms. This method can be applied not only to the full-information setting but also to the bandit setting and provides a better regret bound than previous results.},
  file = {:/home/b/data/neurips/pdfs/je55r5jxdblkz6n5l6oqjsgvg5luqqucjhqzgaugp5zl22m7s56a.pdf:pdf;:/home/b/data/neurips/pdfs/ws4dozypujdh7hnexhwumzq3wdbs5qn75ydjrou7khtrf5ykpquq.pdf:pdf},
