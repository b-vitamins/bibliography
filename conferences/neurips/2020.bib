@inproceedings{lei2020online,
  author = {Lei, Jinlong and Yi, Peng and Hong, Yiguang and Chen, Jie and Shi, Guodong},
  title = {Online Convex Optimization Over Erdos-Renyi Random Networks},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/b3d6e130a30b176f2ca5af7d1e73953f-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/b3d6e130a30b176f2ca5af7d1e73953f-Paper.pdf},
  abstract = {The work studies how node-to-node communications over an Erdős-Rényi random network influence distributed online convex optimization, which is vital in solving large-scale machine learning in antagonistic or changing environments. At per step, each node (computing unit) makes a local decision, experiences a loss evaluated with a convex function, and communicates the decision with other nodes over a network. The node-to-node communications are described by the Erdős-R\ńyi rule, where independently each link takes place with a probability $p$ over a prescribed connected graph. The objective is to minimize the system-wide loss accumulated over a finite time horizon. We consider standard distributed gradient descents with full gradients, one-point bandits and two-points bandits for convex and strongly convex losses, respectively. We establish how the regret bounds scale with respect to time horizon $T$, network size $N$, decision dimension $d$, and an algebraic network connectivity. The regret bounds scaling with respect to $T$ match those obtained by state-of-the-art algorithms and fundamental limits in the corresponding centralized online optimization problems, e.g., $\mathcalO(\sqrtT) $ and $\mathcalO(łn(T)) $ regrets are established for convex and strongly convex losses with full gradient feedback and two-points information, respectively. For classical Erdős-R\'ýi networks over all-to-all possible node communications, the regret scalings with respect to the probability $p$ are analytically established, based on which the tradeoff between the communication overhead and computation accuracy is clearly demonstrated. Numerical studies have validated the theoretical findings.},
  file = {:/home/b/data/neurips/pdfs/b4czurn3zej6umwcbdfz2iwksh2wjaembhh52lokwgpbncm2huda.pdf:pdf;:/home/b/data/neurips/pdfs/vbqd7ouz7glqnoqa6jtsmcowtf6qx2ukblfx6o6yl5m76etpdj3q.pdf:pdf},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin}
}

@inproceedings{jambulapati2020robust,
