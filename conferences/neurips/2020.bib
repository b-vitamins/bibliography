  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/2006.09661},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2006.09661},
  primaryclass = {cs.CV}
}

@inproceedings{song2020multilabel,
  author = {Song, Jiaming and Ermon, Stefano},
  title = {Multi-label Contrastive Predictive Coding},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/5cd5058bca53951ffa7801bcdf421651-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/5cd5058bca53951ffa7801bcdf421651-Paper.pdf},
  abstract = {Variational mutual information (MI) estimators are widely used in unsupervised representation learning methods such as contrastive predictive coding (CPC). A lower bound on MI can be obtained from a multi-class classification problem, where a critic attempts to distinguish a positive sample drawn from the underlying joint distribution from (m-1) negative samples drawn from a suitable proposal distribution. Using this approach, MI estimates are bounded above by łog m, and could thus severely underestimate unless m is very large. To overcome this limitation, we introduce a novel estimator based on a multi-label classification problem, where the critic needs to jointly identify \emphmultiple positive samples at the same time. We show that using the same amount of negative samples, multi-label CPC is able to exceed the łog m bound, while still being a valid lower bound of mutual information. We demonstrate that the proposed approach is able to lead to better mutual information estimation, gain empirical improvements in unsupervised representation learning, and beat the current state-of-the-art in knowledge distillation over 10 out of 13 tasks.},
  file = {:/home/b/data/neurips/pdfs/3yvawahw7rxx75ydfunfjfqlzrdwd4eujc67pdxczfge5x34665a.pdf:pdf;:/home/b/data/neurips/pdfs/uzlx4m7vsaz5ew7nu5y2vpstwul4nyllvhceosjbdjjvis4rikza.pdf:pdf},
  archiveprefix = {arXiv},
