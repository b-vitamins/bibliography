}

@inproceedings{blum2020online,
  author = {Blum, Avrim and Shao, Han},
  title = {Online Learning with Primary and Secondary Losses},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/eb2e9dffe58d635b7d72e99c8e61b5f2-Abstract.html},
