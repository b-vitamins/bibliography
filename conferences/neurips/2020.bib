}

@inproceedings{zhu2020regret,
  author = {Zhu, Yinglun and Nowak, Robert},
  title = {On Regret with Multiple Best Arms},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/670c26185a3783678135b4697f7dbd1a-Abstract.html},
