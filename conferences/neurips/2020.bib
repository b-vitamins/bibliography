@inproceedings{bassily2020stability,
  author = {Bassily,  Raef and Feldman, Vitaly and Guzmán, Cristóbal and Talwar, Kunal},
  title = {Stability of Stochastic Gradient Descent on Nonsmooth Convex Losses},
