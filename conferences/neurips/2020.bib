  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2003.01908},
  primaryclass = {cs.LG}
}

@inproceedings{okuno2020extrapolation,
  author = {Okuno, Akifumi and Shimodaira, Hidetoshi},
