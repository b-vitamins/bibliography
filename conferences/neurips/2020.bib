  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/88855547570f7ff053fff7c54e5148cc-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/88855547570f7ff053fff7c54e5148cc-Paper.pdf},
  abstract = {Image-to-image translation has recently achieved remarkable results. But despite current success, it suffers from inferior performance when translations between classes require large shape changes. We attribute this to the high-resolution bottlenecks which are used by current state-of-the-art image-to-image methods. Therefore, in this work, we propose a novel deep hierarchical Image-to-Image Translation method, called DeepI2I. We learn a model by leveraging hierarchical features: (a) structural information contained in the bottom layers and (b) semantic information extracted from the top layers. To enable the training of deep I2I models on small datasets, we propose a novel transfer learning method, that transfers knowledge from pre-trained GANs. Specifically, we leverage the discriminator of a pre-trained GANs (i.e. BigGAN or StyleGAN) to initialize both the encoder and the discriminator and the pre-trained generator to initialize the generator of our model. Applying knowledge transfer leads to an alignment problem between the encoder and generator. We introduce an adaptor network to address this. On many-class image-to-image translation on three datasets (Animal faces, Birds, and Foods) we decrease mFID by at least 35% when compared to the state-of-the-art. Furthermore, we qualitatively and quantitatively demonstrate that transfer learning significantly improves the performance of I2I systems, especially for small datasets. Finally, we are the first to perform I2I translations for domains with over 100 classes.},
  file = {:/home/b/data/neurips/pdfs/apwhp6gtesbhwvkpkwdigslmxkvbofs7vjkxk3ndlyat2lb3525q.pdf:pdf;:/home/b/data/neurips/pdfs/ess5o3m26cmik24fsisc7okweom5pogyccpw2kivafqlxy3vu5iq.pdf:pdf},
  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/2011.05867},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2011.05867},
  primaryclass = {cs.CV}
}

@inproceedings{ehrhardt2020relate,
  author = {Ehrhardt, Sebastien and Groth, Oliver and Monszpart, Aron and Engelcke, Martin and Posner, Ingmar and Mitra, Niloy and Vedaldi, Andrea},
  title = {RELATE: Physically Plausible Multi-Object Scene Synthesis Using Structured Latent Spaces},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/806beafe154032a5b818e97b4420ad98-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/806beafe154032a5b818e97b4420ad98-Paper.pdf},
  abstract = {We present RELATE, a model that learns to generate physically plausible scenes and videos of multiple interacting objects. Similar to other generative approaches, RELATE is trained end-to-end on raw, unlabeled data. RELATE combines an object-centric GAN formulation with a model that explicitly accounts for correlations between individual objects. This allows the model to generate realistic scenes and videos from a physically-interpretable parameterization. Furthermore, we show that modeling the object correlation is necessary to learn to disentangle object positions and identity. We find that RELATE is also amenable to physically realistic scene editing and that it significantly outperforms prior art in object-centric scene generation in both synthetic (CLEVR, ShapeStacks) and real-world data (cars). In addition, in contrast to state-of-the-art methods in object-centric generative modeling, RELATE also extends naturally to dynamic scenes and generates videos of high visual fidelity. Source code, datasets and more results are available at http://geometry.cs.ucl.ac.uk/projects/2020/relate/.},
  file = {:/home/b/data/neurips/pdfs/3nqngbfwfvneniyltkrfvycyaki7ppgpf2jvroxknwfw7q6tqi7q.pdf:pdf;:/home/b/data/neurips/pdfs/hsyymcq4df47dp7whj6knu2boqkkt67wrvarwuk6ofrlrobksq5q.zip:zip},
  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/2007.01272},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2007.01272},
  primaryclass = {cs.CV}
}

@inproceedings{rouhani2020novel,
  author = {Rouhani, Sara and Rahman, Tahrima and Gogate, Vibhav},
  title = {A Novel Approach for Constrained Optimization in Graphical Models},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/8ab9bb97ce35080338be74dc6375e0ed-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/8ab9bb97ce35080338be74dc6375e0ed-Paper.pdf},
  abstract = {We consider the following constrained maximization problem in discrete probabilistic graphical models (PGMs). Given two (possibly identical) PGMs $M_1$ and $M_2$ defined over the same set of variables and a real number $q$, find an assignment of values to all variables such that the probability of the assignment is maximized w.r.t. $M_1$ and is smaller than $q$ w.r.t. $M_2$. We show that several explanation and robust estimation queries over graphical models are special cases of this problem. We propose a class of approximate algorithms for solving this problem. Our algorithms are based on a graph concept called $k$-separator and heuristic algorithms for multiple choice knapsack and subset-sum problems. Our experiments show that our algorithms are superior to the following approach: encode the problem as a mixed integer linear program (MILP) and solve the latter using a state-of-the-art MILP solver such as SCIP.},
  file = {:/home/b/data/neurips/pdfs/hyl3grywvlxkvs2mjdbzxl335vmyoprb7cxl5ei246uyaqjkf5fq.pdf:pdf;:/home/b/data/neurips/pdfs/cfxujiyr7w6h5s2s2g5nr3lzoxhiad3t56iwybugfxlrgryoer3a.zip:zip},
  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin}
}

@inproceedings{mentzer2020highfidelity,
  author = {Mentzer, Fabian and Toderici, George D and Tschannen, Michael and Agustsson, Eirikur},
  title = {High-Fidelity Generative Image Compression},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/8a50bae297807da9e97722a0b3fd8f27-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2020/file/8a50bae297807da9e97722a0b3fd8f27-Paper.pdf},
  abstract = {We extensively study how to combine Generative Adversarial Networks and learned compression to obtain a state-of-the-art generative lossy compression system. In particular, we investigate normalization layers, generator and discriminator architectures, training strategies, as well as perceptual losses. In contrast to previous work, i) we obtain visually pleasing reconstructions that are perceptually similar to the input, ii) we operate in a broad range of bitrates, and iii) our approach can be applied to high-resolution images. We bridge the gap between rate-distortion-perception theory and practice by evaluating our approach both quantitatively with various perceptual metrics, and with a user study. The study shows that our method is preferred to previous approaches even if they use more than 2x the bitrate.},
  file = {:/home/b/data/neurips/pdfs/c7nygmqbhcqetpmfk2oyu62nsit6c33lkivlfsfh53ajqluu4w7q.pdf:pdf;:/home/b/data/neurips/pdfs/447l6k52phfjrjvta65fetnqqx2ghfqrwoaux5eavl3pr62mz7ja.pdf:pdf},
