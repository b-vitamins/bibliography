}

@inproceedings{zhang2020fgail,
  author = {Zhang, Xin and Li, Yanhua and Zhang, Ziming and Zhang, Zhi-Li},
  title = {f-GAIL: Learning f-Divergence for Generative Adversarial Imitation Learning},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2020},
  volume = {33},
  url = {https://proceedings.neurips.cc/paper_files/paper/2020/hash/967990de5b3eac7b87d49a13c6834978-Abstract.html},
