}

@inproceedings{borovitskiy2020matern,
  author = {Borovitskiy, Viacheslav and Terenin, Alexander and Mostowsky, Peter and Deisenroth (he/him), Marc},
  title = {Matérn Gaussian Processes on Riemannian Manifolds},
  booktitle = {Advances in Neural Information Processing Systems},
