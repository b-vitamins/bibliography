  editor = {H. Larochelle and M. Ranzato and R. Hadsell and M.F. Balcan and H. Lin},
  eprint = {2012.03137},
  primaryclass = {cs.LG}
}

@inproceedings{letham2020reexamining,
  author = {Letham, Ben and Calandra, Roberto and Rai, Akshara and Bakshy, Eytan},
