@inproceedings{ailon2011active,
  author = {Ailon, Nir},
  title = {Active Learning Ranking from Pairwise Preferences with Almost Optimal Query Complexity},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2011},
  volume = {24},
  url = {https://proceedings.neurips.cc/paper_files/paper/2011/hash/81448138f5f163ccdba4acc69819f280-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2011/file/81448138f5f163ccdba4acc69819f280-Paper.pdf},
  abstract = {Given a set $V$ of $n$ elements we wish to linearly order them using pairwise preference labels which may be non-transitive (due to irrationality or arbitrary noise). The goal is to linearly order the elements while disagreeing with as few pairwise preference labels as possible. Our performance is measured by two parameters: The number of disagreements (loss) and the query complexity (number of pairwise preference labels). Our algorithm adaptively queries at most $O(n\poly(łog n,\eps^-1))$ preference labels for a regret of $\eps$ times the optimal loss. This is strictly better, and often significantly better than what non-adaptive sampling could achieve. Our main result helps settle an open problem posed by learning-to-rank (from pairwise information) theoreticians and practitioners: What is a provably correct way to sample preference labels?},
  file = {:/home/b/data/neurips/pdfs/oj5gdzzkxp7zqapvzl44sf2x7emb75gbtzogoquuzshutbejrfoa.pdf:pdf},
  editor = {J. Shawe-Taylor and R. Zemel and P. Bartlett and F. Pereira and K.Q. Weinberger}
}

@inproceedings{yilmaz2011generalised,
