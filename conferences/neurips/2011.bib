}

@inproceedings{turner2011probabilistic,
  author = {Turner, Richard and Sahani, Maneesh},
  title = {Probabilistic amplitude and frequency demodulation},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2011},
  volume = {24},
  url = {https://proceedings.neurips.cc/paper_files/paper/2011/hash/c3992e9a68c5ae12bd18488bc579b30d-Abstract.html},
