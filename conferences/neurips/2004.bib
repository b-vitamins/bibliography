@inproceedings{solem2004surface,
  author = {Solem, Jan and Kahl, Fredrik},
  title = {Surface Reconstruction using Learned Shape Models},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {MIT Press},
  year = {2004},
