}

@inproceedings{gramacy2002adaptive,
  author = {Gramacy, Robert B and Warmuth, Manfred K. K and Brandt, Scott and Ari, Ismail},
  title = {Adaptive Caching by Refetching},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {MIT Press},
