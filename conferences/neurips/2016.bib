  editor = {D. Lee and M. Sugiyama and U. Luxburg and I. Guyon and R. Garnett},
  eprint = {1406.1837},
  primaryclass = {cs.LG}
}

@inproceedings{cuong2016adaptive,
  author = {Cuong, Nguyen and Xu, Huan},
