}

@inproceedings{kandasamy2016multifidelity,
  author = {Kandasamy, Kirthevasan and Dasarathy, Gautam and Poczos, Barnabas and Schneider, Jeff},
  title = {The Multi-fidelity Multi-armed Bandit},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2016},
  volume = {29},
  url = {https://proceedings.neurips.cc/paper_files/paper/2016/hash/2ba596643cbbbc20318224181fa46b28-Abstract.html},
