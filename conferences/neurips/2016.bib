@inproceedings{de2016learning,
  author = {De, Abir and Valera, Isabel and Ganguly, Niloy and Bhattacharya, Sourangshu and Gomez Rodriguez, Manuel},
  title = {Learning and Forecasting Opinion Dynamics in Social Networks},
