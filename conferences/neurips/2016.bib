@inproceedings{minami2016differential,
  author = {Minami, Kentaro and Arai, HItomi and Sato, Issei and Nakagawa, Hiroshi},
  title = {Differential Privacy without Sensitivity},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2016},
  volume = {29},
  url = {https://proceedings.neurips.cc/paper_files/paper/2016/hash/a7aeed74714116f3b292a982238f83d2-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2016/file/a7aeed74714116f3b292a982238f83d2-Paper.pdf},
  abstract = {The exponential mechanism is a general method to construct a randomized estimator that satisfies $(ɛ, 0)$-differential privacy. Recently, Wang et al. showed that the Gibbs posterior, which is a data-dependent probability distribution that contains the Bayesian posterior, is essentially equivalent to the exponential mechanism under certain boundedness conditions on the loss function. While the exponential mechanism provides a way to build an $(ɛ, 0)$-differential private algorithm, it requires boundedness of the loss function, which is quite stringent for some learning problems. In this paper, we focus on $(ɛ, δ)$-differential privacy of Gibbs posteriors with convex and Lipschitz loss functions. Our result extends the classical exponential mechanism, allowing the loss functions to have an unbounded sensitivity.},
  file = {:/home/b/data/neurips/pdfs/cl5l4t2d5cyasqpajh2woj35f4yb436huiplpovzbawp7xnubgfa.pdf:pdf;:/home/b/data/neurips/pdfs/xvqbeyqgvmwfhwdrcwvmgvysyxnzaf4452hxj5nq2ran25vy3p4q.zip:zip},
