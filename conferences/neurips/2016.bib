  publisher = {Curran Associates, Inc.},
  year = {2016},
  volume = {29},
  url = {https://proceedings.neurips.cc/paper_files/paper/2016/hash/8c01a75941549a705cf7275e41b21f0d-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2016/file/8c01a75941549a705cf7275e41b21f0d-Paper.pdf},
  abstract = {In stochastic convex optimization the goal is to minimize a convex function $F(x) ≐ \E_f∼ D[f(x)]$ over a convex set $\K ⊂ \R^d$ where $D$ is some unknown distribution and each $f(·)$ in the support of $D$ is convex over $\K$. The optimization is based on i.i.d.~samples $f^1,f^2,łdots,f^n$ from $D$. A common approach to such problems is empirical risk minimization (ERM) that optimizes $F_S(x) ≐ \frac1n∑_iłeq n f^i(x)$. Here we consider the question of how many samples are necessary for ERM to succeed and the closely related question of uniform convergence of $F_S$ to $F$ over $\K$. We demonstrate that in the standard $\ell_p/\ell_q$ setting of Lipschitz-bounded functions over a $\K$ of bounded radius, ERM requires sample size that scales linearly with the dimension $d$. This nearly matches standard upper bounds and improves on $Ømega(łog d)$ dependence proved for $\ell_2/\ell_2$ setting in (Shalev-Shwartz et al. 2009). In stark contrast, these problems can be solved using dimension-independent number of samples for $\ell_2/\ell_2$ setting and $łog d$ dependence for $\ell_1/\ell_ınfty$ setting using other approaches. We also demonstrate that for a more general class of range-bounded (but not Lipschitz-bounded) stochastic convex programs an even stronger gap appears already in dimension 2.},
  file = {:/home/b/data/neurips/pdfs/4grpnzypkbmoctdik7l47oznox2f4ik5a4lat5lyjmohjtzyui2a.pdf:pdf;:/home/b/data/neurips/pdfs/t7iau2ylqjq6ymposchb66cfz6upqfkuydrsvx7qh3536bhl5dqq.zip:zip},
  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/1608.04414},
  editor = {D. Lee and M. Sugiyama and U. Luxburg and I. Guyon and R. Garnett},
  eprint = {1608.04414},
  primaryclass = {cs.LG}
}

@inproceedings{ciliberto2016consistent,
