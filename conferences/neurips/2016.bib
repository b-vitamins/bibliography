@inproceedings{chaudhuri2016phased,
  author = {Chaudhuri, Sougata and Tewari, Ambuj},
  title = {Phased Exploration with Greedy Exploitation in Stochastic Combinatorial Partial Monitoring Games},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2016},
  volume = {29},
  url = {https://proceedings.neurips.cc/paper_files/paper/2016/hash/b51a15f382ac914391a58850ab343b00-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2016/file/b51a15f382ac914391a58850ab343b00-Paper.pdf},
  abstract = {Partial monitoring games are repeated games where the learner receives feedback that might be different from adversary's move or even the reward gained by the learner. Recently, a general model of combinatorial partial monitoring (CPM) games was proposed i̧telincombinatorial2014, where the learner's action space can be exponentially large and adversary samples its moves from a bounded, continuous space, according to a fixed distribution. The paper gave a confidence bound based algorithm (GCB) that achieves $O(T^2/3łog T)$ distribution independent and $O(łog T)$ distribution dependent regret bounds. The implementation of their algorithm depends on two separate offline oracles and the distribution dependent regret additionally requires existence of a unique optimal action for the learner. Adopting their CPM model, our first contribution is a Phased Exploration with Greedy Exploitation (PEGE) algorithmic framework for the problem. Different algorithms within the framework achieve $O(T^2/3\sqrtłog T)$ distribution independent and $O(łog^2 T)$ distribution dependent regret respectively. Crucially, our framework needs only the simpler ``argmax'' oracle from GCB and the distribution dependent regret does not require existence of a unique optimal action. Our second contribution is another algorithm, PEGE2, which combines gap estimation with a PEGE algorithm, to achieve an $O(łog T)$ regret bound, matching the GCB guarantee but removing the dependence on size of the learner's action space. However, like GCB, PEGE2 requires access to both offline oracles and the existence of a unique optimal action. Finally, we discuss how our algorithm can be efficiently applied to a CPM problem of practical interest: namely, online ranking with feedback at the top.},
  file = {:/home/b/data/neurips/pdfs/smvnys4icvzeiep7a57wkja5vzppzmsci4kswtem3kxejwiw5b7a.pdf:pdf;:/home/b/data/neurips/pdfs/33igt2i3tijnycd2c3dgp3cno2oeqhwe7f2bvyqv3wcvgw34htlq.zip:zip},
  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/1608.06403},
  editor = {D. Lee and M. Sugiyama and U. Luxburg and I. Guyon and R. Garnett},
  eprint = {1608.06403},
  primaryclass = {cs.GT}
}

@inproceedings{suzuki2016minimax,
  author = {Suzuki, Taiji and Kanagawa, Heishiro and Kobayashi, Hayato and Shimizu, Nobuyuki and Tagami, Yukihiro},
  title = {Minimax Optimal Alternating Minimization for Kernel Nonparametric Tensor Learning},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
