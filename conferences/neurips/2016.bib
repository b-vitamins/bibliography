@inproceedings{sonderby2016ladder,
  author = {Sø nderby, Casper Kaae and Raiko, Tapani and Maalø e, Lars and Sø nderby, Sø ren Kaae and Winther, Ole},
  title = {Ladder Variational Autoencoders},
