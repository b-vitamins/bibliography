  url = {https://proceedings.neurips.cc/paper_files/paper/2016/hash/fb87582825f9d28a8d42c5e5e5e8b23d-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2016/file/fb87582825f9d28a8d42c5e5e5e8b23d-Paper.pdf},
  abstract = {The move from hand-designed features to learned features in machine learning has been wildly successful. In spite of this, optimization algorithms are still designed by hand. In this paper we show how the design of an optimization algorithm can be cast as a learning problem, allowing the algorithm to learn to exploit structure in the problems of interest in an automatic way. Our learned algorithms, implemented by LSTMs, outperform generic, hand-designed competitors on the tasks for which they are trained, and also generalize well to new tasks with similar structure. We demonstrate this on a number of tasks, including simple convex problems, training neural networks, and styling images with neural art.},
  file = {:/home/b/data/neurips/pdfs/mmrz5wmgytzedhre4uxnese56ld7xdxaurabhsyv5gfivjy5co7a.pdf:pdf;:/home/b/data/neurips/pdfs/pttkrcv4o54dogkljh5eav2ee3m77oegve2ir5p2lghivqagnv2q.zip:zip},
  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/1606.04474},
  editor = {D. Lee and M. Sugiyama and U. Luxburg and I. Guyon and R. Garnett},
  eprint = {1606.04474},
  primaryclass = {cs.NE}
}

