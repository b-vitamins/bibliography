  editor = {D. Lee and M. Sugiyama and U. Luxburg and I. Guyon and R. Garnett}
}

@inproceedings{syrgkanis2016improved,
  author = {Syrgkanis, Vasilis and Luo, Haipeng and Krishnamurthy, Akshay and Schapire, Robert E},
  title = {Improved Regret Bounds for Oracle-Based Adversarial Contextual Bandits},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2016},
  volume = {29},
  url = {https://proceedings.neurips.cc/paper_files/paper/2016/hash/dfa92d8f817e5b08fcaafb50d03763cf-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2016/file/dfa92d8f817e5b08fcaafb50d03763cf-Paper.pdf},
  abstract = {We propose a new oracle-based algorithm, BISTRO+, for the adversarial contextual bandit problem, where either contexts are drawn i.i.d. or the sequence of contexts is known a priori, but where the losses are picked adversarially. Our algorithm is computationally efficient, assuming access to an offline optimization oracle, and enjoys a regret of order $O((KT)^\frac23(łog N)^\frac13)$, where $K$ is the number of actions, $T$ is the number of iterations, and $N$ is the number of baseline policies. Our result is the first to break the $O(T^\frac34)$ barrier achieved by recent algorithms, which was left as a major open problem. Our analysis employs the recent relaxation framework of (Rakhlin and Sridharan, ICML'16).},
  file = {:/home/b/data/neurips/pdfs/sb66qlhcog74idqfrsubzf6tpeuigd56lhfwvzgyknc3stm7sq5q.pdf:pdf;:/home/b/data/neurips/pdfs/ka5dxdc6rfyoinu4rrcqiwsmzzfbkimzjrxh7cynbscyevocwaxa.zip:zip},
  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/1606.00313},
  editor = {D. Lee and M. Sugiyama and U. Luxburg and I. Guyon and R. Garnett},
  eprint = {1606.00313},
  primaryclass = {cs.LG}
}

@inproceedings{finn2016unsupervised,
  author = {Finn, Chelsea and Goodfellow, Ian and Levine, Sergey},
  title = {Unsupervised Learning for Physical Interaction through Video Prediction},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2016},
  volume = {29},
  url = {https://proceedings.neurips.cc/paper_files/paper/2016/hash/d9d4f495e875a2e075a1a4a6e1b9770f-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2016/file/d9d4f495e875a2e075a1a4a6e1b9770f-Paper.pdf},
  abstract = {A core challenge for an agent learning to interact with the world is to predict how its actions affect objects in its environment. Many existing methods for learning the dynamics of physical interactions require labeled object information. However, to scale real-world interaction learning to a variety of scenes and objects, acquiring labeled data becomes increasingly impractical. To learn about physical object motion without labels, we develop an action-conditioned video prediction model that explicitly models pixel motion, by predicting a distribution over pixel motion from previous frames. Because our model explicitly predicts motion, it is partially invariant to object appearance, enabling it to generalize to previously unseen objects. To explore video prediction for real-world interactive agents, we also introduce a dataset of 59,000 robot interactions involving pushing motions, including a test set with novel objects. In this dataset, accurate prediction of videos conditioned on the robot's future actions amounts to learning a "visual imagination" of different futures based on different courses of action. Our experiments show that our proposed method produces more accurate video predictions both quantitatively and qualitatively, when compared to prior methods.},
  file = {:/home/b/data/neurips/pdfs/phmo6dkzy5av4xlue3ekfsomzr2g23qeispq6hv37pqqw7ur4loq.pdf:pdf;:/home/b/data/neurips/pdfs/kf4y4io3zca2g7v2v6zquk6zu4q53jn7ehk756vxkttkbp4xcrbq.zip:zip},
  archiveprefix = {arXiv},
  arxiv = {https://arxiv.org/abs/1605.07157},
  editor = {D. Lee and M. Sugiyama and U. Luxburg and I. Guyon and R. Garnett},
  eprint = {1605.07157},
  primaryclass = {cs.LG}
}

@inproceedings{johnson2016unified,
  author = {Johnson, Tyler B and Guestrin, Carlos},
  title = {Unified Methods for Exploiting Piecewise Linear Structure in Convex Optimization},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2016},
  volume = {29},
  url = {https://proceedings.neurips.cc/paper_files/paper/2016/hash/cb2c2041d9763d84d7d655e81178f444-Abstract.html},
  pdf = {https://proceedings.neurips.cc/paper_files/paper/2016/file/cb2c2041d9763d84d7d655e81178f444-Paper.pdf},
  abstract = {We develop methods for rapidly identifying important components of a convex optimization problem for the purpose of achieving fast convergence times. By considering a novel problem formulation—the minimization of a sum of piecewise functions—we describe a principled and general mechanism for exploiting piecewise linear structure in convex optimization. This result leads to a theoretically justified working set algorithm and a novel screening test, which generalize and improve upon many prior results on exploiting structure in convex optimization. In empirical comparisons, we study the scalability of our methods. We find that screening scales surprisingly poorly with the size of the problem, while our working set algorithm convincingly outperforms alternative approaches.},
  file = {:/home/b/data/neurips/pdfs/ddowxu3zx2rku6wbgvrfb4jsteevlwomzulbd62gvl5wmq4mm2zq.pdf:pdf},
  editor = {D. Lee and M. Sugiyama and U. Luxburg and I. Guyon and R. Garnett}
}

@inproceedings{sangnier2016joint,
  author = {Sangnier, Maxime and Fercoq, Olivier and d' Alché-Buc, Florence},
