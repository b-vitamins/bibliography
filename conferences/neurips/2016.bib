}

@inproceedings{jitkrittum2016interpretable,
  author = {Jitkrittum, Wittawat and Szabó, Zoltán and Chwialkowski, Kacper P and Gretton, Arthur},
  title = {Interpretable Distribution Features with Maximum Testing Power},
