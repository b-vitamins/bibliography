  eprint = {1701.00757},
  primaryclass = {stat.ML}
}

@inproceedings{zhang2016reshaped,
  author = {Zhang, Huishuai and Liang, Yingbin},
  title = {Reshaped Wirtinger Flow for Solving Quadratic System of Equations},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2016},
  volume = {29},
  url = {https://proceedings.neurips.cc/paper_files/paper/2016/hash/83adc9225e4deb67d7ce42d58fe5157c-Abstract.html},
