@inproceedings{huang2016following,
  author = {Huang, Ruitong and Lattimore, Tor and György, András and Szepesvari, Csaba},
  title = {Following the Leader and Fast Rates in Linear Prediction: Curved Constraint Sets and Other Regularities},
  booktitle = {Advances in Neural Information Processing Systems},
  publisher = {Curran Associates, Inc.},
  year = {2016},
  volume = {29},
  url = {https://proceedings.neurips.cc/paper_files/paper/2016/hash/55a988dfb00a914717b3000a3374694c-Abstract.html},
