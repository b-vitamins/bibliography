  publisher = {MIT Press},
  title = {Using Expectation to Guide Processing: A Study of Three Real-World Applications},
  url = {https://proceedings.neurips.cc/paper_files/paper/1997/hash/8d9a0adb7c204239c9635426f35c9522-Abstract.html},
  volume = {10},
  year = {1997}
}

@inproceedings{elyaniv1997agnostic,
  abstract = {Classification of finite sequences without explicit knowledge of their statistical nature is a fundamental problem with many important applications. We propose a new information theoretic approach to this problem which is based on the following ingredients: (i) se(cid:173) quences are similar when they are likely to be generated by the same source; (ii) cross entropies can be estimated via "universal compres(cid:173) sion"; (iii) Markovian sequences can be asymptotically-optimally merged. With these ingredients we design a method for the classification of discrete sequences whenever they can be compressed. We introduce the method and illustrate its application for hierarchical clustering of languages and for estimating similarities of protein sequences.},
  author = {El-Yaniv, Ran and Fine, Shai and Tishby, Naftali},
  booktitle = {Advances in Neural Information Processing Systems},
