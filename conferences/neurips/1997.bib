  publisher = {MIT Press},
  title = {RCC Cannot Compute Certain FSA, Even with Arbitrary Transfer Functions},
  url = {https://proceedings.neurips.cc/paper_files/paper/1997/hash/299fb2142d7de959380f91c01c3a293c-Abstract.html},
  volume = {10},
  year = {1997}
}

