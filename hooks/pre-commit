#!/bin/bash
# Pre-commit hook to auto-export enrichment tracking database

# Opt-in auto export to avoid constant timestamp drift in tracking.json.
if [ "${BIBOPS_AUTO_EXPORT_TRACKING:-0}" != "1" ]; then
    exit 0
fi

# Check if database exists
if [ -f "bibliography.db" ]; then
    echo "Exporting enrichment tracking data (BIBOPS_AUTO_EXPORT_TRACKING=1)..."
    guix shell -m manifest.scm -- python3 scripts/export-tracking.py tracking.json

    # Note: tracking.json updated but not auto-added to avoid timestamp-only commits.
    # Add manually if enrichment data changed: git add tracking.json
fi

# Continue with commit
exit 0
